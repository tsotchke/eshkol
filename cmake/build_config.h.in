#pragma once

#define ESHKOL_HOST_CXX_COMPILER "@ESHKOL_HOST_CXX_COMPILER@"
#define ESHKOL_HOST_LLVM_MAJOR @ESHKOL_REQUIRED_LLVM_MAJOR@
#define ESHKOL_HOST_CUDA_MAJOR @ESHKOL_HOST_CUDA_MAJOR@
#define ESHKOL_HOST_LLC_EXECUTABLE "@LLC_EXECUTABLE@"
#define ESHKOL_HOST_EXECUTABLE_SUFFIX "@CMAKE_EXECUTABLE_SUFFIX@"
#define ESHKOL_HOST_STATIC_LIBRARY_PREFIX "@CMAKE_STATIC_LIBRARY_PREFIX@"
#define ESHKOL_HOST_STATIC_LIBRARY_SUFFIX "@CMAKE_STATIC_LIBRARY_SUFFIX@"
#define ESHKOL_HOST_RUNTIME_LINK_ARGS "@ESHKOL_HOST_RUNTIME_LINK_ARGS@"
