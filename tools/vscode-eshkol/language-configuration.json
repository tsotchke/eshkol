{
  "comments": {
    "lineComment": ";",
    "blockComment": ["#|", "|#"]
  },
  "brackets": [
    ["(", ")"],
    ["[", "]"],
    ["{", "}"]
  ],
  "autoClosingPairs": [
    { "open": "(", "close": ")" },
    { "open": "[", "close": "]" },
    { "open": "{", "close": "}" },
    { "open": "\"", "close": "\"", "notIn": ["string"] },
    { "open": "#|", "close": "|#" }
  ],
  "surroundingPairs": [
    ["(", ")"],
    ["[", "]"],
    ["{", "}"],
    ["\"", "\""]
  ],
  "indentationRules": {
    "increaseIndentPattern": "^\\s*\\((?:define|lambda|let|let\\*|letrec|begin|if|cond|case|when|unless|do|guard|with-region|borrow|match)\\b",
    "decreaseIndentPattern": "^\\s*\\)"
  },
  "wordPattern": "[a-zA-Z_][a-zA-Z0-9_\\-!?*+/<>=.]*|[+\\-*/<>=!?][a-zA-Z0-9_\\-!?*+/<>=.]*",
  "onEnterRules": [
    {
      "beforeText": "^\\s*\\(",
      "action": { "indent": "indent" }
    }
  ]
}
