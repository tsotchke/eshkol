;;
;; subprocess.esk - Subprocess management FFI wrapper
;;
;; Eshkol bindings to qLLM's subprocess.c for process spawning,
;; I/O capture, timeout, and lifecycle management.
;;

(provide process-spawn process-spawn-shell process-spawn-argv
         process-write-stdin process-close-stdin
         process-read-stdout process-read-stderr
         process-read-all-stdout process-read-all-stderr
         process-wait process-running? process-exit-code
         process-kill process-destroy
         run-command run-command-capture
         run-argv run-argv-capture)

;; ============================================================================
;; FFI Declarations
;; ============================================================================

(extern ptr process-spawn-raw ptr ptr ptr i64 :real qllm_process_spawn)
(extern ptr process-spawn-shell-raw ptr ptr i64 :real qllm_process_spawn_shell)
(extern ptr process-spawn-argv-raw ptr ptr :real qllm_process_spawn_argv)
(extern ptr process-spawn-argv-flags-raw ptr ptr i64 :real qllm_process_spawn_argv_flags)
(extern i64 process-write-stdin-raw ptr ptr i64 :real qllm_process_write_stdin)
(extern void process-close-stdin-raw ptr :real qllm_process_close_stdin)
(extern i64 process-read-stdout-raw ptr ptr i64 :real qllm_process_read_stdout)
(extern i64 process-read-stderr-raw ptr ptr i64 :real qllm_process_read_stderr)
(extern ptr process-read-all-stdout-raw ptr i64 ptr :real qllm_process_read_all_stdout)
(extern ptr process-read-all-stderr-raw ptr i64 ptr :real qllm_process_read_all_stderr)
(extern void process-free-buffer-raw ptr :real qllm_process_free_buffer)
(extern i32 process-wait-raw ptr i32 :real qllm_process_wait)
(extern i32 process-running-raw ptr :real qllm_process_running)
(extern i32 process-exit-code-raw ptr :real qllm_process_exit_code)
(extern void process-kill-raw ptr i32 :real qllm_process_kill)
(extern void process-destroy-raw ptr :real qllm_process_destroy)

;; ============================================================================
;; High-Level Wrappers
;; ============================================================================

;; flags bitmask for process-spawn-raw. Bit 0 = child's stdin is wired
;; to /dev/null instead of a pipe, saving a pipe() + close() pair per
;; call (~100 us on macOS). Use whenever the caller won't write to
;; stdin (the common case — run-command-capture and friends all close
;; stdin immediately).
(define PROCESS_SPAWN_STDIN_NULL 1)

(define (process-spawn command cwd)
  "Spawn a legacy command string. Returns process handle or #f on failure.
   command: shell-compatible command string. The native layer may bypass the
   platform shell for simple commands where direct argv execution is equivalent.
   cwd: working directory."
  (process-spawn-raw command cwd #f 0))

(define (process-spawn-nostdin command cwd)
  "Spawn a legacy command string with stdin redirected to /dev/null. Faster than
   process-spawn + process-close-stdin when the caller never writes
   to stdin (hot path for run-command-capture)."
  (process-spawn-raw command cwd #f PROCESS_SPAWN_STDIN_NULL))

(define (process-spawn-shell command cwd)
  "Spawn a command through the platform shell. Returns process handle."
  (process-spawn-shell-raw command cwd 0))

(define (process-spawn-shell-nostdin command cwd)
  "Spawn a shell command with stdin redirected to /dev/null."
  (process-spawn-shell-raw command cwd PROCESS_SPAWN_STDIN_NULL))

(define (process-owned-c-string->string buf)
  "Copy a malloc-owned C string into Eshkol space, then free it."
  (if buf
      (let ((s (ptr->string buf)))
        (process-free-buffer-raw buf)
        s)
      ""))

;; Audit M9: an argv element containing a literal tab would get
;; re-split by the C-side parse_tab_argv. Reject such args explicitly
;; rather than silently splitting them — shell-style quoting is NOT
;; provided (use process-spawn if you need shell semantics; otherwise
;; argv is strict positional). Also reject NUL bytes for the same
;; truncation-at-C-boundary reason the symbol interner has.
(define (process-argv-check-args argv)
  (for-each
   (lambda (a)
     (unless (string? a)
       (error "process-spawn-argv: argv entries must be strings" a))
     (when (string-contains a "\t")
       (error "process-spawn-argv: argv element contains literal TAB "
              "(would be re-split by the underlying tab-separated wire "
              "format); pass it via a wrapper or escape it externally" a))
     (when (string-contains a "\x00")
       (error "process-spawn-argv: argv element contains NUL byte "
              "(would truncate at the C boundary)" a)))
   argv))

;; process-spawn-argv: safe spawn that does NOT use a shell.
;; argv is a list of strings (program first); we tab-join and pass to
;; the native side which calls execvp. No shell means no injection —
;; prefer this over process-spawn when the arguments are user-controlled.
(define (process-spawn-argv argv cwd)
  "Spawn a process without a shell. argv is a list: (program arg1 arg2 ...).
   Returns process handle or #f on failure. Safe against shell injection."
  (cond
    ((null? argv) #f)
    ((not (list? argv)) #f)
    (else
     (process-argv-check-args argv)
     (let loop ((rest (cdr argv)) (packed (car argv)))
       (if (null? rest)
           (process-spawn-argv-raw packed cwd)
           (loop (cdr rest)
                 (string-append packed "\t" (car rest))))))))

;; Argv spawn with stdin wired to /dev/null. Hot path for run-argv-capture
;; — saves a pipe() + 2 close()s per call (~100 us). See comment on
;; PROCESS_SPAWN_STDIN_NULL above.
(define (process-spawn-argv-nostdin argv cwd)
  "Spawn an argv list without a shell, with stdin wired to /dev/null.
   Faster than process-spawn-argv + process-close-stdin."
  (cond
    ((null? argv) #f)
    ((not (list? argv)) #f)
    (else
     (process-argv-check-args argv)
     (let loop ((rest (cdr argv)) (packed (car argv)))
       (if (null? rest)
           (process-spawn-argv-flags-raw packed cwd PROCESS_SPAWN_STDIN_NULL)
           (loop (cdr rest)
                 (string-append packed "\t" (car rest))))))))

(define (process-write-stdin proc data)
  "Write data to process stdin. Returns bytes written or -1 on error."
  (process-write-stdin-raw proc data (string-length data)))

(define (process-close-stdin proc)
  "Close process stdin (signal EOF)."
  (process-close-stdin-raw proc))

(define (process-read-stdout proc max-bytes)
  "Read available stdout. Returns string or empty string."
  (process-owned-c-string->string
    (process-read-all-stdout-raw proc max-bytes #f)))

(define (process-read-stderr proc max-bytes)
  "Read available stderr. Returns string or empty string."
  (process-owned-c-string->string
    (process-read-all-stderr-raw proc max-bytes #f)))

(define (process-read-all-stdout proc max-bytes)
  "Read all stdout until EOF. Returns string."
  (process-read-stdout proc max-bytes))

(define (process-read-all-stderr proc max-bytes)
  "Read all stderr until EOF. Returns string."
  (process-read-stderr proc max-bytes))

(define (process-wait proc timeout-ms)
  "Wait for process to exit. Returns: 0=exited, 1=timeout, -1=error."
  (process-wait-raw proc timeout-ms))

(define (process-running? proc)
  "Check if process is still running."
  (= (process-running-raw proc) 1))

(define (process-exit-code proc)
  "Get exit code. Only valid after process-wait returns 0."
  (process-exit-code-raw proc))

(define (process-kill proc . signal)
  "Kill process. Default signal is SIGTERM (15)."
  (process-kill-raw proc (if (null? signal) 15 (car signal))))

(define (process-destroy proc)
  "Free all process resources. Kills process if still running."
  (process-destroy-raw proc))

;; ============================================================================
;; Convenience Functions
;; ============================================================================

(define (run-command command . rest)
  "Run a command and wait for completion.
   Args: command [cwd] [timeout-ms]. Returns: exit code (integer)."
  (let* ((cwd (if (> (length rest) 0) (list-ref rest 0) "."))
         (timeout-ms (if (> (length rest) 1) (list-ref rest 1) 30000))
         (proc (process-spawn-shell command cwd)))
    (if (not proc)
        -1
        (begin
          (process-close-stdin proc)
          (let ((wait-result (process-wait proc timeout-ms)))
            (let ((code (if (= wait-result 0)
                            (process-exit-code proc)
                            (begin
                              (process-kill proc)
                              (process-wait proc 5000)
                              -1))))
              (process-destroy proc)
              code))))))

(define (run-command-capture command . rest)
  "Run a command and capture stdout/stderr.
   Args: command [cwd] [timeout-ms] [max-output]. Returns: alist."
  (let* ((cwd (if (> (length rest) 0) (list-ref rest 0) "."))
         (timeout-ms (if (> (length rest) 1) (list-ref rest 1) 30000))
         (max-output (if (> (length rest) 2) (list-ref rest 2) 4194304))
         ;; stdin is never written to in run-command-capture — wire
         ;; it straight to /dev/null in the child and skip the pipe().
         ;; Drops per-call syscall count by a pipe + 2 closes; the
         ;; subsequent process-close-stdin becomes a no-op.
         (proc (process-spawn-shell-nostdin command cwd)))
    (if (not proc)
        (list (cons 'exit-code -1)
              (cons 'stdout "")
              (cons 'stderr "Error: failed to spawn process"))
        (let* ((wait-result (process-wait proc timeout-ms))
               (timed-out (= wait-result 1))
               (_ (when timed-out
                    (process-kill proc)
                    (process-wait proc 5000)))
               (stdout (process-read-all-stdout proc max-output))
               (stderr (process-read-all-stderr proc max-output))
               (code (if timed-out 124 (process-exit-code proc))))
          (process-destroy proc)
          (list (cons 'exit-code code)
                (cons 'stdout stdout)
                (cons 'stderr (if timed-out
                                  (string-append stderr "\n[Process timed out after "
                                                 (number->string (/ timeout-ms 1000))
                                                 "s]")
                                  stderr)))))))

;; ============================================================================
;; Safe (argv-based, no-shell) Convenience Wrappers — #190
;; ============================================================================

(define (run-argv argv . rest)
  "Run an argv list (program + args) to completion without a shell.
   argv: (program arg1 arg2 ...). Safe against shell injection.
   Args: argv [cwd] [timeout-ms]. Returns exit code."
  (let* ((cwd (if (> (length rest) 0) (list-ref rest 0) "."))
         (timeout-ms (if (> (length rest) 1) (list-ref rest 1) 30000))
         (proc (process-spawn-argv-nostdin argv cwd)))
    (if (not proc)
        -1
        (let ((wait-result (process-wait proc timeout-ms)))
          (let ((code (if (= wait-result 0)
                          (process-exit-code proc)
                          (begin
                            (process-kill proc)
                            (process-wait proc 5000)
                            -1))))
            (process-destroy proc)
            code)))))

(define (run-argv-capture argv . rest)
  "Run argv list and capture stdout/stderr without a shell.
   argv: (program arg1 arg2 ...). Safe against shell injection.
   Args: argv [cwd] [timeout-ms] [max-output]. Returns alist."
  (let* ((cwd (if (> (length rest) 0) (list-ref rest 0) "."))
         (timeout-ms (if (> (length rest) 1) (list-ref rest 1) 30000))
         (max-output (if (> (length rest) 2) (list-ref rest 2) 4194304))
         ;; stdin-null fast path — wire the child's stdin straight to
         ;; /dev/null instead of creating a pipe we won't use. Saves
         ;; ~100 us per call on the benchmark hot loop.
         (proc (process-spawn-argv-nostdin argv cwd)))
    (if (not proc)
        (list (cons 'exit-code -1)
              (cons 'stdout "")
              (cons 'stderr "Error: failed to spawn process"))
        (let* ((wait-result (process-wait proc timeout-ms))
               (timed-out (= wait-result 1))
               (_ (when timed-out
                    (process-kill proc)
                    (process-wait proc 5000)))
               (stdout (process-read-all-stdout proc max-output))
               (stderr (process-read-all-stderr proc max-output))
               (code (if timed-out 124 (process-exit-code proc))))
          (process-destroy proc)
          (list (cons 'exit-code code)
                (cons 'stdout stdout)
                (cons 'stderr stderr))))))
