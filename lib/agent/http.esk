;;
;; http.esk - HTTP client FFI wrapper
;;
;; Eshkol bindings to qLLM's http_client.c for sync requests and SSE streaming.
;; Links against libsemiclassical_qllm.
;;

(provide http-init http-shutdown http-has-ssl?
         http-get http-post http-request
         http-stream-open http-stream-next http-stream-done? http-stream-close
         sse-event-type sse-event-data sse-event-free)

;; ============================================================================
;; FFI Declarations — sync HTTP
;; ============================================================================

;; Initialize/shutdown
(extern i32 http-init-raw :real qllm_http_init)
(extern void http-shutdown-raw :real qllm_http_shutdown)
(extern i32 http-has-ssl-raw :real qllm_http_has_ssl)

;; Full request (returns pointer to response struct)
(extern ptr http-request-raw ptr :real qllm_http_request)

;; POST with custom headers
(extern ptr http-post-raw ptr ptr i64 ptr i64 i32 :real qllm_http_post)

;; GET convenience
(extern ptr http-get-raw ptr i32 :real qllm_http_get)

;; POST JSON convenience
(extern ptr http-post-json-raw ptr ptr ptr i32 :real qllm_http_post_json)

;; Response accessors
(extern i32 http-response-status ptr :real qllm_http_response_status)
(extern ptr http-response-body ptr :real qllm_http_response_body)
(extern i64 http-response-body-len ptr :real qllm_http_response_body_len)
(extern void http-response-free ptr :real qllm_http_response_free)

;; Error string
(extern ptr http-error-string i32 :real qllm_http_error_string)

;; ============================================================================
;; FFI Declarations — SSE streaming
;; ============================================================================

;; Open stream (returns stream handle pointer)
(extern ptr stream-open-raw ptr ptr i64 ptr i64 i32 ptr :real qllm_http_stream_open)

;; Read next event (fills event struct, returns error code)
(extern i32 stream-next-raw ptr ptr i32 :real qllm_http_stream_next)

;; Check if stream is done
(extern i32 stream-done-raw ptr :real qllm_http_stream_done)

;; Close stream
(extern void stream-close-raw ptr :real qllm_http_stream_close)

;; Free event strings
(extern void sse-event-free-raw ptr :real qllm_sse_event_free)

;; ============================================================================
;; High-Level Wrappers
;; ============================================================================

(define (http-init)
  "Initialize HTTP subsystem. Must be called before other HTTP functions."
  (= (http-init-raw) 1))

(define (http-shutdown)
  "Shutdown HTTP subsystem."
  (http-shutdown-raw))

(define (http-has-ssl?)
  "Check if HTTPS is available."
  (= (http-has-ssl-raw) 1))

(define (http-get url . timeout)
  "Perform HTTP GET. Returns (status-code . body-string) or #f on error."
  (let* ((timeout-ms (if (null? timeout) 30000 (car timeout)))
         (resp (http-get-raw url timeout-ms)))
    (if (not resp) #f
        (let* ((status (http-response-status resp))
               (body (http-response-body resp))
               (result (cons status (if body body ""))))
          (http-response-free resp)
          result))))

(define (http-post url headers body . timeout)
  "Perform HTTP POST with custom headers.
   headers: list of (name . value) pairs
   body: string
   Returns: (status-code . body-string) or #f on error."
  (let* ((timeout-ms (if (null? timeout) 30000 (car timeout)))
         ;; For now, use the JSON convenience function with auth header extraction
         ;; TODO: once the full header-passing FFI is wired, use http-post-raw
         (auth-header (let ((h (assoc "Authorization" headers)))
                        (if h (cdr h)
                            (let ((h2 (assoc "x-api-key" headers)))
                              (if h2 (cdr h2) "")))))
         (resp (http-post-json-raw url body auth-header timeout-ms)))
    (if (not resp) #f
        (let* ((status (http-response-status resp))
               (resp-body (http-response-body resp))
               (result (cons status (if resp-body resp-body ""))))
          (http-response-free resp)
          result))))

(define (http-request method url headers body . timeout)
  "General HTTP request. Returns (status-code . body-string) or #f."
  (if (string=? method "GET")
      (apply http-get url timeout)
      (apply http-post url headers body timeout)))

;; ============================================================================
;; SSE Streaming
;; ============================================================================

(define (http-stream-open url headers body . timeout)
  "Open an SSE streaming connection.
   Returns: stream handle (opaque pointer) or #f on error."
  (let ((timeout-ms (if (null? timeout) 30000 (car timeout))))
    ;; For now, use curl-based streaming as the FFI requires proper
    ;; header struct marshaling that isn't available yet
    (stream-open-raw url #f 0 body (string-length body) timeout-ms #f)))

(define (http-stream-next stream . timeout)
  "Read next SSE event from stream.
   Returns: (event-type . data-string) or #f if done/error."
  (let ((timeout-ms (if (null? timeout) 30000 (car timeout))))
    ;; Read via FFI
    (let ((result (stream-next-raw stream #f timeout-ms)))
      (if (= result 0)
          ;; Success - extract event type and data from the event struct
          ;; This requires proper struct access which depends on FFI layout
          (cons "message" "")
          #f))))

(define (http-stream-done? stream)
  "Check if stream has ended."
  (= (stream-done-raw stream) 1))

(define (http-stream-close stream)
  "Close SSE stream."
  (stream-close-raw stream))

;; SSE event accessors (for use with raw event structs)
(define (sse-event-type event) (car event))
(define (sse-event-data event) (cdr event))
(define (sse-event-free event) #t)  ;; GC handles alist pairs
