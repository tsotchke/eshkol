;;
;; http.esk - HTTP client FFI wrapper
;;
;; Eshkol bindings to native HTTP clients: NSURLSession on macOS, WinHTTP on
;; Windows, and pinned libcurl/OpenSSL on Linux.  The ABI and behavior are
;; owned by Eshkol and are identical on every supported host.
;;

(require core.capabilities)

(provide http-init http-shutdown http-has-ssl?
         http-get http-post http-request
         http-stream-open http-stream-next http-stream-done? http-stream-error
         http-stream-close sse-event-type sse-event-data sse-event-id
         sse-event-retry-ms sse-event-free)

;; ============================================================================
;; FFI Declarations — sync HTTP
;; ============================================================================

;; Initialize/shutdown
(extern i32 http-init-raw :real qllm_http_init)
(extern void http-shutdown-raw :real qllm_http_shutdown)
(extern i32 http-has-ssl-raw :real qllm_http_has_ssl)

;; Full binary-safe Eshkol request: method, URL, newline-delimited validated
;; headers, body bytes + exact byte length, timeout.
(extern ptr http-request-raw ptr ptr ptr ptr i64 i32 :real eshkol_http_request_bytes)

;; POST with custom headers
(extern ptr http-post-raw ptr ptr i64 ptr i64 i32 :real qllm_http_post)

;; GET convenience
(extern ptr http-get-raw ptr i32 :real qllm_http_get)

;; POST JSON convenience
(extern ptr http-post-json-raw ptr ptr ptr i32 :real qllm_http_post_json)

;; Response accessors
(extern i32 http-response-status ptr :real qllm_http_response_status)
(extern ptr http-response-body ptr :real qllm_http_response_body)
(extern i64 http-response-body-len ptr :real qllm_http_response_body_len)
(extern ptr http-response-error ptr :real qllm_http_response_error)
(extern void http-response-free ptr :real qllm_http_response_free)

;; Error string
(extern ptr http-error-string i32 :real qllm_http_error_string)

;; ============================================================================
;; FFI Declarations — SSE streaming
;; ============================================================================

;; Open stream (method, URL, header block, body bytes + exact length, timeout).
(extern ptr stream-open-raw ptr ptr ptr ptr i64 i32 :real eshkol_http_stream_open_bytes)

;; Read next event (returns owned native event pointer or #f).
(extern ptr stream-next-raw ptr i32 :real eshkol_http_stream_next)

;; Check if stream is done
(extern i32 stream-done-raw ptr :real eshkol_http_stream_done)

;; Last transport/parser error, or #f when none.
(extern ptr stream-error-raw ptr :real eshkol_http_stream_error)

;; Close stream
(extern void stream-close-raw ptr :real eshkol_http_stream_close)

;; Event accessors and ownership.
(extern ptr sse-event-type-raw ptr :real eshkol_sse_event_type)
(extern ptr sse-event-data-raw ptr :real eshkol_sse_event_data)
(extern ptr sse-event-id-raw ptr :real eshkol_sse_event_id)
(extern i64 sse-event-retry-raw ptr :real eshkol_sse_event_retry_ms)
(extern void sse-event-free-raw ptr :real eshkol_sse_event_free)

;; ============================================================================
;; High-Level Wrappers
;; ============================================================================

(define (http-init)
  "Initialize HTTP subsystem. Must be called before other HTTP functions."
  (= (http-init-raw) 1))

(define (http-shutdown)
  "Shutdown HTTP subsystem."
  (http-shutdown-raw))

(define (http-has-ssl?)
  "Check if HTTPS is available."
  (= (http-has-ssl-raw) 1))

;; #195 MEDIUM: URL / header sanitization before dispatch.
;;
;; CRLF injection in a request URL or header value lets an attacker
;; append an extra request to the wire (\r\n<evil-header>) which many
;; HTTP proxies happily forward. NUL in a URL or header truncates at
;; the C boundary and can route the request to the wrong origin.
;; Reject any input containing those bytes before it reaches the
;; curl/libwhatever backend.
;; Audit M8: header-value injection via whitespace-not-\r\n.
;; Some HTTP parsers (notably older proxies and some app frameworks)
;; treat tab and other C0 whitespace as separators within a header
;; value, re-splitting a value like "api.example.com\tHost: evil.com"
;; into two logical headers. Reject tab and the rest of the C0
;; controls in addition to CR/LF/NUL; 0x7f (DEL) too.
(define (http-safe-string? s)
  (and (string? s)
       (not (string-contains s "\r"))
       (not (string-contains s "\n"))
       (not (string-contains s "\t"))
       (not (string-contains s "\x00"))
       (not (string-contains s "\x0b"))   ;; VT
       (not (string-contains s "\x0c"))   ;; FF
       (not (string-contains s "\x7f"))   ;; DEL
       ))

(define (http-token-char? ch)
  (let ((code (char->integer ch)))
    (or (and (>= code 48) (<= code 57))
        (and (>= code 65) (<= code 90))
        (and (>= code 97) (<= code 122))
        (char=? ch #\!) (char=? ch #\#) (char=? ch #\$)
        (char=? ch #\%) (char=? ch #\&) (char=? ch #\')
        (char=? ch #\*) (char=? ch #\+) (char=? ch #\-)
        (char=? ch #\.) (char=? ch #\^) (char=? ch #\_)
        (char=? ch #\`) (char=? ch #\|) (char=? ch #\~))))

(define (http-token-string? s)
  (and (string? s)
       (> (string-length s) 0)
       (let loop ((i 0))
         (or (= i (string-length s))
             (and (http-token-char? (string-ref s i))
                  (loop (+ i 1)))))))

(define (http-check-url url)
  (unless (http-safe-string? url)
    (error "http: URL contains unsafe control byte (CR/LF/NUL/TAB/VT/FF/DEL) — possible injection" url)))

(define (http-check-headers headers)
  (for-each (lambda (pair)
              (let ((name (if (pair? pair) (car pair) ""))
                    (val  (if (pair? pair) (cdr pair) "")))
                (unless (and (http-token-string? name)
                             (http-safe-string? val))
                  (error "http: invalid RFC 9110 header name or unsafe control byte in value"
                         pair))))
            headers))

(define (http-headers->block headers)
  "Serialize a validated header alist into the native ABI's line format."
  (let loop ((rest headers) (result ""))
    (if (null? rest)
        result
        (let ((header (car rest)))
          (loop (cdr rest)
                (string-append result
                               (car header) ": " (cdr header) "\n"))))))

(define (http-get url . timeout)
  "Perform HTTP GET. Returns (status-code . body-string) or #f on error."
  (capability-require! 'network url)
  (http-check-url url)
  (let* ((timeout-ms (if (null? timeout) 30000 (car timeout)))
         (resp (http-request-raw "GET" url "" "" 0 timeout-ms)))
    (if (not resp) #f
        (if (http-response-error resp)
            (begin (http-response-free resp) #f)
            (let* ((status (http-response-status resp))
                   (body (http-response-body resp))
                   (result (cons status (if body body ""))))
              (http-response-free resp)
              result)))))

(define (http-post url headers body . timeout)
  "Perform HTTP POST with custom headers.
   headers: list of (name . value) pairs
   body: string
   Returns: (status-code . body-string) or #f on error."
  (apply http-request "POST" url headers body timeout))

(define (http-request method url headers body . timeout)
  "General HTTP request. Returns (status-code . body-string) or #f."
  (capability-require! 'network url)
  (http-check-url url)
  (unless (http-token-string? method)
    (error "http: method is not a valid RFC 9110 token" method))
  (unless (string? body)
    (error "http: request body must be a byte string" body))
  (http-check-headers headers)
  (let* ((timeout-ms (if (null? timeout) 30000 (car timeout)))
         (header-block (http-headers->block headers))
         (resp (http-request-raw method url header-block body
                                 (string-byte-length body) timeout-ms)))
    (if (not resp) #f
        (if (http-response-error resp)
            (begin (http-response-free resp) #f)
            (let* ((status (http-response-status resp))
                   (resp-body (http-response-body resp))
                   (result (cons status (if resp-body resp-body ""))))
              (http-response-free resp)
              result)))))

;; ============================================================================
;; SSE Streaming
;; ============================================================================

(define (http-stream-open url headers body . timeout)
  "Open an SSE streaming connection.
   Returns: stream handle (opaque pointer) or #f on error."
  (capability-require! 'network url)
  (http-check-url url)
  (http-check-headers headers)
  (let ((timeout-ms (if (null? timeout) 30000 (car timeout)))
        (method (if (string=? body "") "GET" "POST")))
    (stream-open-raw method url (http-headers->block headers) body
                     (string-byte-length body) timeout-ms)))

(define (http-stream-next stream . timeout)
  "Read next SSE event from stream.
   Returns: (event-type . data-string) or #f if done/error."
  (let* ((timeout-ms (if (null? timeout) 30000 (car timeout)))
         (native-event (stream-next-raw stream timeout-ms)))
    (if (not native-event)
        #f
        (let ((event (list (cons "type" (sse-event-type-raw native-event))
                           (cons "data" (sse-event-data-raw native-event))
                           (cons "id" (sse-event-id-raw native-event))
                           (cons "retry-ms" (sse-event-retry-raw native-event)))))
          (sse-event-free-raw native-event)
          event))))

(define (http-stream-done? stream)
  "Check if stream has ended."
  (= (stream-done-raw stream) 1))

(define (http-stream-error stream)
  "Return the stream's transport/parser error string, or #f when none."
  (stream-error-raw stream))

(define (http-stream-close stream)
  "Close SSE stream."
  (stream-close-raw stream))

;; SSE events are ordinary alists after crossing the native ownership boundary.
(define (sse-event-field event name default)
  (let ((entry (assoc name event)))
    (if entry (cdr entry) default)))
(define (sse-event-type event) (sse-event-field event "type" "message"))
(define (sse-event-data event) (sse-event-field event "data" ""))
(define (sse-event-id event) (sse-event-field event "id" ""))
(define (sse-event-retry-ms event) (sse-event-field event "retry-ms" -1))
(define (sse-event-free event) #t)  ;; Native storage is freed by http-stream-next.
