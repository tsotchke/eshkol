;;
;; regex.esk - PCRE2 regular expression FFI wrapper
;; Bindings to agent_regex.c
;;
(provide regex-compile regex-match regex-match? regex-match-all
         regex-replace regex-free
         regex-match-groups regex-group regex-named-group-number
         REGEX_CASELESS REGEX_MULTILINE REGEX_DOTALL)

;; Flags
(define REGEX_CASELESS  1)
(define REGEX_MULTILINE 2)
(define REGEX_DOTALL    4)

;; FFI declarations
(extern i64 regex-compile-raw ptr i32 :real eshkol_regex_compile)
(extern i32 regex-match-raw i64 ptr ptr i64 :real eshkol_regex_match)
(extern i32 regex-match-all-raw i64 ptr ptr i64 i32 :real eshkol_regex_match_all)
(extern i32 regex-replace-raw i64 ptr ptr ptr i64 :real eshkol_regex_replace)
(extern void regex-free-raw i64 :real eshkol_regex_free)
(extern i32 regex-match-groups-raw i64 ptr ptr i64 :real eshkol_regex_match_groups)
(extern i32 regex-match-groups-count-raw i64 ptr :real eshkol_regex_match_groups_count)
(extern i32 regex-named-group-number-raw i64 ptr :real eshkol_regex_named_group_number)

;; High-level wrappers
(define (regex-compile pattern . flags)
  "Compile a regex pattern. Returns handle (int64) or -1 on error."
  (let ((f (if (null? flags) 0 (car flags))))
    (regex-compile-raw pattern f)))

(define (regex-match handle subject)
  "Match pattern against subject. Returns first match string or #f."
  (let* ((buf (make-string 4096 #\nul))
         (result (regex-match-raw handle subject buf 4096)))
    (if (= result 1)
        ;; PCRE2 writes a NUL-terminated match into buf; trim at first NUL.
        ;; stdlib string-trim-right only removes whitespace, so we walk the
        ;; buffer manually rather than depend on a non-existent char-set
        ;; helper. Returning the substring is cheap — no allocation past
        ;; what substring already does.
        (let loop ((i 0))
          (cond
            ((>= i (string-length buf)) buf)
            ((= (char->integer (string-ref buf i)) 0) (substring buf 0 i))
            (else (loop (+ i 1)))))
        #f)))

(define (regex-match? handle subject)
  "Check if pattern matches subject. Returns #t or #f."
  (= (regex-match-raw handle subject #f 0) 1))

(define (regex-match-all handle subject . max)
  "Find all matches. Returns list of match strings."
  (let* ((max-matches (if (null? max) 100 (car max)))
         (buf (make-string (* max-matches 256) #\nul))
         (count (regex-match-all-raw handle subject buf (* max-matches 256) max-matches)))
    (if (<= count 0) '()
        ;; Split null-separated results
        (let loop ((i 0) (start 0) (results '()))
          (cond
            ((>= (length results) count) (reverse results))
            ((>= i (string-length buf)) (reverse results))
            ((= (char->integer (string-ref buf i)) 0)
             (loop (+ i 1) (+ i 1)
                   (cons (substring buf start i) results)))
            (else (loop (+ i 1) start results)))))))

(define (regex-replace handle subject replacement)
  "Replace all matches in subject. Returns new string."
  (let* ((buf (make-string (* 2 (+ (string-length subject) (string-length replacement))) #\nul))
         (len (regex-replace-raw handle subject replacement buf (string-length buf))))
    (if (> len 0) (substring buf 0 len) subject)))

(define (regex-free handle)
  "Free a compiled regex."
  (regex-free-raw handle))

;; ---------------------------------------------------------------------------
;; Capture-group extraction (Noesis #167)
;;
;; regex-match-groups returns a list of strings: group 0 is the whole match,
;; groups 1..N are the captured subgroups. Returns #f on no-match. An unset
;; optional group (e.g. (a(b)?c) where the b was absent) is returned as an
;; empty string "".
;; ---------------------------------------------------------------------------

(define (regex-match-groups handle subject)
  "Match and return (list full-match group1 group2 …) or #f on no match."
  (let* ((buf-size 16384)   ; should comfortably hold most realistic matches
         (buf (make-string buf-size #\nul))
         (count (regex-match-groups-raw handle subject buf buf-size)))
    (cond
      ((<= count 0) #f)     ; -1 = no match, 0 = invalid input
      (else
        ;; Walk buf: successive NUL-terminated strings, count of them is `count`.
        (let loop ((i 0) (start 0) (emitted 0) (acc '()))
          (cond
            ((>= emitted count) (reverse acc))
            ((>= i buf-size) (reverse acc))
            ((= (char->integer (string-ref buf i)) 0)
             (loop (+ i 1) (+ i 1) (+ emitted 1)
                   (cons (substring buf start i) acc)))
            (else (loop (+ i 1) start emitted acc))))))))

(define (regex-group match-groups idx)
  "Access capture group by index. Group 0 = full match, 1.. = subgroups."
  (if (and match-groups (list? match-groups)
           (>= idx 0) (< idx (length match-groups)))
      (list-ref match-groups idx)
      #f))

(define (regex-named-group-number handle name)
  "Return the numeric index for a named capture group, or -1 if absent."
  (regex-named-group-number-raw handle name))
