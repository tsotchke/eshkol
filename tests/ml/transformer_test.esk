;;; Transformer Architecture Test Suite
;;; Tests for positional-encoding, causal-mask, padding-mask
;;; Causal mask and padding mask use additive convention:
;;;   0.0 = attend, -inf = don't attend

(require stdlib)

;; Test 1: Positional encoding returns correct number of elements
(display "TEST: positional-encoding tensor length") (newline)
(let ((pe (positional-encoding 4 2)))
  (display (if (= (tensor-length pe) 8) "PASS" "FAIL"))
  (display ": positional-encoding(4, 2) should have 8 elements (4*2)") (newline))

;; Test 2: PE at position 0 even dim should be sin(0) = 0.0
(display "TEST: positional-encoding pos=0 even dim is sin(0)") (newline)
(let ((pe (positional-encoding 4 2)))
  (display (if (< (abs (- (vref pe 0) 0.0)) 0.01) "PASS" "FAIL"))
  (display ": PE(0, 0) = sin(0) should be 0.0") (newline))

;; Test 3: PE at position 0 odd dim should be cos(0) = 1.0
(display "TEST: positional-encoding pos=0 odd dim is cos(0)") (newline)
(let ((pe (positional-encoding 4 2)))
  (display (if (< (abs (- (vref pe 1) 1.0)) 0.01) "PASS" "FAIL"))
  (display ": PE(0, 1) = cos(0) should be 1.0") (newline))

;; Test 4: PE at position 1 even dim should be sin(1) ~ 0.8415
(display "TEST: positional-encoding pos=1 even dim is sin(1)") (newline)
(let ((pe (positional-encoding 4 2)))
  (display (if (< (abs (- (vref pe 2) 0.8415)) 0.01) "PASS" "FAIL"))
  (display ": PE(1, 0) = sin(1/10000^0) should be ~0.8415") (newline))

;; Test 5: Causal mask size is seq_len * seq_len
(display "TEST: causal-mask tensor length") (newline)
(let ((mask (causal-mask 3)))
  (display (if (= (tensor-length mask) 9) "PASS" "FAIL"))
  (display ": causal-mask(3) should have 9 elements (3*3)") (newline))

;; Test 6: Causal mask diagonal and below are 0.0 (attend)
(display "TEST: causal-mask diagonal and below are 0.0") (newline)
(let ((mask (causal-mask 3)))
  ;; Flat layout for 3x3: row 0=[0,1,2], row 1=[3,4,5], row 2=[6,7,8]
  ;; Diagonal and below: [0,0]=idx0, [1,0]=idx3, [1,1]=idx4, [2,0]=idx6, [2,1]=idx7, [2,2]=idx8
  (display (if (and (< (abs (vref mask 0)) 0.01)   ;; [0,0]
                    (< (abs (vref mask 3)) 0.01)   ;; [1,0]
                    (< (abs (vref mask 4)) 0.01)   ;; [1,1]
                    (< (abs (vref mask 6)) 0.01)   ;; [2,0]
                    (< (abs (vref mask 7)) 0.01)   ;; [2,1]
                    (< (abs (vref mask 8)) 0.01))  ;; [2,2]
               "PASS" "FAIL"))
  (display ": lower triangle and diagonal should all be 0.0") (newline))

;; Test 7: Causal mask above diagonal are -inf (masked)
(display "TEST: causal-mask above diagonal are -inf") (newline)
(let ((mask (causal-mask 3)))
  ;; Above diagonal: [0,1]=idx1, [0,2]=idx2, [1,2]=idx5
  ;; -inf values should be very large negative numbers
  (display (if (and (< (vref mask 1) -1000.0)   ;; [0,1] future
                    (< (vref mask 2) -1000.0)   ;; [0,2] future
                    (< (vref mask 5) -1000.0))  ;; [1,2] future
               "PASS" "FAIL"))
  (display ": upper triangle should be -inf (< -1000)") (newline))

;; Test 8: Causal mask size 1 is just [0.0]
(display "TEST: causal-mask size 1 is single 0.0") (newline)
(let ((mask (causal-mask 1)))
  (display (if (and (= (tensor-length mask) 1)
                    (< (abs (vref mask 0)) 0.01))
               "PASS" "FAIL"))
  (display ": causal-mask(1) should be single element 0.0") (newline))

;; Test 9: Padding mask basic structure
(display "TEST: padding-mask structure") (newline)
(let ((pm (padding-mask #(2 3) 4)))
  ;; 2 sequences, max length 4 => 8 elements
  ;; Seq 0 (length 2): [0, 0, -inf, -inf] (positions 0,1 valid; 2,3 padded)
  ;; Seq 1 (length 3): [0, 0, 0, -inf]    (positions 0,1,2 valid; 3 padded)
  (display (if (= (tensor-length pm) 8) "PASS" "FAIL"))
  (display ": padding-mask for 2 seqs, max_len 4 should have 8 elements") (newline))

;; Test 10: Padding mask valid positions are 0.0, padded are -inf
(display "TEST: padding-mask valid vs padded values") (newline)
(let ((pm (padding-mask #(2 3) 4)))
  ;; Seq 0 (length 2): idx 0,1 = 0.0; idx 2,3 = -inf
  ;; Seq 1 (length 3): idx 4,5,6 = 0.0; idx 7 = -inf
  (display (if (and (< (abs (vref pm 0)) 0.01)    ;; seq 0, pos 0: valid
                    (< (abs (vref pm 1)) 0.01)    ;; seq 0, pos 1: valid
                    (< (vref pm 2) -1000.0)       ;; seq 0, pos 2: padded
                    (< (vref pm 3) -1000.0)       ;; seq 0, pos 3: padded
                    (< (abs (vref pm 4)) 0.01)    ;; seq 1, pos 0: valid
                    (< (abs (vref pm 5)) 0.01)    ;; seq 1, pos 1: valid
                    (< (abs (vref pm 6)) 0.01)    ;; seq 1, pos 2: valid
                    (< (vref pm 7) -1000.0))      ;; seq 1, pos 3: padded
               "PASS" "FAIL"))
  (display ": valid positions should be 0.0, padded should be -inf") (newline))
