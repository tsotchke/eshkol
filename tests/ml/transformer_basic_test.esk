;;; Basic Transformer Functions Test Suite
;;; Tests for the core functions we've validated

(define (run-tests)
  (display "=== Basic Transformer Tests ===")
  (newline)
  (newline)

  ;; Test 1: Causal Mask
  (display "-- Test 1: Causal Mask --")
  (newline)
  (let ((mask (causal-mask 4)))
    (display "causal-mask(4):")
    (newline)
    (display mask)
    (newline)
    ;; Expected: Additive mask (0 = attend, -inf = don't attend)
    (newline))

  ;; Test 2: Positional Encoding
  (display "-- Test 2: Positional Encoding --")
  (newline)
  (let ((pe (positional-encoding 4 8)))
    (display "positional-encoding(seq_len=4, d_model=8):")
    (newline)
    (display pe)
    (newline)
    (newline))

  ;; Test 3: Embedding Lookup
  (display "-- Test 3: Embedding Lookup --")
  (newline)
  (let* ((weights (reshape (arange 0.0 20.0 1.0) (list 5 4)))
         (indices #(0 2 4)))
    (display "Embedding weights (5x4):")
    (newline)
    (display weights)
    (newline)
    (display "Token indices: ")
    (display indices)
    (newline)
    (let ((embedded (embedding indices weights)))
      (display "Embedded output:")
      (newline)
      (display embedded)
      (newline))
    (newline))

  ;; Test 4: Scaled Dot-Product Attention
  (display "-- Test 4: Scaled Dot-Product Attention --")
  (newline)
  (let* ((seq-len 3)
         (d-k 4)
         (Q (reshape (arange 1.0 13.0 1.0) (list seq-len d-k)))
         (K (reshape (arange 1.0 13.0 1.0) (list seq-len d-k)))
         (V (reshape (arange 0.1 1.3 0.1) (list seq-len d-k))))
    (display "Q (3x4):")
    (newline)
    (display Q)
    (newline)
    (display "K (3x4):")
    (newline)
    (display K)
    (newline)
    (display "V (3x4):")
    (newline)
    (display V)
    (newline)
    (let ((attn-output (scaled-dot-attention Q K V)))
      (display "Attention output:")
      (newline)
      (display attn-output)
      (newline))
    (newline))

  ;; Test 5: Padding Mask
  (display "-- Test 5: Padding Mask --")
  (newline)
  (let* ((lengths #(3 2 4))
         (max-len 5))
    (display "Sequence lengths: ")
    (display lengths)
    (newline)
    (display "Max length: 5")
    (newline)
    (let ((mask (padding-mask lengths max-len)))
      (display "Padding mask:")
      (newline)
      (display mask)
      (newline)
      ;; Expected: Additive mask (0 = attend, -inf = don't attend)
      ))
  (newline)

  ;; Test 6: Attention with Causal Mask
  (display "-- Test 6: Attention with Causal Mask --")
  (newline)
  (let* ((seq-len 3)
         (d-k 4)
         (Q (reshape (arange 1.0 13.0 1.0) (list seq-len d-k)))
         (K (reshape (arange 1.0 13.0 1.0) (list seq-len d-k)))
         (V (reshape (arange 0.1 1.3 0.1) (list seq-len d-k)))
         (mask (causal-mask seq-len)))
    (display "Using causal mask")
    (newline)
    (let ((attn-output (scaled-dot-attention Q K V mask)))
      (display "Masked attention output:")
      (newline)
      (display attn-output)
      (newline))
    (newline))

  (display "=== Basic Transformer Tests Complete ===")
  (newline))

(run-tests)
