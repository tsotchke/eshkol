;; merkle_test.esk — smoke for core.merkle (#175)

(require stdlib)
(require core.merkle)

(define passed 0)
(define failed 0)
(define (check label expected actual)
  (if (equal? expected actual)
      (begin (display "PASS: ") (display label) (newline)
             (set! passed (+ passed 1)))
      (begin (display "FAIL: ") (display label)
             (display " (expected ") (display expected)
             (display ", got ") (display actual) (display ")") (newline)
             (set! failed (+ failed 1)))))

;; ── Hash determinism + format ──────────────────────────────────────
(check "fnv1a-64 deterministic" (fnv1a-64 "hello") (fnv1a-64 "hello"))
(check "fnv1a-64 differs by content"
       #t (not (= (fnv1a-64 "foo") (fnv1a-64 "bar"))))
(check "hash->hex length is 16" 16 (string-length (hash->hex (fnv1a-64 "x"))))
;; FNV-1a 64 hex of empty string = the offset basis 0xcbf29ce484222325
(check "fnv1a-64 empty string hex == offset basis"
       "cbf29ce484222325" (hash->hex (fnv1a-64 "")))
;; Spec vector: FNV-1a 64 of "a" should be 0xaf63dc4c8601ec8c
(check "fnv1a-64 spec vector for 'a'"
       "af63dc4c8601ec8c" (hash->hex (fnv1a-64 "a")))

;; ── Merkle tree basics ──────────────────────────────────────────────
(define t1 (merkle-tree (list "alice" "bob" "carol" "dave")))
(check "single-leaf-tree root = leaf hash"
       (fnv1a-64 "lonely")
       (merkle-root (merkle-tree (list "lonely"))))

;; Same data → same root
(define t1-clone (merkle-tree (list "alice" "bob" "carol" "dave")))
(check "merkle-tree deterministic"
       (merkle-root t1) (merkle-root t1-clone))

;; Different order → different root
(define t1-shuffled (merkle-tree (list "bob" "alice" "carol" "dave")))
(check "merkle root order-sensitive"
       #t (not (= (merkle-root t1) (merkle-root t1-shuffled))))

;; merkle-leaves walks left-to-right
(check "merkle-leaves preserves order"
       (list "alice" "bob" "carol" "dave") (merkle-leaves t1))

;; Odd-size tree (3 leaves: duplicates the last one for level construction)
(define t-odd (merkle-tree (list "a" "b" "c")))
(check "merkle-leaves of odd-tree counts each leaf once"
       (list "a" "b" "c") (merkle-leaves t-odd))

;; ── Inclusion proofs ────────────────────────────────────────────────
(define p0 (merkle-proof t1 0))   ; proof for "alice"
(check "valid proof verifies"
       #t (merkle-verify (merkle-root t1) "alice" p0))
(check "wrong leaf with valid proof fails"
       #f (merkle-verify (merkle-root t1) "MALLORY" p0))
(check "valid leaf with wrong proof fails"
       #f (merkle-verify (merkle-root t1) "alice" '()))

;; Verify all 4 leaves in t1
(check "proof for index 0 (alice)"
       #t (merkle-verify (merkle-root t1) "alice" (merkle-proof t1 0)))
(check "proof for index 1 (bob)"
       #t (merkle-verify (merkle-root t1) "bob" (merkle-proof t1 1)))
(check "proof for index 2 (carol)"
       #t (merkle-verify (merkle-root t1) "carol" (merkle-proof t1 2)))
(check "proof for index 3 (dave)"
       #t (merkle-verify (merkle-root t1) "dave" (merkle-proof t1 3)))

;; Odd-tree proofs still verify
(check "odd-tree proof for 'a'"
       #t (merkle-verify (merkle-root t-odd) "a" (merkle-proof t-odd 0)))
(check "odd-tree proof for 'b'"
       #t (merkle-verify (merkle-root t-odd) "b" (merkle-proof t-odd 1)))
(check "odd-tree proof for 'c'"
       #t (merkle-verify (merkle-root t-odd) "c" (merkle-proof t-odd 2)))

;; ── Content-addressable store ───────────────────────────────────────
(define cas (make-cas))
(check "fresh CAS is empty" 0 (cas-size cas))
(check "cas? recognises CAS handle" #t (cas? cas))
(check "cas? rejects non-CAS" #f (cas? "string"))

(define h-foo (cas-put! cas "the contents of foo"))
(define h-bar (cas-put! cas "the contents of bar"))
(check "CAS size after 2 puts" 2 (cas-size cas))
(check "cas-get round-trips foo"
       "the contents of foo" (cas-get cas h-foo))
(check "cas-get round-trips bar"
       "the contents of bar" (cas-get cas h-bar))
(check "cas-has? for present hash" #t (cas-has? cas h-foo))
(check "cas-has? for absent hash" #f (cas-has? cas "deadbeef00000000"))
(check "cas-get of absent hash returns #f"
       #f (cas-get cas "deadbeef00000000"))

;; Putting the same data twice yields the same content hash.
(define h-foo-2 (cas-put! cas "the contents of foo"))
(check "duplicate put returns same hash" h-foo h-foo-2)
(check "duplicate put doesn't grow store" 2 (cas-size cas))

;; ── Result ──────────────────────────────────────────────────────────
(display "---") (newline)
(display "Passed: ") (display passed) (newline)
(display "Failed: ") (display failed) (newline)
(if (> failed 0) (exit 1) (exit 0))
