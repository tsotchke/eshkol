;; Standard HTTP routing helpers for #145/#148.

(require stdlib)
(require core.http_server)

(define passed 0)
(define failed 0)

(define (check name ok)
  (if ok
      (begin
        (set! passed (+ passed 1))
        (display "PASS: ") (display name) (newline))
      (begin
        (set! failed (+ failed 1))
        (display "FAIL: ") (display name) (newline))))

(define health-request "GET /health HTTP/1.1\r\nHost: 127.0.0.1\r\n\r\n")
(define ready-request "GET /ready HTTP/1.1\r\nHost: 127.0.0.1\r\n\r\n")
(define metrics-request "GET /metrics?format=prom HTTP/1.1\r\nHost: 127.0.0.1\r\n\r\n")
(define post-metrics-request "POST /metrics HTTP/1.1\r\nHost: 127.0.0.1\r\nContent-Length: 0\r\n\r\n")
(define delete-health-request "DELETE /health HTTP/1.1\r\nHost: 127.0.0.1\r\n\r\n")
(define missing-request "GET /missing HTTP/1.1\r\nHost: 127.0.0.1\r\n\r\n")
(define post-request
  "POST /tools/run?trace=abc HTTP/1.1\r\nHost: 127.0.0.1\r\nContent-Type: application/json\r\nX-Trace:  abc  \r\n\r\n{\"ok\":true}")
(define oversized-request
  "POST /tools/run HTTP/1.1\r\nHost: 127.0.0.1\r\nContent-Length: 10485761\r\n\r\n")
(define invalid-length-request
  "POST /tools/run HTTP/1.1\r\nHost: 127.0.0.1\r\nContent-Length: nope\r\n\r\n")
(define bad-request "not-a-request")

(display "=== HTTP server routing helpers ===") (newline)

(check "extracts request line"
       (string=? (http-request-line health-request) "GET /health HTTP/1.1"))
(check "extracts method"
       (string=? (http-request-method health-request) "GET"))
(check "extracts target"
       (string=? (http-request-target metrics-request) "/metrics?format=prom"))
(check "strips query string for path"
       (string=? (http-request-path metrics-request) "/metrics"))
(check "extracts query string"
       (string=? (http-request-query post-request) "trace=abc"))
(check "extracts HTTP version"
       (string=? (http-request-version post-request) "HTTP/1.1"))
(check "finds headers case-insensitively"
       (string=? (http-request-header post-request "content-type") "application/json"))
(check "trims header values"
       (string=? (http-request-header post-request "x-trace") "abc"))
(check "returns #f for missing headers"
       (eq? (http-request-header post-request "missing") #f))
(check "parses content length"
       (= (http-request-content-length
            "POST /x HTTP/1.1\r\nContent-Length: 12\r\n\r\nhello") 12))
(check "invalid content length returns #f"
       (eq? (http-request-content-length invalid-length-request) #f))
(check "extracts request body"
       (string=? (http-request-body post-request) "{\"ok\":true}"))
(check "detects oversized declared body"
       (http-request-body-too-large? oversized-request))

(define tool-routes
  (list
    (http-route "POST" "/tools/run"
                (lambda (request)
                  (http-response 200
                                 "application/json"
                                 (string-append "{\"query\":\""
                                                (http-request-query request)
                                                "\"}"))))
    (http-route "GET" "/boom"
                (lambda (request)
                  (error "expected route failure")))))

(let ((response (http-route-request post-request tool-routes)))
  (check "custom route returns handler status"
         (= (http-response-status response) 200))
  (check "custom route returns handler content type"
         (string=? (http-response-content-type response) "application/json"))
  (check "custom route receives request details"
         (string-contains? (http-response-body response) "trace=abc")))

(let ((response (http-route-request "GET /boom HTTP/1.1\r\n\r\n" tool-routes)))
  (check "handler exception becomes 500 response"
         (= (http-response-status response) 500)))

(let ((response (http-route-request oversized-request tool-routes)))
  (check "router rejects oversized request before handler"
         (= (http-response-status response) 413)))

(let ((response (http-route-request invalid-length-request tool-routes)))
  (check "router rejects invalid content length before handler"
         (= (http-response-status response) 400)))

(let ((response (http-route-request health-request tool-routes)))
  (check "router falls back to standard routes"
         (= (http-response-status response) 200)))

(let ((response (http-standard-response health-request)))
  (check "health route returns 200"
         (= (http-response-status response) 200))
  (check "health route returns text/plain"
         (string=? (http-response-content-type response) "text/plain"))
  (check "health route body is OK"
         (string=? (http-response-body response) "OK\n")))

(let ((response (http-standard-response ready-request #t)))
  (check "ready true returns 200"
         (= (car response) 200))
  (check "ready true body is READY"
         (string=? (caddr response) "READY\n")))

(let ((response (http-standard-response ready-request #f)))
  (check "ready false returns 500"
         (= (car response) 500))
  (check "ready false body is NOT READY"
         (string=? (caddr response) "NOT READY\n")))

(define requests-total
  (make-counter "eshkol_http_routing_test_total"
                "HTTP routing helper requests"
                '("path")))
(counter-inc! requests-total '("/metrics"))

(let ((response (http-standard-response metrics-request)))
  (check "metrics route returns 200"
         (= (http-response-status response) 200))
  (check "metrics route content type is prometheus text"
         (string=? (http-response-content-type response) "text/plain; version=0.0.4"))
  (check "metrics route includes HELP line"
         (string-contains? (http-response-body response) "# HELP eshkol_http_routing_test_total"))
  (check "metrics route includes label value"
         (string-contains? (http-response-body response) "path=\"/metrics\"")))

(let ((response (http-standard-response post-metrics-request)))
  (check "metrics route rejects non-GET method"
         (= (http-response-status response) 405))
  (check "method rejection body is explicit"
         (string=? (http-response-body response) "Method Not Allowed\n")))

(let ((response (http-route-request delete-health-request tool-routes)))
  (check "router fallback rejects non-GET standard route"
         (= (http-response-status response) 405)))

(let ((response (http-standard-response missing-request)))
  (check "unknown route returns 404"
         (= (car response) 404))
  (check "unknown route body is Not Found"
         (string=? (caddr response) "Not Found\n")))

(let ((response (http-standard-response bad-request)))
  (check "invalid request returns 400"
         (= (car response) 400))
  (check "invalid request body is Bad Request"
         (string=? (caddr response) "Bad Request\n")))

(let ((response (http-standard-response oversized-request)))
  (check "standard routes reject oversized bodies"
         (= (http-response-status response) 413))
  (check "standard oversized response body is Payload Too Large"
         (string=? (http-response-body response) "Payload Too Large\n")))

(display "Passed: ") (display passed) (newline)
(display "Failed: ") (display failed) (newline)

(if (> failed 0) (exit 1) (exit 0))
