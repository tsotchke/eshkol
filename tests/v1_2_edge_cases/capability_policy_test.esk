;; Capability policy checks for v1.3-evolve #149.

(require stdlib)

(define passed 0)
(define failed 0)

(define (check name ok)
  (if ok
      (begin
        (set! passed (+ passed 1))
        (display "PASS: ") (display name) (newline))
      (begin
        (set! failed (+ failed 1))
        (display "FAIL: ") (display name) (newline))))

(define (raises? thunk)
  (let ((raised #f))
    (guard (exn (#t (set! raised #t)))
      (thunk))
    raised))

(display "=== capability policy suite ===") (newline)

(capability-clear-policy!)
(check "no policy allows subprocess by default"
       (capability-allowed? 'subprocess))
(check "no policy allows network by default"
       (capability-allowed? 'network))

(capability-install-policy! (list 'file-read))
(check "active policy denies missing subprocess"
       (not (capability-allowed? 'subprocess)))
(check "active policy keeps listed capability allowed"
       (capability-allowed? 'file-read))
(check "denied capability raises deterministically"
       (raises? (lambda () (capability-require! 'subprocess 'spawn))))

(define file-policy-path "/tmp/eshkol_capability_file_policy.txt")

(capability-clear-policy!)
(if (file-exists? file-policy-path) (delete-file file-policy-path) #f)
(check "no policy allows file writes by default"
       (write-file file-policy-path "hello"))

(capability-install-policy! '())
(check "empty active policy is deny-by-default"
       (and (capability-policy-active?)
            (not (capability-allowed? 'file-read))
            (not (capability-allowed? 'file-write))))
(check "file metadata requires file-read"
       (not (file-exists? file-policy-path)))
(check "read-file requires file-read"
       (not (read-file file-policy-path)))
(check "file-size requires file-read"
       (not (file-size file-policy-path)))
(check "write-file requires file-write"
       (not (write-file file-policy-path "blocked")))

(capability-install-policy! (list 'file-read))
(check "file-read allows metadata and read-file"
       (and (file-exists? file-policy-path)
            (string=? (read-file file-policy-path) "hello")))
(check "file-read alone still denies write-file"
       (not (write-file file-policy-path "blocked")))

(capability-install-policy! (list 'file-write))
(check "file-write allows write-file"
       (write-file file-policy-path "updated"))
(check "file-write alone still denies metadata"
       (not (file-exists? file-policy-path)))

(capability-install-policy! (list 'file-read))
(check "file-read observes updated file contents"
       (string=? (read-file file-policy-path) "updated"))

(capability-install-policy! (list 'file-write))
(check "file-write allows delete-file cleanup"
       (delete-file file-policy-path))

(capability-install-policy! (list 'subprocess))
(check "shell capability remains denied unless listed"
       (raises? (lambda () (capability-require! 'shell 'spawn-shell))))

(capability-install-policy! (list 'subprocess 'shell))
(check "subprocess allow-list can permit shell"
       (and (capability-allowed? 'subprocess)
            (capability-allowed? 'shell)))

(capability-clear-policy!)
(check "clear policy restores no-policy allow"
       (capability-allowed? 'shell))

(display "Passed: ") (display passed) (newline)
(display "Failed: ") (display failed) (newline)
(if (> failed 0) (exit 1) (exit 0))
