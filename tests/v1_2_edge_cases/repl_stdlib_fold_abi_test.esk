;; mode: jit
;; REPL/JIT regression: preloaded stdlib and later REPL batches must
;; share the same Eshkol internal tagged-value ABI.  Loading stdlib as a
;; native object crossed an aggregate-value ABI boundary on arm64 and
;; corrupted 3-arg stdlib calls such as fold.

(require stdlib)

(define passed 0)
(define failed 0)

(define (check name actual expected)
  (if (equal? expected actual)
      (begin
        (display "PASS: ") (display name) (newline)
        (set! passed (+ passed 1)))
      (begin
        (display "FAIL: ") (display name)
        (display " expected ") (display expected)
        (display ", got ") (display actual) (newline)
        (set! failed (+ failed 1)))))

(check "JIT stdlib fold with first-class +"
       (fold + 0 '(1 2 3 4 5))
       15)

(check "JIT stdlib fold with binary lambda"
       (fold (lambda (a b) (+ a b)) 0 '(1 2 3))
       6)

(newline)
(display "Passed: ") (display passed) (newline)
(display "Failed: ") (display failed) (newline)
(if (> failed 0) (exit 1) (exit 0))
