;;; testing_framework_test.esk
;;;
;;; Exercises the core.testing API end-to-end. Meta-test: uses run-tests
;;; to drive itself, then asserts the final pass/fail counts match what
;;; we set up. If register-test / check-* / run-tests regress, this
;;; test either hangs or reports a wrong summary.

(require core.testing)

(reset-tests!)

(register-test "arithmetic checks"
  (lambda ()
    (check-equal? (+ 1 2) 3)
    (check-equal? (* 4 5) 20)
    (check-equal? (- 10 3) 7)))

(register-test "boolean checks"
  (lambda ()
    (check-true  #t)
    (check-true  (> 5 3))
    (check-false #f)
    (check-false (< 5 3))))

(register-test "approximate equality"
  (lambda ()
    (check-approx 3.14159 3.14 0.01)
    (check-approx 1.0 1.0 0.0001)))

(register-test "list equality"
  (lambda ()
    (check-equal? (list 1 2 3) (list 1 2 3))
    (check-equal? '() '())
    (check-equal? (cons 1 2) (cons 1 2))))

(register-test "string equality"
  (lambda ()
    (check-equal? "hello" "hello")
    (check-equal? (string-append "foo" "bar") "foobar")))

(display "Running tests:") (newline)
(define ok (run-tests))

(newline)
(display "Final counts:") (newline)
(display "  pass=") (display *test-pass-count*) (newline)
(display "  fail=") (display *test-fail-count*) (newline)

;; Verify the final counts.
(if (and ok
         (= *test-fail-count* 0)
         (>= *test-pass-count* 14))
    (begin
      (display "META: framework self-check OK") (newline)
      (exit 0))
    (begin
      (display "META: framework self-check FAILED") (newline)
      (exit 1)))
