;; v1.8/M4 distributed clock + CRDT substrate.

(require core.distributed)

(define pass 0)
(define fail 0)

(define (check name ok)
  (if ok
      (begin
        (set! pass (+ pass 1))
        (display "PASS: ")
        (display name)
        (newline))
      (begin
        (set! fail (+ fail 1))
        (display "FAIL: ")
        (display name)
        (newline))))

(define (raises? thunk)
  (let ((raised #f))
    (guard (exn (#t (set! raised #t)))
      (thunk))
    raised))

(display "=== distributed clocks + CRDTs ===") (newline)

(check "lamport zero" (= (lamport-zero) 0))
(check "lamport tick defaults to one" (= (lamport-tick 4) 5))
(check "lamport recv advances past remote" (= (lamport-recv 2 7) 8))
(check "lamport before predicate" (lamport-before? 3 4))
(check "lamport rejects negative tick"
       (raises? (lambda () (lamport-tick 3 -1))))

(define vc0 (vector-clock-empty))
(define vc-a1 (vector-clock-tick vc0 'a))
(define vc-a3 (vector-clock-tick vc-a1 'a 2))
(define vc-b1 (vector-clock-tick vc0 'b))
(define vc-ab (vector-clock-merge vc-a3 vc-b1))
(define vc-ab-copy (vector-clock-merge vc-b1 vc-a3))

(check "vector-clock missing node is zero"
       (= (vector-clock-ref vc0 'missing) 0))
(check "vector-clock tick records node"
       (= (vector-clock-ref vc-a3 'a) 3))
(check "vector-clock merge preserves left node"
       (= (vector-clock-ref vc-ab 'a) 3))
(check "vector-clock merge preserves right node"
       (= (vector-clock-ref vc-ab 'b) 1))
(check "vector-clock before relation"
       (vector-clock-before? vc-a3 vc-ab))
(check "vector-clock after relation"
       (vector-clock-after? vc-ab vc-a3))
(check "vector-clock concurrent relation"
       (vector-clock-concurrent? vc-a3 vc-b1))
(check "vector-clock merge is commutative by comparison"
       (vector-clock-equal? vc-ab vc-ab-copy))
(check "vector-clock rejects negative tick"
       (raises? (lambda () (vector-clock-tick vc0 'a -1))))

(define gc-a (g-counter-inc (make-g-counter) 'a 2))
(define gc-b (g-counter-inc (make-g-counter) 'b 5))
(define gc-merged (g-counter-merge gc-a gc-b))
(define gc-idempotent (g-counter-merge gc-merged gc-a))

(check "g-counter value sums per-node counts"
       (= (g-counter-value gc-merged) 7))
(check "g-counter merge is idempotent"
       (= (g-counter-value gc-idempotent) 7))
(check "g-counter rejects negative increment"
       (raises? (lambda () (g-counter-inc (make-g-counter) 'a -1))))

(define pn-a
  (pn-counter-dec
    (pn-counter-inc (make-pn-counter) 'a 5)
    'a
    1))
(define pn-b
  (pn-counter-dec
    (pn-counter-inc (make-pn-counter) 'b 3)
    'b
    4))
(define pn-merged (pn-counter-merge pn-a pn-b))

(check "pn-counter local value"
       (= (pn-counter-value pn-a) 4))
(check "pn-counter merged value"
       (= (pn-counter-value pn-merged) 3))
(check "pn-counter merge is idempotent"
       (= (pn-counter-value (pn-counter-merge pn-merged pn-a)) 3))
(check "pn-counter rejects negative decrement"
       (raises? (lambda () (pn-counter-dec (make-pn-counter) 'a -1))))

(define os-a (or-set-add (make-or-set) 'a 'task))
(define os-b (or-set-add (make-or-set) 'b 'task))
(define os-merged (or-set-merge os-a os-b))
(define os-a-removed (or-set-remove os-a 'task))
(define os-unseen-add-survives (or-set-merge os-a-removed os-b))
(define os-all-removed (or-set-remove os-merged 'task))
(define os-with-other (or-set-add os-all-removed 'a 'other))

(check "or-set add makes value visible"
       (or-set-member? os-a 'task))
(check "or-set add advances writer vector clock"
       (= (vector-clock-ref (or-set-clock os-a) 'a) 1))
(check "or-set merge preserves concurrent add"
       (or-set-member? os-merged 'task))
(check "or-set observed remove hides observed dot"
       (not (or-set-member? os-a-removed 'task)))
(check "or-set remove does not erase unseen concurrent add"
       (or-set-member? os-unseen-add-survives 'task))
(check "or-set remove after merge erases all observed dots"
       (not (or-set-member? os-all-removed 'task)))
(check "or-set elements return visible values only"
       (and (or-set-member? os-with-other 'other)
            (not (or-set-member? os-with-other 'task))))
(check "or-set merge is idempotent for visibility"
       (or-set-member? (or-set-merge os-merged os-merged) 'task))

(define lww-old (make-lww-register 'old 1 'a))
(define lww-new (lww-register-set lww-old 'new 2 'a))
(define lww-merged (lww-register-merge lww-old lww-new))
(define lww-writer-a (make-lww-register 'writer-a 3 'a))
(define lww-writer-b (make-lww-register 'writer-b 3 'b))
(define lww-tie (lww-register-merge lww-writer-a lww-writer-b))
(define lww-tie-rev (lww-register-merge lww-writer-b lww-writer-a))
(define lww-deleted (lww-register-delete lww-new 4 'a))

(check "lww-register newer timestamp wins"
       (eq? (lww-register-value lww-merged) 'new))
(check "lww-register writer tie-break converges"
       (and (eq? (lww-register-value lww-tie) 'writer-b)
            (eq? (lww-register-value lww-tie-rev) 'writer-b)))
(check "lww-register delete produces tombstone"
       (and (lww-register-deleted? lww-deleted)
            (not (lww-register-present? lww-deleted))))
(check "lww-register tombstone wins by timestamp"
       (not (lww-register-present?
              (lww-register-merge lww-new lww-deleted))))

(define lm-a (lww-map-set (make-lww-map) 'mode 'draft 1 'a))
(define lm-b (lww-map-set (make-lww-map) 'mode 'final 2 'b))
(define lm-merged (lww-map-merge lm-a lm-b))
(define lm-removed (lww-map-remove lm-merged 'mode 3 'a))
(define lm-with-owner (lww-map-set lm-removed 'owner 'alice 2 'a))
(define lm-with-priority (lww-map-set (make-lww-map) 'priority 5 1 'b))
(define lm-combined (lww-map-merge lm-with-owner lm-with-priority))

(check "lww-map newer entry wins"
       (eq? (lww-map-ref lm-merged 'mode) 'final))
(check "lww-map remove hides key"
       (and (not (lww-map-contains? lm-removed 'mode))
            (eq? (lww-map-ref lm-removed 'mode 'missing) 'missing)))
(check "lww-map merge keeps independent keys"
       (and (eq? (lww-map-ref lm-combined 'owner) 'alice)
            (= (lww-map-ref lm-combined 'priority) 5)))
(check "lww-map merge is idempotent"
       (eq? (lww-map-ref (lww-map-merge lm-combined lm-combined) 'owner)
            'alice))

(define rga-one (rga-append (make-rga) 'a 'alpha))
(define rga-alpha-id (rga-last-id rga-one))
(define rga-two (rga-append rga-one 'a 'beta))
(define rga-beta-id (rga-last-id rga-two))
(define rga-deleted (rga-delete rga-two rga-alpha-id))
(define rga-delete-merged (rga-merge rga-two rga-deleted))
(define rga-after-delete (rga-append rga-deleted 'a 'gamma))
(define rga-left (rga-insert-after (make-rga) 'a (rga-root-id) 'left))
(define rga-right (rga-insert-after (make-rga) 'b (rga-root-id) 'right))
(define rga-concurrent (rga-merge rga-right rga-left))

(check "rga append preserves sequence order"
       (equal? (rga-values rga-two) (list 'alpha 'beta)))
(check "rga last id follows visible tail"
       (equal? rga-beta-id (rga-last-id rga-two)))
(check "rga delete hides tombstoned entry"
       (equal? (rga-values rga-deleted) (list 'beta)))
(check "rga delete wins after merge"
       (equal? (rga-values rga-delete-merged) (list 'beta)))
(check "rga append after delete uses visible tail"
       (equal? (rga-values rga-after-delete) (list 'beta 'gamma)))
(check "rga concurrent inserts converge deterministically"
       (equal? (rga-values rga-concurrent) (list 'left 'right)))
(check "rga merge is idempotent"
       (equal? (rga-values (rga-merge rga-concurrent rga-concurrent))
               (list 'left 'right)))

(display "---") (newline)
(display "Total: ") (display (+ pass fail))
(display ", PASS: ") (display pass)
(display ", FAIL: ") (display fail)
(newline)

(if (> fail 0) (exit 1) (exit 0))
