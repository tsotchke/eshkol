;; mode: jit
;; url-encode / url-decode regression — task #202.

(require stdlib)
(display "=== url-encode + url-decode ===") (newline)

(define pass 0) (define fail 0)
(define (check name cond)
  (if cond (begin (set! pass (+ pass 1)) (display "PASS: ") (display name) (newline))
           (begin (set! fail (+ fail 1)) (display "FAIL: ") (display name) (newline))))

;; encode — unreserved set passes through
(check "encode unreserved alpha"   (string=? (url-encode "ABCxyz") "ABCxyz"))
(check "encode unreserved digits"  (string=? (url-encode "0123456789") "0123456789"))
(check "encode unreserved punct"   (string=? (url-encode "-_.~") "-_.~"))

;; encode — reserved get %XX
(check "encode space"              (string=? (url-encode "a b") "a%20b"))
(check "encode equals"             (string=? (url-encode "k=v") "k%3Dv"))
(check "encode ampersand"          (string=? (url-encode "a&b") "a%26b"))
(check "encode percent"            (string=? (url-encode "100%") "100%25"))
(check "encode slash"              (string=? (url-encode "a/b") "a%2Fb"))
(check "encode question mark"      (string=? (url-encode "a?b") "a%3Fb"))
(check "encode hash"               (string=? (url-encode "a#b") "a%23b"))

;; encode — empty
(check "encode empty"              (string=? (url-encode "") ""))

;; encode — multi-byte UTF-8 (café = c, a, f, é = c3 a9)
(check "encode 2-byte UTF-8 (é)"   (string=? (url-encode "café") "caf%C3%A9"))

;; encode — uppercase hex per RFC 3986
(check "encode uses uppercase hex" (string=? (url-encode " ") "%20"))
(check "encode tilde stays literal" (string=? (url-encode "~") "~"))

;; decode — round-trip from encode output
(check "decode space"              (string=? (url-decode "hello%20world") "hello world"))
(check "decode equals"             (string=? (url-decode "k%3Dv") "k=v"))
(check "decode percent literal"    (string=? (url-decode "100%25") "100%"))
(check "decode mixed case hex"     (string=? (url-decode "%48%65%6c%6C%6f") "Hello"))

;; decode — '+' as space (form-encoding compat)
(check "decode + as space"         (string=? (url-decode "form+data") "form data"))

;; decode — passes through literal
(check "decode literal"            (string=? (url-decode "abc-_.") "abc-_."))
(check "decode empty"              (string=? (url-decode "") ""))

;; decode — malformed (% at end / non-hex) passes through
(check "decode trailing %"         (string=? (url-decode "abc%") "abc%"))
(check "decode % followed by 1 hex" (string=? (url-decode "abc%2") "abc%2"))
(check "decode % followed by non-hex" (string=? (url-decode "%XY") "%XY"))

;; round-trip
(define samples (list "" "abc" "hello world" "a&b=c?d#e" "100% off" "café"))
(define (rt-ok s) (string=? s (url-decode (url-encode s))))
(check "round-trip all samples"
       (and (rt-ok "")
            (rt-ok "abc")
            (rt-ok "hello world")
            (rt-ok "a&b=c?d#e")
            (rt-ok "100% off")
            (rt-ok "café")))

(display "---") (newline)
(display "Total: ") (display (+ pass fail))
(display ", PASS: ") (display pass)
(display ", FAIL: ") (display fail) (newline)
(if (> fail 0) (exit 1))
