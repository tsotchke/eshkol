;; Native EAGLE linear-head FFI regression.
;;
;; Covers the qllm_ffi_linear_* bridge used by examples/eagle_train.esk to
;; train wide EAGLE heads without relying on vector-valued gradient.

(require stdlib)
(require agent.eagle)

(define pass-count 0)
(define fail-count 0)

(define (abs x) (if (< x 0.0) (- 0.0 x) x))

(define (check-approx name expected actual tol)
  (if (< (abs (- actual expected)) tol)
      (begin
        (set! pass-count (+ pass-count 1))
        (display "PASS: ") (display name) (newline))
      (begin
        (set! fail-count (+ fail-count 1))
        (display "FAIL: ") (display name)
        (display " expected=") (display expected)
        (display " actual=") (display actual) (newline))))

(define layer (eagle-linear-create 2 1))

(eagle-linear-set-input! layer 0 2.0)
(eagle-linear-set-input! layer 1 3.0)
(eagle-linear-set-target! layer 0 10.0)
(eagle-linear-forward! layer)
(check-approx "initial pred is zero" 0.0 (eagle-linear-pred layer 0) 1e-9)
(check-approx "initial loss" 100.0 (eagle-linear-loss layer) 1e-9)

(eagle-linear-backward! layer)
(check-approx "dW00 = -40" -40.0 (eagle-linear-grad layer 0 0) 1e-9)
(check-approx "dW01 = -60" -60.0 (eagle-linear-grad layer 0 1) 1e-9)

(eagle-linear-sgd-step! layer 0.01)
(check-approx "weight 0 after SGD" 0.4 (eagle-linear-weight layer 0 0) 1e-9)
(check-approx "weight 1 after SGD" 0.6 (eagle-linear-weight layer 0 1) 1e-9)

(eagle-linear-forward! layer)
(check-approx "pred after SGD" 2.6 (eagle-linear-pred layer 0) 1e-9)
(check-approx "loss decreases after SGD" 54.76 (eagle-linear-loss layer) 1e-9)

(eagle-linear-destroy layer)

(display "Passed: ") (display pass-count) (newline)
(display "Failed: ") (display fail-count) (newline)
(display (if (= fail-count 0) "RESULT: OK" "RESULT: FAILURES")) (newline)
