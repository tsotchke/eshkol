;; Standalone VM regression for date/time primitives.

(display "=== date/time VM surface regression ===") (newline)

(display "T1 format-iso8601 formats epoch nanoseconds: ")
(display (if (and (string=? (format-iso8601 0)
                            "1970-01-01T00:00:00.000Z")
                  (string=? (format-iso8601 1000000000)
                            "1970-01-01T00:00:01.000Z"))
             "PASS"
             "FAIL"))
(newline)

(display "T2 format-iso8601 preserves millisecond precision: ")
(define formatted-ms (format-iso8601 1704067200789000000))
(display (if (string=? formatted-ms
                       "2024-01-01T00:00:00.789Z")
             "PASS"
             (list "FAIL got " formatted-ms)))
(newline)

(display "T3 parse-iso8601 parses UTC and fractional seconds: ")
(display (if (and (= (parse-iso8601 "2024-01-01T00:00:00Z")
                    1704067200000000000)
                  (= (parse-iso8601 "2024-01-01T00:00:00.500Z")
                    1704067200500000000))
             "PASS"
             "FAIL"))
(newline)

(display "T4 parse-iso8601 applies timezone offsets and rejects bad input: ")
(display (if (and (= (parse-iso8601 "2024-01-01T05:00:00+05:00")
                    1704067200000000000)
                  (= (parse-iso8601 "2024-01-01T12:00:00-05:00")
                    1704128400000000000)
                  (not (parse-iso8601 "not-a-date"))
                  (not (parse-iso8601 "2024-01-01")))
             "PASS"
             "FAIL"))
(newline)

(display "T5 current time primitives return plausible values: ")
(define ts (current-timestamp))
(define ns (current-time-ns))
(display (if (and (number? ts)
                  (> ts 1700000000.0)
                  (< ts 3000000000.0)
                  (number? ns)
                  (> ns 1700000000000000000))
             "PASS"
             (list "FAIL got " ts ns)))
(newline)

(display "T6 format-relative abbreviates units: ")
(display (if (and (string=? (format-relative 30) "30s ago")
                  (string=? (format-relative 3600) "1h ago")
                  (string=? (format-relative 172800) "2d ago"))
             "PASS"
             "FAIL"))
(newline)

(display "T7 local-timezone-offset returns sane seconds: ")
(define offset (local-timezone-offset))
(display (if (and (number? offset)
                  (> offset -50401)
                  (< offset 50401))
             "PASS"
             (list "FAIL got " offset)))
(newline)

(display "=== date/time VM surface complete ===") (newline)
