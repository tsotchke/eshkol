;; Standalone VM regression for URL parsing.

(display "=== url parse VM surface regression ===") (newline)

(define parsed (url-parse "https://example.com:8443/path/to?q=1#frag"))

(define (alist-ref key alist)
  (let ((entry (assoc key alist)))
    (if entry
        (cdr entry)
        #f)))

(display "T1 url-parse returns alist: ")
(display (if (pair? parsed)
             "PASS"
             (list "FAIL got " parsed)))
(newline)

(display "T2 url-parse extracts scheme and host: ")
(display (if (and (string=? (alist-ref "scheme" parsed) "https")
                  (string=? (alist-ref "host" parsed) "example.com"))
             "PASS"
             (list "FAIL got " parsed)))
(newline)

(display "T3 url-parse extracts port and path: ")
(display (if (and (= (alist-ref "port" parsed) 8443)
                  (string=? (alist-ref "path" parsed) "/path/to"))
             "PASS"
             (list "FAIL got " parsed)))
(newline)

(display "T4 url-parse extracts query and fragment: ")
(display (if (and (string=? (alist-ref "query" parsed) "q=1")
                  (string=? (alist-ref "fragment" parsed) "frag"))
             "PASS"
             (list "FAIL got " parsed)))
(newline)

(define defaulted (url-parse "https://example.org"))

(display "T5 url-parse defaults https port and root path: ")
(display (if (and (= (alist-ref "port" defaulted) 443)
                  (string=? (alist-ref "path" defaulted) "/"))
             "PASS"
             (list "FAIL got " defaulted)))
(newline)

(display "T6 url-parse rejects malformed input: ")
(display (if (not (url-parse "not a url"))
             "PASS"
             "FAIL"))
(newline)

(display "=== url parse VM surface complete ===") (newline)
