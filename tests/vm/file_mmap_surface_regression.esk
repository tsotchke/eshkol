;; Standalone VM regression for file-mmap/file-munmap and bytevector exposure.

(display "=== file-mmap VM surface regression ===") (newline)

(define path "/tmp/eshkol-vm-mmap-surface.txt")
(define out (open-output-file path))
(write-string "abcdef" out)
(close-port out)

(define in (open-input-file path))
(define text-roundtrip (read-line in))
(close-port in)
(display "T1 file port write/read round-trip: ")
(display (if (string=? text-roundtrip "abcdef")
             "PASS"
             (list "FAIL got " text-roundtrip)))
(newline)

(define mapped (file-mmap path 1 3))
(display "T2 file-mmap returns expected bytevector slice: ")
(display (if (and (bytevector? mapped)
                  (= (bytevector-length mapped) 3)
                  (= (bytevector-u8-ref mapped 0) 98)
                  (= (bytevector-u8-ref mapped 1) 99)
                  (= (bytevector-u8-ref mapped 2) 100))
             "PASS"
             (list "FAIL got " mapped)))
(newline)

(define empty (file-mmap path 6 0))
(display "T3 file-mmap empty EOF slice: ")
(display (if (and (bytevector? empty)
                  (= (bytevector-length empty) 0))
             "PASS"
             (list "FAIL got " empty)))
(newline)

(display "T4 file-munmap no-op succeeds: ")
(file-munmap mapped)
(file-munmap empty)
(display "PASS")
(newline)

(delete-file path)

(display "=== file-mmap VM surface complete ===") (newline)
