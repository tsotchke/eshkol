;; VM-internal numeric aliases must remain registered and correct.
(display (if (= (div2 8 2) 4) "PASS" "FAIL"))
(display ": div2 exact division")
(newline)

(define d (make-dual 2.0 1.0))
(define d2 (make-dual 3.0 0.5))
(display (if (and (dual? d)
                  (= (dual-value d) 2.0)
                  (= (dual-derivative d) 1.0)
                  (= (dual-primal d) 2.0)
                  (= (dual-tangent d) 1.0)
                  (= (dual-value (dual+ d d2)) 5.0)
                  (= (dual-value (dual- d2 d)) 1.0)
                  (= (dual-value (dual* d d2)) 6.0)
                  (= (dual-value (dual/ d2 d)) 1.5)
                  (> (dual-value (dual-sin d)) 0.0)
                  (< (dual-value (dual-cos d)) 0.0)
                  (> (dual-value (dual-exp d)) 7.0)
                  (> (dual-value (dual-log d)) 0.0)
                  (> (dual-value (dual-sqrt d)) 1.0))
             "PASS" "FAIL"))
(display ": complete dual-number alias surface")
(newline)
