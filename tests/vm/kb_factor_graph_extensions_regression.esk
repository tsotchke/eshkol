;; Standalone VM KB/factor-graph extension regression.

(define kb (make-kb))
(kb-assert! kb (make-fact '(likes alice cats)))
(kb-assert! kb (make-fact '(likes bob dogs)))
(kb-assert! kb (make-fact '(parent alice bob)))

(display (if (= (kb-count kb) 3) "PASS" "FAIL")) (display ": kb-count all") (newline)
(display (if (= (kb-count-predicate kb 'likes) 2) "PASS" "FAIL")) (display ": kb-count predicate") (newline)
(display (if (= (kb-count-matching kb 'likes) 2) "PASS" "FAIL"))
(display ": kb-count matching alias") (newline)

(display (if (kb-retract! kb (make-fact '(likes alice cats))) "PASS" "FAIL"))
(display ": kb-retract structural") (newline)
(display (if (= (kb-count kb) 2) "PASS" "FAIL")) (display ": kb-count after retract") (newline)
(display (if (= (kb-count-predicate kb 'likes) 1) "PASS" "FAIL"))
(display ": kb-count predicate after retract") (newline)

(define fg (make-factor-graph 1 '(65)))
(define m (fg-marginal fg 0))
(display (if (and (> (tensor-ref m 64) 0.015) (< (tensor-ref m 64) 0.016))
             "PASS"
             "FAIL"))
(display ": fg-marginal supports dim > 64") (newline)

(display (if (> (fg-entropy fg 0) 4.0) "PASS" "FAIL"))
(display ": fg-entropy supports dim > 64") (newline)
(display (if (> (fg-total-entropy fg) 4.0) "PASS" "FAIL"))
(display ": fg-total-entropy") (newline)
(display (if (> (fg-joint-entropy fg) 4.0) "PASS" "FAIL"))
(display ": fg-joint-entropy alias") (newline)

(define observed (make-factor-graph 1 '(3)))
(display (if (fg-observe! observed 0 2) "PASS" "FAIL"))
(display ": fg-observe registered") (newline)
(define observed-m (fg-marginal observed 0))
(display (if (= (tensor-ref observed-m 2) 1.0) "PASS" "FAIL"))
(display ": fg-observe clamps belief") (newline)

(display "PASS: KB/factor-graph extension regression complete")
(newline)
