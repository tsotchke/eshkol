;; Standalone VM reverse-mode AD tape regression.
;; Covers VM-only builtin registration and native dispatch gaps.

(define tape (ad-tape-new))
(define x (ad-var tape 2.0))
(define three (ad-const tape 3.0))
(define y (ad-pow tape x three))
(define sum-node (ad-add tape x three))
(define sub-node (ad-sub tape three x))
(define mul-node (ad-mul tape x three))
(define div-node (ad-div tape three x))
(define cos-node (ad-cos tape x))
(define log-node (ad-log tape x))
(define sqrt-node (ad-sqrt tape x))
(define neg-node (ad-neg tape x))
(define abs-node (ad-abs tape neg-node))
(define relu-node (ad-relu tape neg-node))
(define sigmoid-node (ad-sigmoid tape x))
(define tanh-node (ad-tanh tape x))
(ad-backward tape y)

(display (if (= (ad-node-value tape y) 8.0) "PASS" "FAIL"))
(display ": ad-node-value reads forward value")
(newline)

(display (if (= (ad-value tape y) 8.0) "PASS" "FAIL"))
(display ": ad-value alias reads forward value")
(newline)

(display (if (= (ad-gradient tape x) 12.0) "PASS" "FAIL"))
(display ": ad-pow propagates gradient")
(newline)

(display (if (= (ad-gradient-of tape x) 12.0) "PASS" "FAIL"))
(display ": ad-gradient-of alias works")
(newline)

(display (if (> (ad-tape-length tape) 0) "PASS" "FAIL"))
(display ": ad-tape-length reports nodes")
(newline)

(display (if (= (ad-value-of tape y) 8.0) "PASS" "FAIL"))
(display ": ad-value-of alias works")
(newline)

(display (if (and (= (ad-node-value tape sum-node) 5.0)
                  (= (ad-node-value tape sub-node) 1.0)
                  (= (ad-node-value tape mul-node) 6.0)
                  (= (ad-node-value tape div-node) 1.5)
                  (< (abs (- (ad-node-value tape abs-node) 2.0)) 1e-12)
                  (= (ad-node-value tape relu-node) 0.0)
                  (> (ad-node-value tape sigmoid-node) 0.5)
                  (> (ad-node-value tape tanh-node) 0.9)
                  (< (ad-node-value tape cos-node) 0.0)
                  (> (ad-node-value tape log-node) 0.0)
                  (> (ad-node-value tape sqrt-node) 1.0))
             "PASS" "FAIL"))
(display ": complete low-level AD operation surface")
(newline)

;; Low-level reverse-mode gradient of f(a,b)=a^2+b^2 at (1,1) built directly on
;; the tape: seed a,b as variables, record the graph, one backward sweep, then
;; read each input's adjoint.  Expected grad = (2a, 2b) = (2, 2).  (The former
;; high-level `reverse-gradient` convenience is exercised on the VM / via the
;; `gradient` surface; here we assert the low-level tape primitives that are
;; public on every substrate.)
(define rt (ad-tape-new))
(define ra (ad-var rt 1.0))
(define rb (ad-var rt 1.0))
(define rf (ad-add rt (ad-mul rt ra ra) (ad-mul rt rb rb)))
(ad-backward rt rf)
(display (if (and (= (ad-gradient rt ra) 2.0) (= (ad-gradient rt rb) 2.0))
             "PASS" "FAIL"))
(display ": low-level tape reverse-mode gradient = (2a, 2b)")
(newline)

(ad-tape-release tape)
(ad-tape-release tape)
(display "PASS: ad-tape-release is idempotent")
(newline)
