;; Standalone VM geometric builtin surface regression.
;; The default build may not link qLLM geometry, but these names must resolve
;; and their no-library fallback must consume the right number of arguments.

(define t (make-tensor '(2) 0.0))
(define m (make-euclidean-manifold 2))
(define h (make-hyperbolic-manifold 2 -1.0))
(define s (make-spherical-manifold 2))

(make-product-manifold m h)
(manifold-curvature h)
(hyperbolic-exp-map t t -1.0)
(hyperbolic-log-map t t -1.0)
(geodesic-distance t t -1.0)
(parallel-transport t t t -1.0)
(manifold-project t -1.0)
(mobius-add t t -1.0)
(mobius-scalar-mul 0.5 t -1.0)
(poincare-distance t t -1.0)
(frechet-mean t t -1.0)
(great-circle-distance t t)
(slerp t t 0.5)
(spherical-exp t t)
(spherical-log t t)
(spherical-project t)
(so3-exp t)
(so3-log t)
(se3-exp t)
(se3-log t)
(quaternion-mul t t)
(metric-tensor h)
(christoffel h t)
(riemann-curvature h)
(ricci-scalar h)
(sectional-curvature h t t)
(wedge-product t t)
(exterior-derivative t)
(hodge-star t t)
(interior-product t t)
(pullback t t)
(riemannian-sgd-step t t 0.01 -1.0)
(riemannian-adam-step t t 0.01 0.9 0.999 -1.0)
(riemannian-grad t t -1.0)
(retraction t t -1.0)
(vector-transport t t t -1.0)
(geodesic-attention-scores t t -1.0)
(geodesic-attention-values t t -1.0)
(curvature-softmax t -1.0)
(geodesic-attention-forward t t t -1.0)
(set-curvature! h -0.5)
(get-curvature h)
(curvature-gradient h t)
(transition-geometry! h -1.0 0.1)
(manifold-interpolate h s 0.5)
(curvature-hessian h t)
(adaptive-curvature-step h t)
(manifold-type h)
(manifold-dim h)
(manifold-dimension h)
(manifold-destroy! h)

(display "PASS: geometric builtin surface is registered and stack-safe")
(newline)
