;; Standalone VM regression for optional SQLite convenience builtins.
;; The minimal standalone VM binary does not link agent SQLite hooks, so these
;; must fail cleanly instead of introducing a sqlite dependency.

(display "=== sqlite VM surface regression ===") (newline)

(define transaction-result
  (db-transaction 0
                  (lambda ()
                    42)))

(display "T1 db-transaction cleanly unavailable without SQLite hooks: ")
(display (if (not transaction-result)
             "PASS"
             (list "FAIL got " transaction-result)))
(newline)

(display "T2 db-busy-timeout cleanly unavailable without SQLite hooks: ")
(display (if (not (db-busy-timeout 0 100))
             "PASS"
             "FAIL"))
(newline)

(display "T3 db-last-insert-id cleanly unavailable without SQLite hooks: ")
(display (if (not (db-last-insert-id 0))
             "PASS"
             "FAIL"))
(newline)

(display "T4 db-changes cleanly unavailable without SQLite hooks: ")
(display (if (not (db-changes 0))
             "PASS"
             "FAIL"))
(newline)

(display "=== sqlite VM surface complete ===") (newline)
