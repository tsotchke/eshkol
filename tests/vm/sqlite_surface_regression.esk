;; Standalone VM regression for optional SQLite convenience builtins.
;; Invalid database handles must fail cleanly whether or not the production
;; agent SQLite bridge is linked into the hosted VM executable.

(display "=== sqlite VM surface regression ===") (newline)

(define transaction-result
  (db-transaction 0
                  (lambda ()
                    42)))

(display "T1 db-transaction rejects an invalid handle: ")
(display (if (not transaction-result)
             "PASS"
             (list "FAIL got " transaction-result)))
(newline)

(display "T2 db-busy-timeout rejects an invalid handle: ")
(display (if (not (db-busy-timeout 0 100))
             "PASS"
             "FAIL"))
(newline)

(display "T3 db-last-insert-id rejects an invalid handle: ")
(display (if (not (db-last-insert-id 0))
             "PASS"
             "FAIL"))
(newline)

(display "T4 db-changes rejects an invalid handle: ")
(display (if (not (db-changes 0))
             "PASS"
             "FAIL"))
(newline)

(display "=== sqlite VM surface complete ===") (newline)
