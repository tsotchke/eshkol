; ESH-0180: R7RS 2-arg substring — (substring s start) => (substring s start (string-length s))
(define (check name got want)
  (display (if (equal? got want) "PASS " "FAIL ")) (display name)
  (if (not (equal? got want)) (begin (display " got=") (write got) (display " want=") (write want)))
  (newline))
(check "2arg-mid"   (substring "hello" 1)   "ello")
(check "2arg-zero"  (substring "hello" 0)   "hello")
(check "2arg-empty" (substring "hello" 5)   "")
(check "3arg-still" (substring "hello" 1 3) "el")
(check "2arg-append" (string-append "[" (substring "abcdef" 2) "]") "[cdef]")
