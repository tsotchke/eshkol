; num_exact_inexact.esk - exactness conversions at the 2^53 double boundary.
(require stdlib)
(define two53 (expt 2 53))                ; 9007199254740992
(define d53 (exact->inexact two53))
(define ok
  (and (= d53 9007199254740992.0)
       (= (inexact->exact 9007199254740992.0) two53)
       (= (inexact->exact 0.5) (/ 1 2))
       (= (exact->inexact (/ 1 2)) 0.5)
       ; 2^53 + 1 is NOT representable as a double: rounds back to 2^53
       (= (exact->inexact (+ two53 1)) d53)
       ; 2^53 + 2 IS representable
       (= (inexact->exact (exact->inexact (+ two53 2))) (+ two53 2))
       (= (exact->inexact 0) 0.0)))
(if ok (begin (display "OK exact-boundary") (newline))
       (begin (display "FAIL") (newline)))
