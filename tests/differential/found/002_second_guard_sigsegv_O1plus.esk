;; FINDING 002 (differential harness, corpus 20_guard_raise, hand-shrunk)
;; A displayed guard that actually catches a raise, followed by ANY second
;; guard form, SIGSEGVs at -O1/-O2/-O3 while exiting 0 at -O0 and under JIT:
;;   aot -O0 : prints #<unknown>, rc 0
;;   aot -O1/-O2/-O3 : SIGSEGV (rc 139)
;;   jit (cache or not) : rc 0
;; Axis pairs that diverge: aot-o0-vs-aot-o2, jit-vs-aot-o2, ...
;; Drop either the display, the raise, or the second guard and the crash
;; disappears.
(display (guard (e (#t e)) (raise 'x)))
(guard (e (#t e)) 2)
