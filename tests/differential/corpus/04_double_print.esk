;; double formatting incl. inf/nan
(display 0.1) (newline)
(display 1.5) (newline)
(display 100.0) (newline)
(display 0.001) (newline)
(display 1e10) (newline)
(display 1e-10) (newline)
(display -2.5) (newline)
(display (sqrt 2.0)) (newline)
(display (floor 2.7)) (newline)
(display (ceiling 2.3)) (newline)
(display (round 2.5)) (newline)
(display (truncate -2.7)) (newline)
(display (/ 1.0 0.0)) (newline)
(display (/ -1.0 0.0)) (newline)
(display (exp 0.0)) (newline)
