;; letrec + shadowing
(define (run)
  (letrec ((ev? (lambda (n) (if (= n 0) #t (od? (- n 1)))))
           (od? (lambda (n) (if (= n 0) #f (ev? (- n 1))))))
    (list (ev? 10) (od? 10))))
(display (run)) (newline)
(define x 'outer)
(define (shadow-test)
  (let ((x 'inner))
    (let ((x 'innermost))
      x)))
(display (shadow-test)) (newline)
(display x) (newline)
(let* ((a 1) (b (+ a 1)) (c (* b 2)))
  (display (list a b c)) (newline))
