;; exact rational arithmetic
(display (+ 1/2 1/3)) (newline)
(display (- 1/2 1/3)) (newline)
(display (* 2/3 3/4)) (newline)
(display (/ 1 3)) (newline)
(display (/ 10 4)) (newline)
(display (+ 1/3 2/3)) (newline)
(display (< 1/3 1/2)) (newline)
(display (numerator 6/8)) (newline)
(display (denominator 6/8)) (newline)
(display (exact->inexact 1/4)) (newline)
