;; delay/force + stream sieve
(define-syntax cons-stream (syntax-rules () ((_ a b) (cons a (delay b)))))
(define (stream-car s) (car s))
(define (stream-cdr s) (force (cdr s)))
(define (integers-from n) (cons-stream n (integers-from (+ n 1))))
(define (stream-filter p s)
  (if (p (stream-car s))
      (cons-stream (stream-car s) (stream-filter p (stream-cdr s)))
      (stream-filter p (stream-cdr s))))
(define (sieve s)
  (cons-stream (stream-car s)
               (sieve (stream-filter
                       (lambda (x) (not (= 0 (modulo x (stream-car s)))))
                       (stream-cdr s)))))
(define primes (sieve (integers-from 2)))
(define (stream-ref s n) (if (= n 0) (stream-car s) (stream-ref (stream-cdr s) (- n 1))))
(display (stream-ref primes 0)) (newline)
(display (stream-ref primes 4)) (newline)
(display (stream-ref primes 9)) (newline)
(define p (delay (begin (display "forced-once") (newline) 5)))
(display (force p)) (newline)
(display (force p)) (newline)
