;; hash tables (deterministic: query keys directly, no iteration order)
(define h (make-hash-table))
(hash-set! h "alice" 30)
(hash-set! h "bob" 25)
(hash-set! h 42 "answer")
(display (hash-ref h "alice")) (newline)
(display (hash-ref h "bob")) (newline)
(display (hash-ref h 42)) (newline)
(hash-set! h "alice" 31)
(display (hash-ref h "alice")) (newline)
