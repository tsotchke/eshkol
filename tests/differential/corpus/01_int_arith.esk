;; integer arithmetic: quotient/remainder/modulo/expt/gcd/lcm/abs/min/max
(display (+ 17 25)) (newline)
(display (- 3 10)) (newline)
(display (* 123 456)) (newline)
(display (quotient 17 5)) (newline)
(display (quotient -17 5)) (newline)
(display (remainder 17 5)) (newline)
(display (remainder -17 5)) (newline)
(display (modulo 17 5)) (newline)
(display (modulo -17 5)) (newline)
(display (expt 2 10)) (newline)
(display (abs -42)) (newline)
(display (min 3 1 2)) (newline)
(display (max 3 1 2)) (newline)
(display (gcd 12 18)) (newline)
(display (lcm 4 6)) (newline)
