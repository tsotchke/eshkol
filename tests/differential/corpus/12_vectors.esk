;; vector operations, literal #(...) and (vector ...)
(define v (vector 1 2 3 4 5))
(display (vector-length v)) (newline)
(display (vector-ref v 2)) (newline)
(vector-set! v 2 99)
(display (vector-ref v 2)) (newline)
(display (vector->list (vector 7 8 9))) (newline)
(display (list->vector '(a b c))) (newline)
(define lit #(1.5 2.5 3.5))
(display (vector-ref lit 1)) (newline)
(define mv (make-vector 3 0))
(vector-set! mv 1 'mid)
(display mv) (newline)
