;; closures capturing mutable state via set!
(define (make-counter)
  (let ((n 0))
    (lambda () (set! n (+ n 1)) n)))
(define c1 (make-counter))
(define c2 (make-counter))
(display (c1)) (newline)
(display (c1)) (newline)
(display (c2)) (newline)
(display (c1)) (newline)
(define (make-adder k) (lambda (x) (+ x k)))
(define add5 (make-adder 5))
(define add7 (make-adder 7))
(display (add5 10)) (newline)
(display (add7 10)) (newline)
