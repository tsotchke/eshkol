(require stdlib)

(display "TEST: Rational number edge cases") (newline)

; 1. Zero rational
(display (if (= 0/1 0) "PASS" "FAIL")) (display ": 0/1 equals 0") (newline)
(display (if (= 0/3 0) "PASS" "FAIL")) (display ": 0/3 equals 0") (newline)

; 2. Unity
(display (if (= 1/1 1) "PASS" "FAIL")) (display ": 1/1 equals 1") (newline)
(display (if (= 5/5 1) "PASS" "FAIL")) (display ": 5/5 equals 1") (newline)

; 3. Auto-reduction
(display (if (= 2/4 1/2) "PASS" "FAIL")) (display ": 2/4 reduces to 1/2") (newline)
(display (if (= 6/9 2/3) "PASS" "FAIL")) (display ": 6/9 reduces to 2/3") (newline)
(display (if (= 4/8 1/2) "PASS" "FAIL")) (display ": 4/8 reduces to 1/2") (newline)
(display (if (= 10/15 2/3) "PASS" "FAIL")) (display ": 10/15 reduces to 2/3") (newline)

; 4. Negative rationals
(display (if (= -1/2 (- 0 1/2)) "PASS" "FAIL")) (display ": -1/2 equals (- 0 1/2)") (newline)
(display (if (< -1/2 0) "PASS" "FAIL")) (display ": -1/2 is less than 0") (newline)
(display (if (= -3/6 -1/2) "PASS" "FAIL")) (display ": -3/6 reduces to -1/2") (newline)

; 5. Addition
(display (if (= (+ 1/3 1/3) 2/3) "PASS" "FAIL")) (display ": 1/3 + 1/3 = 2/3") (newline)
(display (if (= (+ 1/2 1/3) 5/6) "PASS" "FAIL")) (display ": 1/2 + 1/3 = 5/6") (newline)
(display (if (= (+ 1/4 3/4) 1) "PASS" "FAIL")) (display ": 1/4 + 3/4 = 1") (newline)

; 6. Multiplication
(display (if (= (* 2/3 3/4) 1/2) "PASS" "FAIL")) (display ": 2/3 * 3/4 = 1/2") (newline)
(display (if (= (* 1/2 1/2) 1/4) "PASS" "FAIL")) (display ": 1/2 * 1/2 = 1/4") (newline)

; 7. Division
(display (if (= (/ 1/2 1/3) 3/2) "PASS" "FAIL")) (display ": (/ 1/2 1/3) = 3/2") (newline)
(display (if (= (/ 2/3 4/3) 1/2) "PASS" "FAIL")) (display ": (/ 2/3 4/3) = 1/2") (newline)

; 8. Comparison
(display (if (< 1/3 1/2) "PASS" "FAIL")) (display ": 1/3 < 1/2") (newline)
(display (if (> 2/3 1/2) "PASS" "FAIL")) (display ": 2/3 > 1/2") (newline)
(display (if (<= 1/2 1/2) "PASS" "FAIL")) (display ": 1/2 <= 1/2") (newline)
(display (if (>= 3/4 1/2) "PASS" "FAIL")) (display ": 3/4 >= 1/2") (newline)

; 9. exact? on rationals
(display (if (exact? 1/2) "PASS" "FAIL")) (display ": 1/2 is exact") (newline)
(display (if (exact? 3/7) "PASS" "FAIL")) (display ": 3/7 is exact") (newline)

; 10. rational? predicate
(display (if (rational? 1/2) "PASS" "FAIL")) (display ": rational? on 1/2") (newline)
(display (if (rational? 3) "PASS" "FAIL")) (display ": rational? on integer 3") (newline)
(display (if (not (rational? 1.5)) "PASS" "FAIL")) (display ": rational? on 1.5 is false") (newline)

; 11. numerator/denominator accessors
(display (if (= (numerator 3/7) 3) "PASS" "FAIL")) (display ": numerator of 3/7 is 3") (newline)
(display (if (= (denominator 3/7) 7) "PASS" "FAIL")) (display ": denominator of 3/7 is 7") (newline)
(display (if (= (numerator 2/4) 1) "PASS" "FAIL")) (display ": numerator of 2/4 (reduced) is 1") (newline)
(display (if (= (denominator 2/4) 2) "PASS" "FAIL")) (display ": denominator of 2/4 (reduced) is 2") (newline)

; 12. Rational + integer
(display (if (= (+ 1/2 1) 3/2) "PASS" "FAIL")) (display ": 1/2 + 1 = 3/2") (newline)
(display (if (= (+ 2 1/3) 7/3) "PASS" "FAIL")) (display ": 2 + 1/3 = 7/3") (newline)
(display (if (= (- 1 1/4) 3/4) "PASS" "FAIL")) (display ": 1 - 1/4 = 3/4") (newline)

; 13. Rational + float coercion (inexact result)
(display (if (inexact? (+ 1/2 0.5)) "PASS" "FAIL")) (display ": 1/2 + 0.5 gives inexact result") (newline)
(display (if (= (+ 1/2 0.5) 1.0) "PASS" "FAIL")) (display ": 1/2 + 0.5 = 1.0") (newline)

; 14. Large rationals
(display (if (= 999999/1000000 999999/1000000) "PASS" "FAIL")) (display ": 999999/1000000 self-equality") (newline)
(display (if (< 999999/1000000 1) "PASS" "FAIL")) (display ": 999999/1000000 < 1") (newline)

; 15. exact->inexact on rationals
(display (if (inexact? (exact->inexact 1/2)) "PASS" "FAIL")) (display ": exact->inexact 1/2 is inexact") (newline)
(display (if (= (exact->inexact 1/2) 0.5) "PASS" "FAIL")) (display ": exact->inexact 1/2 = 0.5") (newline)
(display (if (= (exact->inexact 1/3) (/ 1.0 3.0)) "PASS" "FAIL")) (display ": exact->inexact 1/3 = 1.0/3.0") (newline)

; 16. inexact->exact on 0.5
(display (if (exact? (inexact->exact 0.5)) "PASS" "FAIL")) (display ": inexact->exact 0.5 is exact") (newline)
(display (if (= (inexact->exact 0.5) 1/2) "PASS" "FAIL")) (display ": inexact->exact 0.5 = 1/2") (newline)
