; recursion-depth probe -- generated by scripts/gen_recursion_depth.py
; stdlib (length) on a long list -- non-tail length SIGILLs (ESH-0108)
; KIND: stdlib_length
; DEPTH: 1000000
; EXPECT: xknown ESH-0108
(require stdlib)
(define (build n acc) (if (= n 0) acc (build (- n 1) (cons n acc))))
(define __want 1000000)
(define __got (length (build 1000000 (quote ()))))
(if (= __got __want)
    (begin (display "PASS: stdlib_length d=1000000 v=") (display __got) (newline))
    (begin (display "WRONG: stdlib_length d=1000000 got=") (display __got)
           (display " want=") (display __want) (newline)))
