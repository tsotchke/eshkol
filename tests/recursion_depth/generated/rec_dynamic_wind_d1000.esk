; recursion-depth probe -- generated by scripts/gen_recursion_depth.py
; deep dynamic-wind nesting -- overflow ~100k; SIGILL variant silent (ESH-0119)
; KIND: dynamic_wind
; DEPTH: 1000
; EXPECT: pass
(define (dw n)
  (if (= n 0) 0
      (dynamic-wind (lambda () #f)
                    (lambda () (+ n (dw (- n 1))))
                    (lambda () #f))))
(define __want (quotient (* 1000 (+ 1000 1)) 2))
(define __got (dw 1000))
(if (= __got __want)
    (begin (display "PASS: dynamic_wind d=1000 v=") (display __got) (newline))
    (begin (display "WRONG: dynamic_wind d=1000 got=") (display __got)
           (display " want=") (display __want) (newline)))
