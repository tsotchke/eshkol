; recursion-depth probe -- generated by scripts/gen_recursion_depth.py
; mutual tail recursion, 2-cycle (ping/pong) -- proper tail call, O(1) stack
; KIND: mutual_tail2
; DEPTH: 500000
; EXPECT: pass
(define (ping n acc) (if (= n 0) acc (pong (- n 1) (+ acc n))))
(define (pong n acc) (if (= n 0) acc (ping (- n 1) (+ acc n))))
(define __want (quotient (* 500000 (+ 500000 1)) 2))
(define __got (ping 500000 0))
(if (= __got __want)
    (begin (display "PASS: mutual_tail2 d=500000 v=") (display __got) (newline))
    (begin (display "WRONG: mutual_tail2 d=500000 got=") (display __got)
           (display " want=") (display __want) (newline)))
