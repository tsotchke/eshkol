; recursion-depth probe -- generated by scripts/gen_recursion_depth.py
; deep dynamic-wind nesting -- clean platform-dependent boundary near 100k
; KIND: dynamic_wind
; DEPTH: 90000
; EXPECT: boundary
(define (dw n)
  (if (= n 0) 0
      (dynamic-wind (lambda () #f)
                    (lambda () (+ n (dw (- n 1))))
                    (lambda () #f))))
(define __want (quotient (* 90000 (+ 90000 1)) 2))
(define __got (dw 90000))
(if (= __got __want)
    (begin (display "PASS: dynamic_wind d=90000 v=") (display __got) (newline))
    (begin (display "WRONG: dynamic_wind d=90000 got=") (display __got)
           (display " want=") (display __want) (newline)))
