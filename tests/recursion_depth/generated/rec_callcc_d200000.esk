; recursion-depth probe -- generated by scripts/gen_recursion_depth.py
; deep call/cc nesting -- clean 100000 guard
; KIND: callcc
; DEPTH: 200000
; EXPECT: limit
(define (cc n) (if (= n 0) 0 (call/cc (lambda (k) (+ n (cc (- n 1)))))))
(define __want (quotient (* 200000 (+ 200000 1)) 2))
(define __got (cc 200000))
(if (= __got __want)
    (begin (display "PASS: callcc d=200000 v=") (display __got) (newline))
    (begin (display "WRONG: callcc d=200000 got=") (display __got)
           (display " want=") (display __want) (newline)))
