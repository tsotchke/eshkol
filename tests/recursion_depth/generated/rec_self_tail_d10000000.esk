; recursion-depth probe -- generated by scripts/gen_recursion_depth.py
; self tail recursion -- must be O(1) stack
; KIND: self_tail
; DEPTH: 10000000
; EXPECT: pass
(define (rec n acc) (if (= n 0) acc (rec (- n 1) (+ acc n))))
(define __want (quotient (* 10000000 (+ 10000000 1)) 2))
(define __got (rec 10000000 0))
(if (= __got __want)
    (begin (display "PASS: self_tail d=10000000 v=") (display __got) (newline))
    (begin (display "WRONG: self_tail d=10000000 got=") (display __got)
           (display " want=") (display __want) (newline)))
