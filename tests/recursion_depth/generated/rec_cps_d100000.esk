; recursion-depth probe -- generated by scripts/gen_recursion_depth.py
; CPS / explicit continuation chain -- clean 100000 guard (ESH-0080 fixed #93)
; KIND: cps
; DEPTH: 100000
; EXPECT: boundary
(define (sum-cps n k) (if (= n 0) (k 0) (sum-cps (- n 1) (lambda (r) (k (+ r n))))))
(define __want (quotient (* 100000 (+ 100000 1)) 2))
(define __got (sum-cps 100000 (lambda (x) x)))
(if (= __got __want)
    (begin (display "PASS: cps d=100000 v=") (display __got) (newline))
    (begin (display "WRONG: cps d=100000 got=") (display __got)
           (display " want=") (display __want) (newline)))
