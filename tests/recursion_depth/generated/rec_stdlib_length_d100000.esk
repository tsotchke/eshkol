; recursion-depth probe -- generated by scripts/gen_recursion_depth.py
; stdlib (length) on a long list -- tail-safe after ESH-0108
; KIND: stdlib_length
; DEPTH: 100000
; EXPECT: pass
(require stdlib)
(define (build n acc) (if (= n 0) acc (build (- n 1) (cons n acc))))
(define __want 100000)
(define __got (length (build 100000 (quote ()))))
(if (= __got __want)
    (begin (display "PASS: stdlib_length d=100000 v=") (display __got) (newline))
    (begin (display "WRONG: stdlib_length d=100000 got=") (display __got)
           (display " want=") (display __want) (newline)))
