; recursion-depth probe -- generated by scripts/gen_recursion_depth.py
; recursion through a metacircular evaluator -- clean platform-dependent boundary
; KIND: metacircular
; DEPTH: 30000
; EXPECT: boundary
(require stdlib)
(define (tagged? e t) (and (pair? e) (eq? (car e) t)))
(define (lookup v env)
  (if (null? env) (error "unbound" v)
      (let loop ((vs (caar env)) (xs (cdar env)))
        (cond ((null? vs) (lookup v (cdr env)))
              ((eq? (car vs) v) (car xs))
              (else (loop (cdr vs) (cdr xs)))))))
(define (meval exp env)
  (cond ((number? exp) exp)
        ((symbol? exp) (lookup exp env))
        ((tagged? exp 'quote) (cadr exp))
        ((tagged? exp 'if)
         (if (not (eq? (meval (cadr exp) env) #f))
             (meval (caddr exp) env) (meval (cadddr exp) env)))
        ((tagged? exp 'lambda) (list 'closure (cadr exp) (caddr exp) env))
        (else (mapply (meval (car exp) env)
                      (map (lambda (a) (meval a env)) (cdr exp))))))
(define (mapply proc args)
  (cond ((procedure? proc) (apply proc args))
        ((tagged? proc 'closure)
         (meval (caddr proc) (cons (cons (cadr proc) args) (cadddr proc))))
        (else (error "not-applicable" proc))))
(define meta-env (list (cons (list '+ '- '* '= '<) (list + - * = <))))
;; interpreted (self-application) tail-recursive triangular sum to depth 30000
(define meta-prog
  '((lambda (sum) (sum sum 30000 0))
    (lambda (self n acc) (if (= n 0) acc (self self (- n 1) (+ acc n))))))
(define __want (quotient (* 30000 (+ 30000 1)) 2))
(define __got (meval meta-prog meta-env))
(if (= __got __want)
    (begin (display "PASS: metacircular d=30000 v=") (display __got) (newline))
    (begin (display "WRONG: metacircular d=30000 got=") (display __got)
           (display " want=") (display __want) (newline)))
