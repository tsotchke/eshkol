; recursion-depth probe -- generated by scripts/gen_recursion_depth.py
; deep guard nesting -- silent SIGILL ~200k (ESH-0119)
; KIND: guard
; DEPTH: 300000
; EXPECT: xknown ESH-0119
(define (g n) (if (= n 0) 0 (guard (e (#t -1)) (+ n (g (- n 1))))))
(define __want (quotient (* 300000 (+ 300000 1)) 2))
(define __got (g 300000))
(if (= __got __want)
    (begin (display "PASS: guard d=300000 v=") (display __got) (newline))
    (begin (display "WRONG: guard d=300000 got=") (display __got)
           (display " want=") (display __want) (newline)))
