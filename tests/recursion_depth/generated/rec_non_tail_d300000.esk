; recursion-depth probe -- generated by scripts/gen_recursion_depth.py
; non-tail recursion (accumulator on the C stack) -- documented clean ceiling (ESH-0112)
; KIND: non_tail
; DEPTH: 300000
; EXPECT: limit
(define (down n) (if (= n 0) 0 (+ n (down (- n 1)))))
(define __want (quotient (* 300000 (+ 300000 1)) 2))
(define __got (down 300000))
(if (= __got __want)
    (begin (display "PASS: non_tail d=300000 v=") (display __got) (newline))
    (begin (display "WRONG: non_tail d=300000 got=") (display __got)
           (display " want=") (display __want) (newline)))
