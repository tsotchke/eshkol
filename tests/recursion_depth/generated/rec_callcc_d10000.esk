; recursion-depth probe -- generated by scripts/gen_recursion_depth.py
; deep call/cc nesting -- clean 100000 guard
; KIND: callcc
; DEPTH: 10000
; EXPECT: pass
(define (cc n) (if (= n 0) 0 (call/cc (lambda (k) (+ n (cc (- n 1)))))))
(define __want (quotient (* 10000 (+ 10000 1)) 2))
(define __got (cc 10000))
(if (= __got __want)
    (begin (display "PASS: callcc d=10000 v=") (display __got) (newline))
    (begin (display "WRONG: callcc d=10000 got=") (display __got)
           (display " want=") (display __want) (newline)))
