;; SICP Chapter 5.1/5.2 - recursive register machines.
;; Exercises label-valued continue registers, save/restore across calls, and
;; stack statistics with recursive factorial and Fibonacci controllers.

(define fails 0)
(define (check name expected actual)
  (if (equal? expected actual)
      (begin (display "PASS: ") (display name) (newline))
      (begin (set! fails (+ fails 1))
             (display "FAIL: ") (display name) (display " expected=") (display expected)
             (display " actual=") (display actual) (newline))))

;; ---- register file ----
(define (make-regs names)
  (map (lambda (n) (cons n 0)) names))
(define (reg-cell regs name)
  (let loop ((rs regs))
    (cond ((null? rs) (error "no register" name))
          ((eq? (caar rs) name) (car rs))
          (else (loop (cdr rs))))))
(define (get-reg regs name) (cdr (reg-cell regs name)))
(define (set-reg! regs name v) (set-cdr! (reg-cell regs name) v))

;; ---- stack: #(contents depth max-depth pushes) ----
(define (make-stack)
  (let ((s (make-vector 4)))
    (vector-set! s 0 '())
    (vector-set! s 1 0)
    (vector-set! s 2 0)
    (vector-set! s 3 0)
    s))
(define (stack-contents s) (vector-ref s 0))
(define (stack-depth s) (vector-ref s 1))
(define (stack-max-depth s) (vector-ref s 2))
(define (stack-pushes s) (vector-ref s 3))
(define (push-stack! s reg-name value)
  (let ((new-depth (+ (stack-depth s) 1)))
    (vector-set! s 0 (cons (cons reg-name value) (stack-contents s)))
    (vector-set! s 1 new-depth)
    (if (> new-depth (stack-max-depth s))
        (vector-set! s 2 new-depth))
    (vector-set! s 3 (+ (stack-pushes s) 1))
    "ok"))
(define (pop-stack! s reg-name)
  (let ((contents (stack-contents s)))
    (cond ((null? contents) (error "empty stack" reg-name))
          ((not (eq? (caar contents) reg-name))
           (error "restore register mismatch" (list reg-name (caar contents))))
          (else
           (vector-set! s 0 (cdr contents))
           (vector-set! s 1 (- (stack-depth s) 1))
           (cdar contents)))))

;; ---- operation and label tables ----
(define (op-lookup ops name)
  (let loop ((os ops))
    (cond ((null? os) (error "no op" name))
          ((eq? (caar os) name) (cdar os))
          (else (loop (cdr os))))))
(define (build-labels instrs)
  (let loop ((is instrs) (i 0) (acc '()))
    (cond ((null? is) (reverse acc))
          ((symbol? (car is)) (loop (cdr is) (+ i 1) (cons (cons (car is) i) acc)))
          (else (loop (cdr is) (+ i 1) acc)))))
(define (label-index labels name)
  (let loop ((ls labels))
    (cond ((null? ls) (error "no label" name))
          ((eq? (caar ls) name) (cdar ls))
          (else (loop (cdr ls))))))
(define (list->vec lst)
  (let* ((n (length lst)) (v (make-vector n)))
    (let loop ((i 0) (xs lst))
      (if (null? xs) v (begin (vector-set! v i (car xs)) (loop (+ i 1) (cdr xs)))))))

(define (eval-operand op regs)
  (cond ((eq? (car op) 'const) (cadr op))
        ((eq? (car op) 'reg) (get-reg regs (cadr op)))
        (else (error "bad operand" op))))
(define (eval-opexp form regs ops)
  (let ((proc (op-lookup ops (cadr form)))
        (vals (map (lambda (a) (eval-operand a regs)) (cddr form))))
    (apply proc vals)))

;; ---- the machine loop ----
(define (run-machine reg-names ops instrs)
  (let ((regs (make-regs reg-names))
        (stack (make-stack))
        (labels (build-labels instrs))
        (code (list->vec instrs))
        (n (length instrs)))
    (let run ((pc 0) (flag #f))
      (if (>= pc n)
          (cons regs stack)
          (let ((ins (vector-ref code pc)))
            (cond
              ((symbol? ins) (run (+ pc 1) flag))
              ((eq? (car ins) 'assign)
               (let ((target (cadr ins)) (expr (caddr ins)))
                 (set-reg! regs target
                           (cond ((eq? (car expr) 'const) (cadr expr))
                                 ((eq? (car expr) 'reg) (get-reg regs (cadr expr)))
                                 ((eq? (car expr) 'label) (label-index labels (cadr expr)))
                                 ((eq? (car expr) 'op) (eval-opexp expr regs ops))
                                 (else (error "bad assign" expr))))
                 (run (+ pc 1) flag)))
              ((eq? (car ins) 'test)
               (run (+ pc 1) (eval-opexp (cadr ins) regs ops)))
              ((eq? (car ins) 'branch)
               (if (not (eq? flag #f))
                   (run (label-index labels (cadr (cadr ins))) flag)
                   (run (+ pc 1) flag)))
              ((eq? (car ins) 'goto)
               (let ((dest (cadr ins)))
                 (if (eq? (car dest) 'label)
                     (run (label-index labels (cadr dest)) flag)
                     (run (get-reg regs (cadr dest)) flag))))
              ((eq? (car ins) 'save)
               (push-stack! stack (cadr ins) (get-reg regs (cadr ins)))
               (run (+ pc 1) flag))
              ((eq? (car ins) 'restore)
               (set-reg! regs (cadr ins) (pop-stack! stack (cadr ins)))
               (run (+ pc 1) flag))
              (else (error "bad instruction" ins))))))))

(define ops
  (list (cons '+ +) (cons '- -) (cons '* *)
        (cons '= (lambda (a b) (if (= a b) #t #f)))
        (cons '< (lambda (a b) (if (< a b) #t #f)))))

(define (machine-reg m name) (get-reg (car m) name))
(define (machine-stack m) (cdr m))

;; Recursive factorial machine from SICP 5.1.4.
(define (run-recursive-factorial n)
  (run-machine
   '(n val continue)
   ops
   (list
    (list 'assign 'n (list 'const n))
    '(assign continue (label fact-done))
    'fact-loop
    '(test (op = (reg n) (const 1)))
    '(branch (label base-case))
    '(save continue)
    '(save n)
    '(assign n (op - (reg n) (const 1)))
    '(assign continue (label after-fact))
    '(goto (label fact-loop))
    'after-fact
    '(restore n)
    '(restore continue)
    '(assign val (op * (reg n) (reg val)))
    '(goto (reg continue))
    'base-case
    '(assign val (const 1))
    '(goto (reg continue))
    'fact-done)))

(define fact5 (run-recursive-factorial 5))
(define fact1 (run-recursive-factorial 1))

(check "recursive factorial 5 value" 120 (machine-reg fact5 'val))
(check "recursive factorial restores n" 5 (machine-reg fact5 'n))
(check "recursive factorial stack empty" 0 (stack-depth (machine-stack fact5)))
(check "recursive factorial push count" 8 (stack-pushes (machine-stack fact5)))
(check "recursive factorial max depth" 8 (stack-max-depth (machine-stack fact5)))
(check "recursive factorial base value" 1 (machine-reg fact1 'val))
(check "recursive factorial base push count" 0 (stack-pushes (machine-stack fact1)))

;; Recursive Fibonacci machine from SICP 5.1.4.
(define (run-recursive-fibonacci n)
  (run-machine
   '(n val continue)
   ops
   (list
    (list 'assign 'n (list 'const n))
    '(assign continue (label fib-done))
    'fib-loop
    '(test (op < (reg n) (const 2)))
    '(branch (label immediate-answer))
    '(save continue)
    '(assign continue (label afterfib-n-1))
    '(save n)
    '(assign n (op - (reg n) (const 1)))
    '(goto (label fib-loop))
    'afterfib-n-1
    '(restore n)
    '(restore continue)
    '(assign n (op - (reg n) (const 2)))
    '(save continue)
    '(assign continue (label afterfib-n-2))
    '(save val)
    '(goto (label fib-loop))
    'afterfib-n-2
    '(assign n (reg val))
    '(restore val)
    '(restore continue)
    '(assign val (op + (reg val) (reg n)))
    '(goto (reg continue))
    'immediate-answer
    '(assign val (reg n))
    '(goto (reg continue))
    'fib-done)))

(define fib5 (run-recursive-fibonacci 5))
(define fib0 (run-recursive-fibonacci 0))

(check "recursive fibonacci 5 value" 5 (machine-reg fib5 'val))
(check "recursive fibonacci stack empty" 0 (stack-depth (machine-stack fib5)))
(check "recursive fibonacci push count" 28 (stack-pushes (machine-stack fib5)))
(check "recursive fibonacci max depth" 8 (stack-max-depth (machine-stack fib5)))
(check "recursive fibonacci zero value" 0 (machine-reg fib0 'val))
(check "recursive fibonacci zero push count" 0 (stack-pushes (machine-stack fib0)))

(display "ch5 register machine recursive: ")
(display (if (= fails 0) "ALL PASS" (cons fails 'FAILS))) (newline)
