;; SICP Chapter 5.2 - register-machine stack operations and statistics.
;; Extends the compact simulator style from ch5_register_machine.esk with
;; save/restore, checked restore names, stack statistics, and initialization.

(define fails 0)
(define (check name expected actual)
  (if (equal? expected actual)
      (begin (display "PASS: ") (display name) (newline))
      (begin (set! fails (+ fails 1))
             (display "FAIL: ") (display name) (display " expected=") (display expected)
             (display " actual=") (display actual) (newline))))

;; ---- register file: a-list of (name . value), mutated with set-cdr! ----
(define (make-regs names)
  (map (lambda (n) (cons n 0)) names))
(define (reg-cell regs name)
  (let loop ((rs regs))
    (cond ((null? rs) (error "no register" name))
          ((eq? (caar rs) name) (car rs))
          (else (loop (cdr rs))))))
(define (get-reg regs name) (cdr (reg-cell regs name)))
(define (set-reg! regs name v) (set-cdr! (reg-cell regs name) v))

;; ---- stack: #(contents depth max-depth pushes) ----
(define (make-stack)
  (let ((s (make-vector 4)))
    (vector-set! s 0 '())
    (vector-set! s 1 0)
    (vector-set! s 2 0)
    (vector-set! s 3 0)
    s))
(define (stack-contents s) (vector-ref s 0))
(define (stack-depth s) (vector-ref s 1))
(define (stack-max-depth s) (vector-ref s 2))
(define (stack-pushes s) (vector-ref s 3))
(define (reset-stack! s)
  (vector-set! s 0 '())
  (vector-set! s 1 0)
  (vector-set! s 2 0)
  (vector-set! s 3 0)
  "ok")
(define (push-stack! s reg-name value)
  (let ((new-depth (+ (stack-depth s) 1)))
    (vector-set! s 0 (cons (cons reg-name value) (stack-contents s)))
    (vector-set! s 1 new-depth)
    (if (> new-depth (stack-max-depth s))
        (vector-set! s 2 new-depth))
    (vector-set! s 3 (+ (stack-pushes s) 1))
    "ok"))
(define (pop-stack! s reg-name)
  (let ((contents (stack-contents s)))
    (cond ((null? contents) (error "empty stack" reg-name))
          ((not (eq? (caar contents) reg-name))
           (error "restore register mismatch" (list reg-name (caar contents))))
          (else
           (vector-set! s 0 (cdr contents))
           (vector-set! s 1 (- (stack-depth s) 1))
           (cdar contents)))))

;; ---- operation and label tables ----
(define (op-lookup ops name)
  (let loop ((os ops))
    (cond ((null? os) (error "no op" name))
          ((eq? (caar os) name) (cdar os))
          (else (loop (cdr os))))))
(define (build-labels instrs)
  (let loop ((is instrs) (i 0) (acc '()))
    (cond ((null? is) (reverse acc))
          ((symbol? (car is)) (loop (cdr is) (+ i 1) (cons (cons (car is) i) acc)))
          (else (loop (cdr is) (+ i 1) acc)))))
(define (label-index labels name)
  (let loop ((ls labels))
    (cond ((null? ls) (error "no label" name))
          ((eq? (caar ls) name) (cdar ls))
          (else (loop (cdr ls))))))
(define (list->vec lst)
  (let* ((n (length lst)) (v (make-vector n)))
    (let loop ((i 0) (xs lst))
      (if (null? xs) v (begin (vector-set! v i (car xs)) (loop (+ i 1) (cdr xs)))))))

;; evaluate an operand: (const v) | (reg r)
(define (eval-operand op regs)
  (cond ((eq? (car op) 'const) (cadr op))
        ((eq? (car op) 'reg) (get-reg regs (cadr op)))
        (else (error "bad operand" op))))
(define (eval-opexp form regs ops)
  (let ((proc (op-lookup ops (cadr form)))
        (vals (map (lambda (a) (eval-operand a regs)) (cddr form))))
    (apply proc vals)))
(define (perform-opexp form regs ops stack)
  (if (eq? (cadr form) 'initialize-stack)
      (reset-stack! stack)
      (eval-opexp form regs ops)))

;; ---- the machine loop ----
(define (run-machine reg-names ops instrs)
  (let ((regs (make-regs reg-names))
        (stack (make-stack))
        (labels (build-labels instrs))
        (code (list->vec instrs))
        (n (length instrs)))
    (let run ((pc 0) (flag #f))
      (if (>= pc n)
          (cons regs stack)
          (let ((ins (vector-ref code pc)))
            (cond
              ((symbol? ins) (run (+ pc 1) flag))
              ((eq? (car ins) 'assign)
               (let ((target (cadr ins)) (expr (caddr ins)))
                 (set-reg! regs target
                           (cond ((eq? (car expr) 'const) (cadr expr))
                                 ((eq? (car expr) 'reg) (get-reg regs (cadr expr)))
                                 ((eq? (car expr) 'op) (eval-opexp expr regs ops))
                                 (else (error "bad assign" expr))))
                 (run (+ pc 1) flag)))
              ((eq? (car ins) 'test)
               (run (+ pc 1) (eval-opexp (cadr ins) regs ops)))
              ((eq? (car ins) 'branch)
               (if (not (eq? flag #f))
                   (run (label-index labels (cadr (cadr ins))) flag)
                   (run (+ pc 1) flag)))
              ((eq? (car ins) 'goto)
               (let ((dest (cadr ins)))
                 (if (eq? (car dest) 'label)
                     (run (label-index labels (cadr dest)) flag)
                     (run (get-reg regs (cadr dest)) flag))))
              ((eq? (car ins) 'save)
               (push-stack! stack (cadr ins) (get-reg regs (cadr ins)))
               (run (+ pc 1) flag))
              ((eq? (car ins) 'restore)
               (set-reg! regs (cadr ins) (pop-stack! stack (cadr ins)))
               (run (+ pc 1) flag))
              ((eq? (car ins) 'perform)
               (perform-opexp (cadr ins) regs ops stack)
               (run (+ pc 1) flag))
              (else (error "bad instruction" ins))))))))

(define ops
  (list (cons '+ +) (cons '- -) (cons '* *)
        (cons '= (lambda (a b) (if (= a b) #t #f)))
        (cons '> (lambda (a b) (if (> a b) #t #f)))))

(define (machine-reg m name) (get-reg (car m) name))
(define (machine-stack m) (cdr m))

;; Save/restore is LIFO and preserves overwritten register values.
(define saved-machine
  (run-machine
   '(x y total)
   ops
   (list
    '(assign x (const 10))
    '(assign y (const 20))
    '(save x)
    '(assign x (const 99))
    '(save y)
    '(assign y (const 77))
    '(restore y)
    '(restore x)
    '(assign total (op + (reg x) (reg y))))))

(check "stack save/restore x" 10 (machine-reg saved-machine 'x))
(check "stack save/restore y" 20 (machine-reg saved-machine 'y))
(check "stack save/restore total" 30 (machine-reg saved-machine 'total))
(check "stack depth after balanced restores" 0 (stack-depth (machine-stack saved-machine)))
(check "stack max depth records nesting" 2 (stack-max-depth (machine-stack saved-machine)))
(check "stack push count records saves" 2 (stack-pushes (machine-stack saved-machine)))

;; initialize-stack clears contents and resets statistics for later calls.
(define initialized-machine
  (run-machine
   '(a)
   ops
   (list
    '(assign a (const 5))
    '(save a)
    '(assign a (const 6))
    '(save a)
    '(perform (op initialize-stack))
    '(assign a (const 9))
    '(save a)
    '(assign a (const 0))
    '(restore a))))

(check "stack initialize preserves later restore" 9 (machine-reg initialized-machine 'a))
(check "stack initialize depth reset" 0 (stack-depth (machine-stack initialized-machine)))
(check "stack initialize max-depth reset" 1 (stack-max-depth (machine-stack initialized-machine)))
(check "stack initialize push-count reset" 1 (stack-pushes (machine-stack initialized-machine)))

(define (underflow-result)
  (guard (exn
          (else "caught"))
    (run-machine '(a) ops (list '(restore a)))
    "not-caught"))
(define (mismatch-result)
  (guard (exn
          (else "caught"))
    (run-machine '(a b) ops (list '(assign a (const 12)) '(save a) '(restore b)))
    "not-caught"))

(check "stack underflow edge is catchable" "caught" (underflow-result))
(check "stack mismatched restore edge is catchable" "caught" (mismatch-result))

(display "ch5 register machine stack: ")
(display (if (= fails 0) "ALL PASS" (cons fails 'FAILS))) (newline)
