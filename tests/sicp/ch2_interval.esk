;; SICP Chapter 2.1.4 — Interval arithmetic.

(define fails 0)
(define (check name ok)
  (if ok (begin (display "PASS: ") (display name) (newline))
      (begin (set! fails (+ fails 1)) (display "FAIL: ") (display name) (newline))))
(define (close? a b) (< (abs (- a b)) 1e-9))

(define (make-interval a b) (cons a b))
(define (lower-bound i) (car i))
(define (upper-bound i) (cdr i))
(define (add-interval x y)
  (make-interval (+ (lower-bound x) (lower-bound y))
                 (+ (upper-bound x) (upper-bound y))))
(define (mul-interval x y)
  (let ((p1 (* (lower-bound x) (lower-bound y)))
        (p2 (* (lower-bound x) (upper-bound y)))
        (p3 (* (upper-bound x) (lower-bound y)))
        (p4 (* (upper-bound x) (upper-bound y))))
    (make-interval (min p1 p2 p3 p4) (max p1 p2 p3 p4))))
(define (div-interval x y)
  (mul-interval x (make-interval (/ 1.0 (upper-bound y)) (/ 1.0 (lower-bound y)))))
(define (sub-interval x y)
  (make-interval (- (lower-bound x) (upper-bound y))
                 (- (upper-bound x) (lower-bound y))))
(define (width i) (/ (- (upper-bound i) (lower-bound i)) 2.0))

(define a (make-interval 1.0 2.0))
(define b (make-interval 3.0 5.0))

(let ((s (add-interval a b)))
  (check "add lower" (close? (lower-bound s) 4.0))
  (check "add upper" (close? (upper-bound s) 7.0)))
(let ((m (mul-interval a b)))
  (check "mul lower" (close? (lower-bound m) 3.0))
  (check "mul upper" (close? (upper-bound m) 10.0)))
(let ((d (div-interval (make-interval 6.0 8.0) (make-interval 2.0 4.0))))
  (check "div lower" (close? (lower-bound d) 1.5))
  (check "div upper" (close? (upper-bound d) 4.0)))
(let ((s (sub-interval b a)))
  (check "sub lower" (close? (lower-bound s) 1.0))
  (check "sub upper" (close? (upper-bound s) 4.0)))
;; width of sum = sum of widths (2.1.4 property)
(check "width-additive"
       (close? (width (add-interval a b)) (+ (width a) (width b))))
;; interval spanning negative: [-1,1]*[2,3] = [-3,3]
(let ((m (mul-interval (make-interval -1.0 1.0) (make-interval 2.0 3.0))))
  (check "mul-neg-span" (and (close? (lower-bound m) -3.0) (close? (upper-bound m) 3.0))))

(newline)
(if (= fails 0)
    (begin (display "ALL-PASS ch2_interval") (newline))
    (begin (display "HAS-FAIL ch2_interval ") (display fails) (newline)))
