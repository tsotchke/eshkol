;; SICP 3.3.5 — constraint propagation: connectors (has-value?, set-value!,
;; forget-value!, connect), adder/multiplier/constant primitives, and a probe
;; that collects (name value) records into a list instead of printing.
;; Exercises the book's celsius-fahrenheit-converter in BOTH directions:
;; set C=25 -> F=77, forget, set F=212 -> C=100.

(define fails 0)
(define (check name expected actual)
  (if (equal? expected actual)
      (begin (display "PASS: ") (display name) (newline))
      (begin (set! fails (+ fails 1))
             (display "FAIL: ") (display name)
             (display " expected=") (display expected)
             (display " actual=") (display actual) (newline))))
;; numeric check via = (tolerates exact/inexact representation differences)
(define (check-num name expected actual)
  (if (and (number? actual) (= expected actual))
      (begin (display "PASS: ") (display name) (newline))
      (begin (set! fails (+ fails 1))
             (display "FAIL: ") (display name)
             (display " expected=") (display expected)
             (display " actual=") (display actual) (newline))))

;; ---- generic helpers ----
(define (for-each-except exception procedure lst)
  (define (loop items)
    (cond ((null? items) 'done)
          ((eq? (car items) exception) (loop (cdr items)))
          (else (procedure (car items))
                (loop (cdr items)))))
  (loop lst))

(define (memq-obj x lst)
  (cond ((null? lst) #f)
        ((eq? x (car lst)) #t)
        (else (memq-obj x (cdr lst)))))

;; ---- connector / constraint interface ----
(define (inform-about-value constraint) (constraint 'I-have-a-value))
(define (inform-about-no-value constraint) (constraint 'I-lost-my-value))
(define (has-value? connector) (connector 'has-value?))
(define (get-value connector) (connector 'value))
(define (set-value! connector new-value informant)
  ((connector 'set-value!) new-value informant))
(define (forget-value! connector retractor)
  ((connector 'forget) retractor))
(define (connect connector new-constraint)
  ((connector 'connect) new-constraint))

;; ---- connectors ----
(define (make-connector)
  (let ((value #f) (informant #f) (constraints '()))
    (define (set-my-value newval setter)
      (cond ((not (has-value? me))
             (set! value newval)
             (set! informant setter)
             (for-each-except setter inform-about-value constraints))
            ((not (= value newval))
             (error "Contradiction" (list value newval)))
            (else 'ignored)))
    (define (forget-my-value retractor)
      (if (eq? retractor informant)
          (begin (set! informant #f)
                 (for-each-except retractor inform-about-no-value constraints))
          'ignored))
    (define (connect-me new-constraint)
      (if (not (memq-obj new-constraint constraints))
          (set! constraints (cons new-constraint constraints)))
      (if (has-value? me)
          (inform-about-value new-constraint))
      'done)
    (define (me request)
      (cond ((eq? request 'has-value?) (if informant #t #f))
            ((eq? request 'value) value)
            ((eq? request 'set-value!) set-my-value)
            ((eq? request 'forget) forget-my-value)
            ((eq? request 'connect) connect-me)
            (else (error "Unknown operation -- CONNECTOR" request))))
    me))

;; ---- primitive constraints ----
(define (adder a1 a2 sum)
  (define (process-new-value)
    (cond ((and (has-value? a1) (has-value? a2))
           (set-value! sum (+ (get-value a1) (get-value a2)) me))
          ((and (has-value? a1) (has-value? sum))
           (set-value! a2 (- (get-value sum) (get-value a1)) me))
          ((and (has-value? a2) (has-value? sum))
           (set-value! a1 (- (get-value sum) (get-value a2)) me))))
  (define (process-forget-value)
    (forget-value! sum me)
    (forget-value! a1 me)
    (forget-value! a2 me)
    (process-new-value))
  (define (me request)
    (cond ((eq? request 'I-have-a-value) (process-new-value))
          ((eq? request 'I-lost-my-value) (process-forget-value))
          (else (error "Unknown request -- ADDER" request))))
  (connect a1 me)
  (connect a2 me)
  (connect sum me)
  me)

(define (multiplier m1 m2 product)
  (define (process-new-value)
    (cond ((or (and (has-value? m1) (= (get-value m1) 0))
               (and (has-value? m2) (= (get-value m2) 0)))
           (set-value! product 0 me))
          ((and (has-value? m1) (has-value? m2))
           (set-value! product (* (get-value m1) (get-value m2)) me))
          ((and (has-value? product) (has-value? m1))
           (set-value! m2 (/ (get-value product) (get-value m1)) me))
          ((and (has-value? product) (has-value? m2))
           (set-value! m1 (/ (get-value product) (get-value m2)) me))))
  (define (process-forget-value)
    (forget-value! product me)
    (forget-value! m1 me)
    (forget-value! m2 me)
    (process-new-value))
  (define (me request)
    (cond ((eq? request 'I-have-a-value) (process-new-value))
          ((eq? request 'I-lost-my-value) (process-forget-value))
          (else (error "Unknown request -- MULTIPLIER" request))))
  (connect m1 me)
  (connect m2 me)
  (connect product me)
  me)

(define (constant value connector)
  (define (me request)
    (error "Unknown request -- CONSTANT" request))
  (connect connector me)
  (set-value! connector value me)
  me)

;; ---- probe: collects (name value) / (name ?) records, newest first ----
(define probe-log '())
(define (probe name connector)
  (define (process-new-value)
    (set! probe-log (cons (list name (get-value connector)) probe-log)))
  (define (process-forget-value)
    (set! probe-log (cons (list name '?) probe-log)))
  (define (me request)
    (cond ((eq? request 'I-have-a-value) (process-new-value))
          ((eq? request 'I-lost-my-value) (process-forget-value))
          (else (error "Unknown request -- PROBE" request))))
  (connect connector me)
  me)

;; ================= adder alone: full three-way propagation =================
(define aa (make-connector))
(define ab (make-connector))
(define ac (make-connector))
(adder aa ab ac)
(check "adder-initially-unset" #f (has-value? ac))
(set-value! aa 3 'user)
(set-value! ab 4 'user)
(check "adder-forward 3+4" #t (has-value? ac))
(check-num "adder-forward-value" 7 (get-value ac))
(forget-value! ab 'user)
(check "adder-forget-clears-sum" #f (has-value? ac))
(check "adder-forget-keeps-a1" #t (has-value? aa))
(set-value! ac 10 'user)
(check-num "adder-backward b=sum-a" 7 (get-value ab))
(forget-value! aa 'user)
(check "adder-forget-a1-clears-b" #f (has-value? ab))
(check "adder-sum-still-set (user informant)" #t (has-value? ac))

;; ================= multiplier alone, incl. 0 short-circuit =================
(define m1 (make-connector))
(define m2 (make-connector))
(define mp (make-connector))
(multiplier m1 m2 mp)
(set-value! m1 0 'user)
(check "mult-zero-shortcircuit (m2 unknown)" #t (has-value? mp))
(check-num "mult-zero-product" 0 (get-value mp))
(forget-value! m1 'user)
(check "mult-forget-zero" #f (has-value? mp))
(set-value! mp 12 'user)
(set-value! m1 3 'user)
(check-num "mult-backward m2=p/m1" 4 (get-value m2))
(forget-value! m1 'user)
(set-value! m2 6 'user)
(check-num "mult-backward m1=p/m2" 2 (get-value m1))

;; ================= wrong retractor is ignored =================
(define wr (make-connector))
(set-value! wr 42 'alice)
(forget-value! wr 'bob)
(check "forget-wrong-retractor-ignored" #t (has-value? wr))
(check-num "forget-wrong-retractor-value-kept" 42 (get-value wr))
(forget-value! wr 'alice)
(check "forget-right-retractor" #f (has-value? wr))

;; ================= celsius-fahrenheit-converter, both directions ==========
;; 9C = 5(F - 32)
(define (celsius-fahrenheit-converter c f)
  (let ((u (make-connector))
        (v (make-connector))
        (w (make-connector))
        (x (make-connector))
        (y (make-connector)))
    (multiplier c w u)
    (multiplier v x u)
    (adder v y f)
    (constant 9 w)
    (constant 5 x)
    (constant 32 y))
  'ok)

(define C (make-connector))
(define F (make-connector))
(celsius-fahrenheit-converter C F)
(probe 'celsius C)
(probe 'fahrenheit F)

;; direction 1: C = 25 -> F = 77
(set-value! C 25 'user)
(check "cf-C-set" #t (has-value? C))
(check "cf-F-derived" #t (has-value? F))
(check-num "cf-C-value" 25 (get-value C))
(check-num "cf-F=77" 77 (get-value F))
;; probe saw both events (F first is not guaranteed by spec order, so inspect)
(check "cf-probe-count-after-set" 2 (length probe-log))
(check "cf-probe-celsius-name" 'celsius (car (car (cdr probe-log))))
(check-num "cf-probe-celsius-value" 25 (car (cdr (car (cdr probe-log)))))
(check "cf-probe-fahrenheit-name" 'fahrenheit (car (car probe-log)))
(check-num "cf-probe-fahrenheit-value" 77 (car (cdr (car probe-log))))

;; setting the SAME value again is ignored (no contradiction, no new probe)
(set-value! C 25 'user2)
(check "cf-same-value-ignored" 2 (length probe-log))

;; forget: both values retract
(forget-value! C 'user)
(check "cf-forget-C" #f (has-value? C))
(check "cf-forget-F-retracted" #f (has-value? F))
(check "cf-probe-count-after-forget" 4 (length probe-log))
(check "cf-probe-forget-record" '(fahrenheit ?) (car probe-log))
(check "cf-probe-forget-record-2" '(celsius ?) (car (cdr probe-log)))

;; direction 2: F = 212 -> C = 100
(set-value! F 212 'user)
(check "fc-F-set" #t (has-value? F))
(check "fc-C-derived" #t (has-value? C))
(check-num "fc-F-value" 212 (get-value F))
(check-num "fc-C=100" 100 (get-value C))
(check "fc-probe-count" 6 (length probe-log))

;; and back again: forget F, re-derive from C = -40 (the fixed point)
(forget-value! F 'user)
(check "fc-forget-F" #f (has-value? C))
(set-value! C -40 'user)
(check-num "cf-minus40" -40 (get-value F))

(newline)
(if (= fails 0)
    (begin (display "ALL-PASS ch3_constraints") (newline))
    (begin (display "HAS-FAIL ch3_constraints ") (display fails) (newline)))
