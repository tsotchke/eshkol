;; SICP Chapter 2.5.3 - Polynomial arithmetic and symbolic algebra.
;; Polynomials are tagged by their variable and carry sparse, descending
;; term lists.  Terms are (order coeff), matching the SICP representation.

(define fails 0)
(define (check name ok)
  (if ok (begin (display "PASS: ") (display name) (newline))
      (begin (set! fails (+ fails 1)) (display "FAIL: ") (display name) (newline))))

;; ---- term-list representation ----
(define (the-empty-termlist) '())
(define (empty-termlist? term-list) (null? term-list))
(define (make-term order coeff) (list order coeff))
(define (order term) (car term))
(define (coeff term) (cadr term))
(define (first-term term-list) (car term-list))
(define (rest-terms term-list) (cdr term-list))
(define (=zero? x) (= x 0))
(define (adjoin-term term term-list)
  (if (=zero? (coeff term))
      term-list
      (cons term term-list)))

;; ---- polynomial representation ----
(define (make-poly variable term-list) (cons variable term-list))
(define (variable poly) (car poly))
(define (term-list poly) (cdr poly))
(define (variable? x) (symbol? x))
(define (same-variable? v1 v2) (and (variable? v1) (variable? v2) (eq? v1 v2)))
(define (same-poly-variable? p1 p2) (same-variable? (variable p1) (variable p2)))

;; ---- term-list arithmetic ----
(define (add-terms l1 l2)
  (cond ((empty-termlist? l1) l2)
        ((empty-termlist? l2) l1)
        (else
         (let ((t1 (first-term l1))
               (t2 (first-term l2)))
           (cond ((> (order t1) (order t2))
                  (adjoin-term t1 (add-terms (rest-terms l1) l2)))
                 ((< (order t1) (order t2))
                  (adjoin-term t2 (add-terms l1 (rest-terms l2))))
                 (else
                  (adjoin-term
                   (make-term (order t1) (+ (coeff t1) (coeff t2)))
                   (add-terms (rest-terms l1) (rest-terms l2)))))))))

(define (mul-term-by-all-terms t term-list)
  (if (empty-termlist? term-list)
      (the-empty-termlist)
      (let ((t2 (first-term term-list)))
        (adjoin-term
         (make-term (+ (order t) (order t2)) (* (coeff t) (coeff t2)))
         (mul-term-by-all-terms t (rest-terms term-list))))))

(define (mul-terms l1 l2)
  (if (empty-termlist? l1)
      (the-empty-termlist)
      (add-terms (mul-term-by-all-terms (first-term l1) l2)
                 (mul-terms (rest-terms l1) l2))))

;; Standard SICP operations for same-variable polynomials.
(define (add-poly p1 p2)
  (if (same-poly-variable? p1 p2)
      (make-poly (variable p1) (add-terms (term-list p1) (term-list p2)))
      (error "Polys not in same var -- ADD-POLY" (list p1 p2))))

(define (mul-poly p1 p2)
  (if (same-poly-variable? p1 p2)
      (make-poly (variable p1) (mul-terms (term-list p1) (term-list p2)))
      (error "Polys not in same var -- MUL-POLY" (list p1 p2))))

;; Test helper for the mismatch edge case.  Calling add-poly on mismatched
;; variables intentionally raises an error, so the smoke probe asserts the
;; guard separately and keeps running.
(define (poly-addable? p1 p2) (same-poly-variable? p1 p2))

(define x-plus-1
  (make-poly 'x (list (make-term 1 1) (make-term 0 1))))
(define x-plus-2
  (make-poly 'x (list (make-term 1 1) (make-term 0 2))))
(define sparse-x
  (make-poly 'x (list (make-term 4 3) (make-term 2 -2) (make-term 0 7))))
(define sparse-y
  (make-poly 'y (list (make-term 2 1) (make-term 0 4))))

;; term constructors and selectors
(check "make-term-order" (= (order (make-term 5 13)) 5))
(check "make-term-coeff" (= (coeff (make-term 5 13)) 13))
(check "empty-termlist" (empty-termlist? (the-empty-termlist)))

;; adjoin-term suppresses zero coefficients but keeps nonzero terms.
(check "adjoin-term-zero-suppressed"
       (equal? (adjoin-term (make-term 3 0)
                            (list (make-term 1 4) (make-term 0 1)))
               '((1 4) (0 1))))
(check "adjoin-term-nonzero"
       (equal? (adjoin-term (make-term 3 9)
                            (list (make-term 1 4) (make-term 0 1)))
               '((3 9) (1 4) (0 1))))

;; add-terms preserves descending order and drops exact cancellations.
(check "add-terms-sparse"
       (equal? (add-terms '((4 3) (2 -2) (0 7))
                          '((3 5) (2 2) (0 -1)))
               '((4 3) (3 5) (0 6))))
(check "add-terms-cancellation-edge"
       (equal? (add-terms '((2 3) (0 1))
                          '((2 -3) (0 -1)))
               '()))

;; polynomial constructors, variables, and same-variable checks.
(check "make-poly-variable" (eq? (variable sparse-x) 'x))
(check "make-poly-term-list" (equal? (term-list x-plus-1) '((1 1) (0 1))))
(check "same-variable-true" (same-variable? 'x 'x))
(check "same-variable-false" (not (same-variable? 'x 'y)))
(check "same-variable-nonsymbol" (not (same-variable? 'x 3)))
(check "poly-addable-mismatch-edge" (not (poly-addable? sparse-x sparse-y)))

;; add-polynomial examples from the symbolic algebra package.
(check "add-poly-same-variable"
       (equal? (add-poly (make-poly 'x '((3 2) (1 4) (0 1)))
                         (make-poly 'x '((2 5) (1 -4) (0 6))))
               '(x (3 2) (2 5) (0 7))))
(check "add-poly-zero-result-edge"
       (equal? (add-poly (make-poly 'x '((1 5) (0 -5)))
                         (make-poly 'x '((1 -5) (0 5))))
               '(x)))

;; multiplication covers coefficient multiplication and like-order collection:
;; (x + 1)(x + 2) = x^2 + 3x + 2.
(check "mul-poly-linear"
       (equal? (mul-poly x-plus-1 x-plus-2)
               '(x (2 1) (1 3) (0 2))))
(check "mul-terms-coefficients"
       (equal? (mul-terms '((2 -3) (0 2))
                          '((1 4) (0 -5)))
               '((3 -12) (2 15) (1 8) (0 -10))))
(check "mul-poly-by-zero-edge"
       (equal? (mul-poly sparse-x (make-poly 'x (the-empty-termlist)))
               '(x)))

(newline)
(if (= fails 0)
    (begin (display "ALL-PASS ch2_polynomial_arithmetic") (newline))
    (begin (display "HAS-FAIL ch2_polynomial_arithmetic ") (display fails) (newline)))
