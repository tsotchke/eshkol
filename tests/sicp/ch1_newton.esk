;; SICP Chapter 1.3 — higher-order procedures: fixed points, average damping,
;; Newton's method, sqrt/cube-root, continued fractions, repeated application.
(define fails 0)
(define (check name expected actual)
  (if (< (abs (- expected actual)) 0.0001)
      (begin (display "PASS: ") (display name) (newline))
      (begin (set! fails (+ fails 1))
             (display "FAIL: ") (display name) (display " expected=") (display expected)
             (display " actual=") (display actual) (newline))))

;; fixed-point of f starting at guess
(define tolerance 0.00001)
(define (fixed-point f first-guess)
  (define (close-enough? a b) (< (abs (- a b)) tolerance))
  (define (try guess)
    (let ((next (f guess)))
      (if (close-enough? guess next) next (try next))))
  (try first-guess))

(check "fixed-point cos" 0.739085 (fixed-point (lambda (x) (cos x)) 1.0))

;; average damping
(define (average-damp f) (lambda (x) (/ (+ x (f x)) 2.0)))
(define (sqrt-fp x) (fixed-point (average-damp (lambda (y) (/ x y))) 1.0))
(check "sqrt via fixed-point+damp" 3.0 (sqrt-fp 9.0))

;; Newton's method
(define dx 0.00001)
(define (deriv g) (lambda (x) (/ (- (g (+ x dx)) (g x)) dx)))
(define (newton-transform g) (lambda (x) (- x (/ (g x) ((deriv g) x)))))
(define (newtons-method g guess) (fixed-point (newton-transform g) guess))
(define (sqrt-newton x) (newtons-method (lambda (y) (- (* y y) x)) 1.0))
(check "sqrt via Newton" 4.0 (sqrt-newton 16.0))

;; cube root via fixed point
(define (cube-root x)
  (fixed-point (average-damp (lambda (y) (/ x (* y y)))) 1.0))
(check "cube-root 27" 3.0 (cube-root 27.0))

;; continued fraction -> 1/phi  (all Ni=Di=1)
(define (cont-frac n d k)
  (define (recur i)
    (if (> i k) 0.0
        (/ (n i) (+ (d i) (recur (+ i 1))))))
  (recur 1))
(check "cont-frac 1/phi" 0.6180 (cont-frac (lambda (i) 1.0) (lambda (i) 1.0) 20))

;; e - 2 via Euler continued fraction (Di = 1,2,1,1,4,1,1,6,...)
(define (euler-d i)
  (if (= (remainder (+ i 1) 3) 0)
      (* 2.0 (/ (+ i 1) 3))
      1.0))
(check "e-2 cont-frac" 0.71828 (cont-frac (lambda (i) 1.0) euler-d 20))

;; repeated application of a function n times
(define (compose f g) (lambda (x) (f (g x))))
(define (repeated f n)
  (if (= n 1) f (compose f (repeated f (- n 1)))))
(check "repeated square twice" 625.0 ((repeated (lambda (x) (* x x)) 2) 5.0))

(display "ch1 newton: ") (display (if (= fails 0) "ALL PASS" (cons fails 'FAILS))) (newline)
