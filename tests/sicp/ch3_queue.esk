;; SICP Chapter 3.3.2 — mutable queue built on set-car!/set-cdr! with
;; front/rear pointers, plus a small agenda-style ordered insert.
(define fails 0)
(define (check name expected actual)
  (if (equal? expected actual)
      (begin (display "PASS: ") (display name) (newline))
      (begin (set! fails (+ fails 1))
             (display "FAIL: ") (display name) (display " expected=") (display expected)
             (display " actual=") (display actual) (newline))))

;; ---- queue as (front-ptr . rear-ptr) ----
(define (make-queue) (cons '() '()))
(define (front-ptr q) (car q))
(define (rear-ptr q) (cdr q))
(define (set-front-ptr! q item) (set-car! q item))
(define (set-rear-ptr! q item) (set-cdr! q item))
(define (empty-queue? q) (null? (front-ptr q)))
(define (front-queue q)
  (if (empty-queue? q) (error "front of empty queue") (car (front-ptr q))))
(define (insert-queue! q item)
  (let ((new (cons item '())))
    (cond ((empty-queue? q)
           (set-front-ptr! q new) (set-rear-ptr! q new))
          (else
           (set-cdr! (rear-ptr q) new) (set-rear-ptr! q new)))
    q))
(define (delete-queue! q)
  (cond ((empty-queue? q) (error "delete of empty queue"))
        (else (set-front-ptr! q (cdr (front-ptr q)))
              (if (null? (front-ptr q)) (set-rear-ptr! q '()))
              q)))
(define (queue->list q) (front-ptr q))

(define q (make-queue))
(check "empty?" #t (empty-queue? q))
(insert-queue! q 'a)
(insert-queue! q 'b)
(insert-queue! q 'c)
(check "front-after-3" 'a (front-queue q))
(check "contents" '(a b c) (queue->list q))
(delete-queue! q)
(check "front-after-del" 'b (front-queue q))
(check "contents-after-del" '(b c) (queue->list q))
(insert-queue! q 'd)
(check "fifo-order" '(b c d) (queue->list q))
(delete-queue! q)
(delete-queue! q)
(delete-queue! q)
(check "empty-again" #t (empty-queue? q))
(insert-queue! q 'z)            ; reuse after empty
(check "reuse-after-empty" 'z (front-queue q))

(display "ch3 queue: ") (display (if (= fails 0) "ALL PASS" (cons fails 'FAILS))) (newline)
