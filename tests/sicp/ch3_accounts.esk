;; SICP Chapter 3.1 — Local state via closures + set!.
;; make-withdraw, make-account, make-accumulator, make-monitored.
;;
;; This file is written in the NATURAL SICP style (mutated state is a lambda
;; PARAMETER). It deliberately surfaces a real Eshkol bug: a set!-mutated
;; *parameter* captured by MULTIPLE sibling closures is not shared — each
;; closure captures a private copy (see make-account / SICP 3.1.1). Single-closure
;; cases (make-withdraw, make-accumulator) work. See the gap report.

(define fails 0)
;; throw-safe check: compares with equal? so a wrong-typed result records a FAIL
;; instead of aborting the file.
(define (check name expected actual)
  (if (equal? expected actual)
      (begin (display "PASS: ") (display name) (newline))
      (begin (set! fails (+ fails 1))
             (display "FAIL: ") (display name)
             (display " expected=") (display expected)
             (display " actual=") (display actual) (newline))))

;; ---- 3.1.1 make-withdraw (single closure — works) ----
(define (make-withdraw balance)
  (lambda (amount)
    (if (>= balance amount)
        (begin (set! balance (- balance amount)) balance)
        'insufficient-funds)))
(define W1 (make-withdraw 100))
(define W2 (make-withdraw 100))
(check "withdraw-50" 50 (W1 50))
(check "withdraw-again-30" 20 (W1 30))
(check "withdraw-insufficient" 'insufficient-funds (W1 60))
(check "withdraw-independent-state" 30 (W2 70))

;; ---- 3.1.1 make-account (message-passing, TWO sibling closures share balance) ----
(define (make-account balance)
  (define (withdraw amount)
    (if (>= balance amount) (begin (set! balance (- balance amount)) balance)
        'insufficient))
  (define (deposit amount) (set! balance (+ balance amount)) balance)
  (define (dispatch m)
    (cond ((eq? m 'withdraw) withdraw)
          ((eq? m 'deposit) deposit)
          (else (error "Unknown request -- MAKE-ACCOUNT" m))))
  dispatch)
(define acc (make-account 100))
(check "account-withdraw" 50 ((acc 'withdraw) 50))   ; 100 - 50
(check "account-deposit"  90 ((acc 'deposit) 40))    ; 50 + 40  (BUG: deposit's copy is 100 -> 140)
(check "account-withdraw2" 30 ((acc 'withdraw) 60))  ; 90 - 60

;; ---- 3.1.2 make-accumulator (single closure — works) ----
(define (make-accumulator sum)
  (lambda (amount) (set! sum (+ sum amount)) sum))
(define A (make-accumulator 5))
(check "accumulator-1" 15 (A 10))
(check "accumulator-2" 25 (A 10))

;; ---- 3.1.2 make-monitored (single closure over internal `count` — works) ----
(define (make-monitored f)
  (let ((count 0))
    (lambda (arg)
      (cond ((eq? arg 'how-many-calls?) count)
            ((eq? arg 'reset-count) (set! count 0) count)
            (else (set! count (+ count 1)) (f arg))))))
(define s (make-monitored (lambda (x) (* x x))))
(check "monitored-call" 25 (s 5))
(s 6)
(check "monitored-count" 2 (s 'how-many-calls?))
(s 'reset-count)
(check "monitored-reset" 0 (s 'how-many-calls?))

(newline)
(if (= fails 0)
    (begin (display "ALL-PASS ch3_accounts") (newline))
    (begin (display "HAS-FAIL ch3_accounts ") (display fails) (newline)))
