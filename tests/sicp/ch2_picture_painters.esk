;; SICP Chapter 2.2.4 -- Picture-language painters and combinators.
;;
;; The textbook renderer ultimately calls a primitive `draw-line`.  This probe
;; keeps the full closure/combinator semantics testable in a headless gate by
;; representing a painter as a procedure from a frame to the list of transformed
;; line segments it would draw.

(define fails 0)
(define (check name ok)
  (if ok (begin (display "PASS: ") (display name) (newline))
      (begin (set! fails (+ fails 1)) (display "FAIL: ") (display name) (newline))))
(define (close? a b) (< (abs (- a b)) 1e-9))

;; ---- vectors, frames, and segments (exercises 2.46-2.48) ----
(define (make-vect x y) (cons x y))
(define (xcor-vect v) (car v))
(define (ycor-vect v) (cdr v))
(define (add-vect a b)
  (make-vect (+ (xcor-vect a) (xcor-vect b))
             (+ (ycor-vect a) (ycor-vect b))))
(define (sub-vect a b)
  (make-vect (- (xcor-vect a) (xcor-vect b))
             (- (ycor-vect a) (ycor-vect b))))
(define (scale-vect s v)
  (make-vect (* s (xcor-vect v)) (* s (ycor-vect v))))

(define (make-frame origin edge1 edge2) (list origin edge1 edge2))
(define (origin-frame f) (car f))
(define (edge1-frame f) (cadr f))
(define (edge2-frame f) (caddr f))
(define (frame-coord-map frame)
  (lambda (v)
    (add-vect (origin-frame frame)
              (add-vect (scale-vect (xcor-vect v) (edge1-frame frame))
                        (scale-vect (ycor-vect v) (edge2-frame frame))))))

(define (make-segment s e) (cons s e))
(define (start-segment s) (car s))
(define (end-segment s) (cdr s))

(define unit-frame
  (make-frame (make-vect 0.0 0.0) (make-vect 1.0 0.0) (make-vect 0.0 1.0)))
(define shifted-frame
  (make-frame (make-vect 1.0 1.0) (make-vect 2.0 0.0) (make-vect 0.0 3.0)))

;; ---- painters as segment-producing closures ----
(define (map-segments coord-map segs)
  (if (null? segs) '()
      (cons (make-segment (coord-map (start-segment (car segs)))
                          (coord-map (end-segment (car segs))))
            (map-segments coord-map (cdr segs)))))

(define (segments->painter segment-list)
  (lambda (frame)
    (map-segments (frame-coord-map frame) segment-list)))

(define (transform-painter painter origin corner1 corner2)
  (lambda (frame)
    (let ((m (frame-coord-map frame)))
      (let ((new-origin (m origin)))
        (painter
         (make-frame new-origin
                     (sub-vect (m corner1) new-origin)
                     (sub-vect (m corner2) new-origin)))))))

(define (flip-vert painter)
  (transform-painter painter
                     (make-vect 0.0 1.0)
                     (make-vect 1.0 1.0)
                     (make-vect 0.0 0.0)))
(define (flip-horiz painter)
  (transform-painter painter
                     (make-vect 1.0 0.0)
                     (make-vect 0.0 0.0)
                     (make-vect 1.0 1.0)))
(define (rotate90 painter)
  (transform-painter painter
                     (make-vect 1.0 0.0)
                     (make-vect 1.0 1.0)
                     (make-vect 0.0 0.0)))
(define (rotate180 painter)
  (transform-painter painter
                     (make-vect 1.0 1.0)
                     (make-vect 0.0 1.0)
                     (make-vect 1.0 0.0)))
(define (rotate270 painter)
  (transform-painter painter
                     (make-vect 0.0 1.0)
                     (make-vect 0.0 0.0)
                     (make-vect 1.0 1.0)))

(define (beside painter1 painter2)
  (let ((split-point (make-vect 0.5 0.0)))
    (let ((paint-left
           (transform-painter painter1
                              (make-vect 0.0 0.0)
                              split-point
                              (make-vect 0.0 1.0)))
          (paint-right
           (transform-painter painter2
                              split-point
                              (make-vect 1.0 0.0)
                              (make-vect 0.5 1.0))))
      (lambda (frame)
        (append (paint-left frame) (paint-right frame))))))

(define (below painter1 painter2)
  (let ((split-point (make-vect 0.0 0.5)))
    (let ((paint-bottom
           (transform-painter painter1
                              (make-vect 0.0 0.0)
                              (make-vect 1.0 0.0)
                              split-point))
          (paint-top
           (transform-painter painter2
                              split-point
                              (make-vect 1.0 0.5)
                              (make-vect 0.0 1.0))))
      (lambda (frame)
        (append (paint-bottom frame) (paint-top frame))))))

;; ---- recursive painter combinators ----
(define (right-split painter n)
  (if (= n 0) painter
      (let ((smaller (right-split painter (- n 1))))
        (beside painter (below smaller smaller)))))

(define (up-split painter n)
  (if (= n 0) painter
      (let ((smaller (up-split painter (- n 1))))
        (below painter (beside smaller smaller)))))

(define (corner-split painter n)
  (if (= n 0) painter
      (let ((up (up-split painter (- n 1)))
            (right (right-split painter (- n 1))))
        (let ((top-left (beside up up))
              (bottom-right (below right right))
              (corner (corner-split painter (- n 1))))
          (beside (below painter top-left)
                  (below bottom-right corner))))))

(define (identity-painter painter) painter)
(define (square-of-four top-left top-right bottom-left bottom-right)
  (lambda (painter)
    (let ((top (beside (top-left painter) (top-right painter)))
          (bottom (beside (bottom-left painter) (bottom-right painter))))
      (below bottom top))))

(define (square-limit painter n)
  ((square-of-four flip-horiz identity-painter rotate180 flip-vert)
   (corner-split painter n)))

;; ---- assertions over the segment model ----
(define (nth xs n)
  (if (= n 0) (car xs) (nth (cdr xs) (- n 1))))
(define (vect-close? v x y)
  (and (close? (xcor-vect v) x) (close? (ycor-vect v) y)))
(define (segment-close? segment sx sy ex ey)
  (and (vect-close? (start-segment segment) sx sy)
       (vect-close? (end-segment segment) ex ey)))
(define (segment-count painter) (length (painter unit-frame)))
(define (in-unit? x) (and (< -0.000000001 x) (< x 1.000000001)))
(define (vect-in-unit-square? v) (and (in-unit? (xcor-vect v)) (in-unit? (ycor-vect v))))
(define (all-segments-in-unit-square? segs)
  (if (null? segs) #t
      (and (vect-in-unit-square? (start-segment (car segs)))
           (vect-in-unit-square? (end-segment (car segs)))
           (all-segments-in-unit-square? (cdr segs)))))

(define diagonal-painter
  (segments->painter
   (list (make-segment (make-vect 0.0 0.0) (make-vect 1.0 1.0)))))
(define tick-painter
  (segments->painter
   (list (make-segment (make-vect 0.25 0.0) (make-vect 0.5 0.75)))))
(define outline-painter
  (segments->painter
   (list (make-segment (make-vect 0.0 0.0) (make-vect 1.0 0.0))
         (make-segment (make-vect 1.0 0.0) (make-vect 1.0 1.0))
         (make-segment (make-vect 1.0 1.0) (make-vect 0.0 1.0))
         (make-segment (make-vect 0.0 1.0) (make-vect 0.0 0.0)))))

(let ((segs (diagonal-painter shifted-frame)))
  (check "segments->painter maps through arbitrary frame"
         (and (= (length segs) 1)
              (segment-close? (car segs) 1.0 1.0 3.0 4.0))))

(let ((segs ((flip-vert tick-painter) unit-frame)))
  (check "flip-vert reflects y coordinates"
         (segment-close? (car segs) 0.25 1.0 0.5 0.25)))
(let ((segs ((flip-horiz tick-painter) unit-frame)))
  (check "flip-horiz reflects x coordinates"
         (segment-close? (car segs) 0.75 0.0 0.5 0.75)))
(let ((segs ((rotate90 tick-painter) unit-frame)))
  (check "rotate90 turns painter counterclockwise"
         (segment-close? (car segs) 1.0 0.25 0.25 0.5)))
(let ((segs ((rotate180 tick-painter) unit-frame)))
  (check "rotate180 reverses both axes"
         (segment-close? (car segs) 0.75 1.0 0.5 0.25)))
(let ((segs ((rotate270 tick-painter) unit-frame)))
  (check "rotate270 turns painter clockwise"
         (segment-close? (car segs) 0.0 0.75 0.75 0.5)))

(let ((segs ((beside diagonal-painter diagonal-painter) unit-frame)))
  (check "beside preserves order and splits x axis"
         (and (= (length segs) 2)
              (segment-close? (nth segs 0) 0.0 0.0 0.5 1.0)
              (segment-close? (nth segs 1) 0.5 0.0 1.0 1.0))))
(let ((segs ((below diagonal-painter diagonal-painter) unit-frame)))
  (check "below preserves order and splits y axis"
         (and (= (length segs) 2)
              (segment-close? (nth segs 0) 0.0 0.0 1.0 0.5)
              (segment-close? (nth segs 1) 0.0 0.5 1.0 1.0))))
(check "outline painter keeps four border segments" (= (segment-count outline-painter) 4))

(check "right-split grows 1,3,7 segments" (= (segment-count (right-split diagonal-painter 2)) 7))
(check "up-split grows 1,3,7 segments" (= (segment-count (up-split diagonal-painter 2)) 7))
(check "corner-split n=1 has six segments" (= (segment-count (corner-split diagonal-painter 1)) 6))
(check "square-limit n=1 composes four transformed corners"
       (= (segment-count (square-limit diagonal-painter 1)) 24))
(check "square-limit keeps all segments inside the frame"
       (all-segments-in-unit-square? ((square-limit tick-painter 1) unit-frame)))

(newline)
(if (= fails 0)
    (begin (display "ALL-PASS ch2_picture_painters") (newline))
    (begin (display "HAS-FAIL ch2_picture_painters ") (display fails) (newline)))
