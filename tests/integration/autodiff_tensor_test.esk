;; Autodiff + Tensor Integration Test Suite
;; Tests AD (automatic differentiation) combined with tensor operations.
;; Uses reverse-mode gradient to verify correctness of gradients for
;; various tensor-based scalar functions.

(require stdlib)

(display "TEST: Autodiff + tensor integration") (newline)

;; Helper: approximate equality within tolerance
(define (approx= a b tol)
  (< (abs (- a b)) tol))

;; Helper: returns length of a tensor/vector
(define (tensor-length t)
  (vector-length t))

;; ============================================================
;; Test 1: Gradient of tensor-sum
;; f(x) = sum(x), gradient = [1, 1, 1]
;; ============================================================
(let* ((g (gradient (lambda (x) (tensor-sum x)) #(1.0 2.0 3.0))))
  (display
    (if (and (approx= (vector-ref g 0) 1.0 1e-6)
             (approx= (vector-ref g 1) 1.0 1e-6)
             (approx= (vector-ref g 2) 1.0 1e-6))
        "PASS" "FAIL"))
  (display ": gradient of tensor-sum = all ones") (newline))

;; ============================================================
;; Test 2: Gradient of tensor-dot with constant vector
;; f(x) = dot(x, c) where c = [4.0 5.0 6.0]
;; gradient = c = [4.0, 5.0, 6.0]
;; ============================================================
(let* ((c #(4.0 5.0 6.0))
       (g (gradient (lambda (x) (tensor-dot x c)) #(1.0 2.0 3.0))))
  (display
    (if (and (approx= (vector-ref g 0) 4.0 1e-6)
             (approx= (vector-ref g 1) 5.0 1e-6)
             (approx= (vector-ref g 2) 6.0 1e-6))
        "PASS" "FAIL"))
  (display ": gradient of tensor-dot with constant = constant vector") (newline))

;; ============================================================
;; Test 3: Gradient of scaled sum
;; f(x) = 2 * sum(x), gradient = [2, 2, 2]
;; ============================================================
(let* ((g (gradient (lambda (x) (* 2.0 (tensor-sum x))) #(1.0 2.0 3.0))))
  (display
    (if (and (approx= (vector-ref g 0) 2.0 1e-6)
             (approx= (vector-ref g 1) 2.0 1e-6)
             (approx= (vector-ref g 2) 2.0 1e-6))
        "PASS" "FAIL"))
  (display ": gradient of scaled tensor-sum = scaled ones") (newline))

;; ============================================================
;; Test 4: Gradient of element access x[0]
;; f(x) = x[0], gradient = [1, 0, 0]
;; ============================================================
(let* ((g (gradient (lambda (x) (vector-ref x 0)) #(1.0 2.0 3.0))))
  (display
    (if (and (approx= (vector-ref g 0) 1.0 1e-6)
             (approx= (vector-ref g 1) 0.0 1e-6)
             (approx= (vector-ref g 2) 0.0 1e-6))
        "PASS" "FAIL"))
  (display ": gradient of x[0] = unit basis vector e0") (newline))

;; ============================================================
;; Test 5: Gradient of element access x[1]
;; f(x) = x[1], gradient = [0, 1, 0]
;; ============================================================
(let* ((g (gradient (lambda (x) (vector-ref x 1)) #(1.0 2.0 3.0))))
  (display
    (if (and (approx= (vector-ref g 0) 0.0 1e-6)
             (approx= (vector-ref g 1) 1.0 1e-6)
             (approx= (vector-ref g 2) 0.0 1e-6))
        "PASS" "FAIL"))
  (display ": gradient of x[1] = unit basis vector e1") (newline))

;; ============================================================
;; Test 6: Sum of squares gradient
;; f(x) = sum(x * x) = x[0]^2 + x[1]^2 + x[2]^2
;; gradient = 2 * x = [2.0, 4.0, 6.0] at x=[1, 2, 3]
;; ============================================================
(let* ((g (gradient
            (lambda (x)
              (+ (* (vector-ref x 0) (vector-ref x 0))
                 (* (vector-ref x 1) (vector-ref x 1))
                 (* (vector-ref x 2) (vector-ref x 2))))
            #(1.0 2.0 3.0))))
  (display
    (if (and (approx= (vector-ref g 0) 2.0 1e-6)
             (approx= (vector-ref g 1) 4.0 1e-6)
             (approx= (vector-ref g 2) 6.0 1e-6))
        "PASS" "FAIL"))
  (display ": gradient of sum-of-squares = 2*x") (newline))

;; ============================================================
;; Test 7: Gradient of tensor-dot self (x dot x)
;; f(x) = dot(x, x) = sum(x^2), gradient = 2*x
;; At x=[1, 2, 3]: gradient = [2, 4, 6]
;; ============================================================
(let* ((g (gradient (lambda (x) (tensor-dot x x)) #(1.0 2.0 3.0))))
  (display
    (if (and (approx= (vector-ref g 0) 2.0 1e-6)
             (approx= (vector-ref g 1) 4.0 1e-6)
             (approx= (vector-ref g 2) 6.0 1e-6))
        "PASS" "FAIL"))
  (display ": gradient of tensor-dot self = 2*x") (newline))

;; ============================================================
;; Test 8: Gradient shape matches input shape
;; gradient of any scalar function f:R^3->R should be a 3-vector
;; ============================================================
(let* ((input #(1.0 2.0 3.0))
       (g (gradient (lambda (x) (tensor-sum x)) input)))
  (display
    (if (= (tensor-length g) (tensor-length input))
        "PASS" "FAIL"))
  (display ": gradient shape matches input tensor shape") (newline))

;; ============================================================
;; Test 9: Gradient of constant function = zeros
;; f(x) = 42.0 (ignores x), gradient = [0, 0, 0]
;; ============================================================
(let* ((g (gradient (lambda (x) 42.0) #(1.0 2.0 3.0))))
  (display
    (if (and (approx= (vector-ref g 0) 0.0 1e-6)
             (approx= (vector-ref g 1) 0.0 1e-6)
             (approx= (vector-ref g 2) 0.0 1e-6))
        "PASS" "FAIL"))
  (display ": gradient of constant function = zero vector") (newline))

;; ============================================================
;; Test 10: Gradient at zero tensor
;; f(x) = sum(x^2) at x=[0, 0, 0], gradient = 2*x = [0, 0, 0]
;; ============================================================
(let* ((g (gradient
            (lambda (x)
              (+ (* (vector-ref x 0) (vector-ref x 0))
                 (* (vector-ref x 1) (vector-ref x 1))
                 (* (vector-ref x 2) (vector-ref x 2))))
            #(0.0 0.0 0.0))))
  (display
    (if (and (approx= (vector-ref g 0) 0.0 1e-6)
             (approx= (vector-ref g 1) 0.0 1e-6)
             (approx= (vector-ref g 2) 0.0 1e-6))
        "PASS" "FAIL"))
  (display ": gradient of sum-of-squares at zero = zero vector") (newline))

;; ============================================================
;; Test 11: Single-element tensor gradient
;; f(x) = x[0]^2 at x=[5.0], gradient = [10.0]
;; ============================================================
(let* ((g (gradient
            (lambda (x) (* (vector-ref x 0) (vector-ref x 0)))
            #(5.0))))
  (display
    (if (approx= (vector-ref g 0) 10.0 1e-6)
        "PASS" "FAIL"))
  (display ": gradient of single-element x^2 at x=5 = 10") (newline))

;; ============================================================
;; Test 12: Simple neural network forward pass gradient w.r.t. weights
;; output = w[0]*x0 + w[1]*x1 + bias, inputs x=[2.0, 3.0], bias=1.0
;; d(output)/d(w) = [x0, x1] = [2.0, 3.0]
;; ============================================================
(let* ((inputs #(2.0 3.0))
       (bias 1.0)
       (g (gradient
            (lambda (w)
              (+ (* (vector-ref w 0) (vector-ref inputs 0))
                 (* (vector-ref w 1) (vector-ref inputs 1))
                 bias))
            #(0.5 0.5))))
  (display
    (if (and (approx= (vector-ref g 0) 2.0 1e-6)
             (approx= (vector-ref g 1) 3.0 1e-6))
        "PASS" "FAIL"))
  (display ": neural net gradient w.r.t. weights = inputs") (newline))

;; ============================================================
;; Test 13: Gradient of weighted sum
;; f(x) = 1*x[0] + 2*x[1] + 3*x[2], gradient = [1, 2, 3]
;; ============================================================
(let* ((g (gradient
            (lambda (x)
              (+ (* 1.0 (vector-ref x 0))
                 (* 2.0 (vector-ref x 1))
                 (* 3.0 (vector-ref x 2))))
            #(0.0 0.0 0.0))))
  (display
    (if (and (approx= (vector-ref g 0) 1.0 1e-6)
             (approx= (vector-ref g 1) 2.0 1e-6)
             (approx= (vector-ref g 2) 3.0 1e-6))
        "PASS" "FAIL"))
  (display ": gradient of weighted sum = weight coefficients") (newline))

;; ============================================================
;; Test 14: Gradient of cross-product term x[0]*x[1]
;; f(x) = x[0]*x[1], gradient = [x[1], x[0], 0] = [4.0, 3.0, 0.0] at x=[3,4,5]
;; ============================================================
(let* ((g (gradient
            (lambda (x)
              (* (vector-ref x 0) (vector-ref x 1)))
            #(3.0 4.0 5.0))))
  (display
    (if (and (approx= (vector-ref g 0) 4.0 1e-6)
             (approx= (vector-ref g 1) 3.0 1e-6)
             (approx= (vector-ref g 2) 0.0 1e-6))
        "PASS" "FAIL"))
  (display ": gradient of x[0]*x[1] = [x1, x0, 0]") (newline))

;; ============================================================
;; Test 15: Gradient of cubic term x[0]^3
;; f(x) = x[0]^3, gradient w.r.t. x[0] = 3*x[0]^2 = 12.0 at x[0]=2
;; ============================================================
(let* ((g (gradient
            (lambda (x)
              (* (vector-ref x 0)
                 (* (vector-ref x 0) (vector-ref x 0))))
            #(2.0 0.0 0.0))))
  (display
    (if (and (approx= (vector-ref g 0) 12.0 1e-6)
             (approx= (vector-ref g 1) 0.0 1e-6)
             (approx= (vector-ref g 2) 0.0 1e-6))
        "PASS" "FAIL"))
  (display ": gradient of x[0]^3 = 3*x[0]^2") (newline))

;; ============================================================
;; Test 16: Gradient of sum with scalar offset
;; f(x) = sum(x) + 100.0, gradient = [1, 1, 1] (constant does not affect grad)
;; ============================================================
(let* ((g (gradient
            (lambda (x) (+ (tensor-sum x) 100.0))
            #(5.0 5.0 5.0))))
  (display
    (if (and (approx= (vector-ref g 0) 1.0 1e-6)
             (approx= (vector-ref g 1) 1.0 1e-6)
             (approx= (vector-ref g 2) 1.0 1e-6))
        "PASS" "FAIL"))
  (display ": gradient of sum+constant = all ones") (newline))

;; ============================================================
;; Test 17: Gradient is independent of evaluation point value for linear f
;; f(x) = sum(x), gradient = [1,1,1] regardless of where x lives
;; ============================================================
(let* ((g1 (gradient (lambda (x) (tensor-sum x)) #(0.0 0.0 0.0)))
       (g2 (gradient (lambda (x) (tensor-sum x)) #(100.0 200.0 300.0))))
  (display
    (if (and (approx= (vector-ref g1 0) 1.0 1e-6)
             (approx= (vector-ref g2 0) 1.0 1e-6)
             (approx= (vector-ref g1 1) 1.0 1e-6)
             (approx= (vector-ref g2 1) 1.0 1e-6))
        "PASS" "FAIL"))
  (display ": linear function gradient is point-independent") (newline))

;; ============================================================
;; Test 18: Gradient of negated sum
;; f(x) = -(sum(x)), gradient = [-1, -1, -1]
;; ============================================================
(let* ((g (gradient (lambda (x) (- (tensor-sum x))) #(1.0 2.0 3.0))))
  (display
    (if (and (approx= (vector-ref g 0) -1.0 1e-6)
             (approx= (vector-ref g 1) -1.0 1e-6)
             (approx= (vector-ref g 2) -1.0 1e-6))
        "PASS" "FAIL"))
  (display ": gradient of negated tensor-sum = all negative ones") (newline))

;; ============================================================
;; Test 19: Gradient of dot product with scaled constant
;; f(x) = dot(x, 3*c) = 3 * dot(x, c), c=[1,1,1], gradient = [3, 3, 3]
;; ============================================================
(let* ((c #(3.0 3.0 3.0))
       (g (gradient (lambda (x) (tensor-dot x c)) #(1.0 1.0 1.0))))
  (display
    (if (and (approx= (vector-ref g 0) 3.0 1e-6)
             (approx= (vector-ref g 1) 3.0 1e-6)
             (approx= (vector-ref g 2) 3.0 1e-6))
        "PASS" "FAIL"))
  (display ": gradient of dot(x, 3*ones) = [3, 3, 3]") (newline))

;; ============================================================
;; Test 20: Two-layer linear gradient
;; f(x) = w2 * (w1 dot x), where w1=[1,0,0], w2=5.0
;; gradient = w2 * w1 = [5, 0, 0]
;; ============================================================
(let* ((w1 #(1.0 0.0 0.0))
       (w2 5.0)
       (g (gradient
            (lambda (x) (* w2 (tensor-dot w1 x)))
            #(2.0 3.0 4.0))))
  (display
    (if (and (approx= (vector-ref g 0) 5.0 1e-6)
             (approx= (vector-ref g 1) 0.0 1e-6)
             (approx= (vector-ref g 2) 0.0 1e-6))
        "PASS" "FAIL"))
  (display ": gradient of scaled dot product = scaled basis vector") (newline))

;; ============================================================
;; Test 21: Multi-dimensional tensor gradient flattens all elements
;; f(x) = sum(x) for x:[2,2], gradient = [1, 1, 1, 1]
;; ============================================================
(let* ((g (gradient
            (lambda (x) (tensor-sum x))
            (tensor 2 2 1.0 2.0 3.0 4.0))))
  (display
    (if (and (= (vector-length g) 4)
             (approx= (vector-ref g 0) 1.0 1e-6)
             (approx= (vector-ref g 1) 1.0 1e-6)
             (approx= (vector-ref g 2) 1.0 1e-6)
             (approx= (vector-ref g 3) 1.0 1e-6))
        "PASS" "FAIL"))
  (display ": gradient of 2x2 tensor-sum covers all elements") (newline))

;; ============================================================
;; Test 22: Gradient through matmul with a constant matrix
;; f(X) = sum(X * C), C = [[1, 2], [3, 4]]
;; gradient rows are the row-sums of C: [3, 7]
;; ============================================================
(let* ((c (tensor 2 2 1.0 2.0 3.0 4.0))
       (g (gradient
            (lambda (x) (tensor-sum (matmul x c)))
            (tensor 2 2 10.0 20.0 30.0 40.0))))
  (display
    (if (and (= (vector-length g) 4)
             (approx= (vector-ref g 0) 3.0 1e-6)
             (approx= (vector-ref g 1) 7.0 1e-6)
             (approx= (vector-ref g 2) 3.0 1e-6)
             (approx= (vector-ref g 3) 7.0 1e-6))
        "PASS" "FAIL"))
  (display ": gradient through matmul covers matrix elements") (newline))

;; ============================================================
;; Test 23: Gradient through matrix tensor-dot
;; f(X) = sum(tensor-dot(X, C)), C = [[1, 2], [3, 4]]
;; gradient rows are the row-sums of C: [3, 7]
;; ============================================================
(let* ((c (tensor 2 2 1.0 2.0 3.0 4.0))
       (g (gradient
            (lambda (x) (tensor-sum (tensor-dot x c)))
            (tensor 2 2 10.0 20.0 30.0 40.0))))
  (display
    (if (and (= (vector-length g) 4)
             (approx= (vector-ref g 0) 3.0 1e-6)
             (approx= (vector-ref g 1) 7.0 1e-6)
             (approx= (vector-ref g 2) 3.0 1e-6)
             (approx= (vector-ref g 3) 7.0 1e-6))
        "PASS" "FAIL"))
  (display ": gradient through matrix tensor-dot covers matrix elements") (newline))

;; ============================================================
;; Test 24: Gradient through matmul then tensor-sum
;; f(A) = sum(A * b), where b = [[10], [20]]
;; gradient wrt each row of A is b^T, flattened as [10, 20, 10, 20]
;; ============================================================
(let* ((b (tensor 2 1 10.0 20.0))
       (g (gradient
            (lambda (a) (tensor-sum (matmul a b)))
            (tensor 2 2 1.0 2.0 3.0 4.0))))
  (display
    (if (and (= (vector-length g) 4)
             (approx= (vector-ref g 0) 10.0 1e-6)
             (approx= (vector-ref g 1) 20.0 1e-6)
             (approx= (vector-ref g 2) 10.0 1e-6)
             (approx= (vector-ref g 3) 20.0 1e-6))
        "PASS" "FAIL"))
  (display ": gradient through matmul tensor-sum matches right operand") (newline))

;; ============================================================
;; Test 25: Gradient through 2D tensor-dot then tensor-sum
;; Same function as Test 24, but through the tensor-dot lowering path.
;; ============================================================
(let* ((b (tensor 2 1 10.0 20.0))
       (g (gradient
            (lambda (a) (tensor-sum (tensor-dot a b)))
            (tensor 2 2 1.0 2.0 3.0 4.0))))
  (display
    (if (and (= (vector-length g) 4)
             (approx= (vector-ref g 0) 10.0 1e-6)
             (approx= (vector-ref g 1) 20.0 1e-6)
             (approx= (vector-ref g 2) 10.0 1e-6)
             (approx= (vector-ref g 3) 20.0 1e-6))
        "PASS" "FAIL"))
  (display ": gradient through 2D tensor-dot tensor-sum matches right operand") (newline))

;; ============================================================
;; Test 26: Gradient through tensor-mean
;; f(x) = mean(x), gradient = [1/4, 1/4, 1/4, 1/4]
;; ============================================================
(let* ((g (gradient
            (lambda (x) (tensor-mean x))
            (tensor 4 2.0 4.0 6.0 8.0))))
  (display
    (if (and (= (vector-length g) 4)
             (approx= (vector-ref g 0) 0.25 1e-6)
             (approx= (vector-ref g 1) 0.25 1e-6)
             (approx= (vector-ref g 2) 0.25 1e-6)
             (approx= (vector-ref g 3) 0.25 1e-6))
        "PASS" "FAIL"))
  (display ": gradient through tensor-mean distributes reciprocal count") (newline))

;; ============================================================
;; Test 27: Gradient through elementwise tensor-mul then tensor-sum
;; f(x) = sum(x * c), c = [2, 3, 4], gradient = c
;; ============================================================
(let* ((c (tensor 3 2.0 3.0 4.0))
       (g (gradient
            (lambda (x) (tensor-sum (tensor-mul x c)))
            (tensor 3 1.0 2.0 3.0))))
  (display
    (if (and (= (vector-length g) 3)
             (approx= (vector-ref g 0) 2.0 1e-6)
             (approx= (vector-ref g 1) 3.0 1e-6)
             (approx= (vector-ref g 2) 4.0 1e-6))
        "PASS" "FAIL"))
  (display ": gradient through tensor-mul tensor-sum matches multiplier") (newline))

;; ============================================================
;; Test 28: Gradient through tensor-exp then tensor-sum
;; f(x) = sum(exp(x)), gradient = exp(x)
;; ============================================================
(let* ((g (gradient
            (lambda (x) (tensor-sum (tensor-exp x)))
            (tensor 2 0.0 1.0))))
  (display
    (if (and (= (vector-length g) 2)
             (approx= (vector-ref g 0) 1.0 1e-6)
             (approx= (vector-ref g 1) 2.718281828459045 1e-5))
        "PASS" "FAIL"))
  (display ": gradient through tensor-exp tensor-sum matches exp") (newline))

;; ============================================================
;; Test 29: Gradient through tensor-sqrt then tensor-sum
;; f(x) = sum(sqrt(x)), gradient = 1/(2*sqrt(x))
;; ============================================================
(let* ((g (gradient
            (lambda (x) (tensor-sum (tensor-sqrt x)))
            (tensor 2 4.0 9.0))))
  (display
    (if (and (= (vector-length g) 2)
             (approx= (vector-ref g 0) 0.25 1e-6)
             (approx= (vector-ref g 1) 0.16666666666666666 1e-5))
        "PASS" "FAIL"))
  (display ": gradient through tensor-sqrt tensor-sum matches reciprocal roots") (newline))

;; ============================================================
;; Test 30: Gradient through relu then tensor-sum
;; f(x) = sum(relu(x)), gradient is the positive mask
;; ============================================================
(let* ((g (gradient
            (lambda (x) (tensor-sum (relu x)))
            (tensor 3 -1.0 0.0 2.0))))
  (display
    (if (and (= (vector-length g) 3)
             (approx= (vector-ref g 0) 0.0 1e-6)
             (approx= (vector-ref g 1) 0.0 1e-6)
             (approx= (vector-ref g 2) 1.0 1e-6))
        "PASS" "FAIL"))
  (display ": gradient through relu tensor-sum matches positive mask") (newline))

;; ============================================================
;; Test 31: Gradient through sigmoid then tensor-sum
;; f(x) = sum(sigmoid(x)), gradient = sigmoid(x)*(1-sigmoid(x))
;; ============================================================
(let* ((g (gradient
            (lambda (x) (tensor-sum (sigmoid x)))
            (tensor 2 0.0 1.0))))
  (display
    (if (and (= (vector-length g) 2)
             (approx= (vector-ref g 0) 0.25 1e-6)
             (approx= (vector-ref g 1) 0.19661193324148185 1e-5))
        "PASS" "FAIL"))
  (display ": gradient through sigmoid tensor-sum matches sigmoid derivative") (newline))

;; ============================================================
;; Test 32: Gradient through GELU then tensor-sum
;; The GELU implementation uses the standard tanh approximation.
;; ============================================================
(let* ((g (gradient
            (lambda (x) (tensor-sum (gelu x)))
            (tensor 2 0.0 1.0))))
  (display
    (if (and (= (vector-length g) 2)
             (approx= (vector-ref g 0) 0.5 1e-6)
             (approx= (vector-ref g 1) 1.06778 1e-4))
        "PASS" "FAIL"))
  (display ": gradient through gelu tensor-sum matches tanh approximation") (newline))

;; ============================================================
;; Test 33: Gradient through SiLU then tensor-sum
;; SiLU'(x) = sigmoid(x) * (1 + x * (1 - sigmoid(x)))
;; ============================================================
(let* ((g (gradient
            (lambda (x) (tensor-sum (silu x)))
            (tensor 2 0.0 1.0))))
  (display
    (if (and (= (vector-length g) 2)
             (approx= (vector-ref g 0) 0.5 1e-6)
             (approx= (vector-ref g 1) 0.927671 1e-4))
        "PASS" "FAIL"))
  (display ": gradient through silu tensor-sum matches silu derivative") (newline))

;; ============================================================
;; Test 34: Gradient through leaky-relu then tensor-sum
;; Default alpha is 0.01.
;; ============================================================
(let* ((g (gradient
            (lambda (x) (tensor-sum (leaky-relu x)))
            (tensor 2 -1.0 2.0))))
  (display
    (if (and (= (vector-length g) 2)
             (approx= (vector-ref g 0) 0.01 1e-6)
             (approx= (vector-ref g 1) 1.0 1e-6))
        "PASS" "FAIL"))
  (display ": gradient through leaky-relu tensor-sum matches default slope") (newline))
