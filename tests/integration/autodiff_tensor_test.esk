            (tensor 3 1.0 3.0 2.0))))
  (display
    (if (and (= (vector-length g) 3)
             (approx= (vector-ref g 0) 0.0 1e-6)
             (approx= (vector-ref g 1) 1.0 1e-6)
             (approx= (vector-ref g 2) 0.0 1e-6))
        "PASS" "FAIL"))
  (display ": gradient through tensor-max selects maximum element") (newline))

;; ============================================================
