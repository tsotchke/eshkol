             (approx= (vector-ref g 3) 0.5 1e-6)
             (approx= (vector-ref g 4) 0.5 1e-6)
             (approx= (vector-ref g 5) 0.5 1e-6))
        "PASS" "FAIL"))
  (display ": gradient through axis tensor-mean divides by axis length") (newline))

