;; XLA dispatch threshold test
;; Verifies that small tensors use SIMD and large tensors use XLA
(display "=== XLA Dispatch Threshold Test ===") (newline)

;; Small matmul - should use SIMD path (10*10*10 = 1000 ops < 100K threshold)
(display "--- Small matmul (SIMD path) ---") (newline)
(define small-A (reshape (arange 100) 10 10))
(define small-B (reshape (arange 100) 10 10))
(define small-C (matmul small-A small-B))
(display "Small result shape: ") (display (tensor-shape small-C)) (newline)
(display "Small C[0,0] = ") (display (tensor-get small-C 0 0)) (newline)

;; Medium matmul - should use cBLAS path (50*50*50 = 125K ops > 4K threshold)
(display "--- Medium matmul (cBLAS path) ---") (newline)
(define med-A (reshape (arange 2500) 50 50))
(define med-B (reshape (arange 2500) 50 50))
(define med-C (matmul med-A med-B))
(display "Medium result shape: ") (display (tensor-shape med-C)) (newline)
(display "Medium C[0,0] = ") (display (tensor-get med-C 0 0)) (newline)

;; Large matmul - should use XLA path if available (400*400*400 = 64M ops >> 100K)
(display "--- Large matmul (XLA path if available) ---") (newline)
(define large-A (reshape (arange 160000) 400 400))
(define large-B (reshape (arange 160000) 400 400))
(define large-C (matmul large-A large-B))
(display "Large result shape: ") (display (tensor-shape large-C)) (newline)
(display "Large C[0,0] = ") (display (tensor-get large-C 0 0)) (newline)

;; All three should produce correct results regardless of backend
(display "Dispatch threshold test: PASS") (newline)
