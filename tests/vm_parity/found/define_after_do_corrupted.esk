; FILED: a top-level `do` loop corrupts top-level defines that FOLLOW it —
; the later make-vector's slot is clobbered and reads back ().
; Moving the define above the do loop makes it work.
; native -r : 7
; vm        : ()
(define v (make-vector 3 0))
(do ((i 0 (+ i 1))) ((= i 3)) (vector-set! v i i))
(define w (make-vector 2 7))
(display (vector-ref w 0))
