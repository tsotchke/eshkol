; VM<->native `gradient` parity.
;
; Exercises the full public gradient surface the VM now supports — direct,
; through-a-function-parameter (wrapped), and curried forms; 2-arg / 3-arg
; scalar losses spread into N coordinates; an arity-1 whole-vector loss read
; via vref; non-polynomial losses (sin/cos/exp/log/div); and repeated calls in
; a loop (memory).  Every gradient prints as a Scheme vector `#(...)` (or a
; bare scalar for a scalar point), so the pre-existing vector/tensor display
; quirk is not exercised and the newline-normalized byte streams match native.
;
; Higher-order nesting (gradient of a derivative / Taylor tower) is
; deliberately absent — it stays native-only (see tests/vm_parity/PARITY.tsv).

; --- 2-arg scalar loss, direct: (x-3)^2 + (y-5)^2, grad at (0,0) = (-6,-10) ---
(define (loss x y) (+ (* (- x 3.0) (- x 3.0)) (* (- y 5.0) (- y 5.0))))
(display (gradient loss (vector 0.0 0.0))) (newline)            ; #(-6 -10)

; --- 3-arg scalar loss: (x-1)^2+(y-2)^2+(z-3)^2, grad at origin = (-2,-4,-6) --
(define (loss3 x y z)
  (+ (* (- x 1.0) (- x 1.0))
     (+ (* (- y 2.0) (- y 2.0)) (* (- z 3.0) (- z 3.0)))))
(display (gradient loss3 (vector 0.0 0.0 0.0))) (newline)       ; #(-2 -4 -6)

; --- arity-1 whole-vector loss read via vref: v0^2+v1^2, grad at (3,4)=(6,8) --
(define (vloss v) (+ (* (vref v 0) (vref v 0)) (* (vref v 1) (vref v 1))))
(display (gradient vloss (vector 3.0 4.0))) (newline)           ; #(6 8)

; --- non-polynomial: sin(x)cos(y) + x^3 at (0.7, 1.3) ---
(define (nonpoly x y) (+ (* (sin x) (cos y)) (* x x x)))
(display (gradient nonpoly (vector 0.7 1.3))) (newline)         ; #(1.67459 -0.620741)

; --- exp + log, scalar point returns a scalar derivative: e^x + 1/x at 2 ---
(define (elg x) (+ (exp x) (log x)))
(display (gradient elg 2.0)) (newline)                          ; 7.88906

; --- quotient loss u/v at (6,2): d/du = 1/v = 0.5, d/dv = -u/v^2 = -1.5 ---
(display (gradient (lambda (u v) (/ u v)) (vector 6.0 2.0))) (newline) ; #(0.5 -1.5)

; --- through a callable parameter (wrapped) agrees with the direct call ---
(define (gwrap f p) (gradient f p))
(display (gwrap loss (vector 1.0 1.0))) (newline)               ; #(-4 -8)

; --- curried: single vector point, and spread scalar coordinates ---
(display ((gradient loss) (vector 0.0 0.0))) (newline)          ; #(-6 -10)
(display ((gradient loss) 0.0 0.0)) (newline)                   ; #(-6 -10)

; --- gradient in a loop (500 calls): grad of a^2+b^2 at (1,2) is (2,4);
;     summing d/da over 500 iterations = 1000, and the run must not leak. ---
(define (qloss a b) (+ (* a a) (* b b)))
(define (loopsum n)
  (let loop ((i 0) (s 0.0))
    (if (= i n) s
        (loop (+ i 1) (+ s (vref (gradient qloss (vector 1.0 2.0)) 0))))))
(display (loopsum 500)) (newline)                               ; 1000
