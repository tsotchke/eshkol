; vectors via make-vector / vector (NOT #(...) literals — see found/)
(define v (make-vector 5 0))
(do ((i 0 (+ i 1))) ((= i 5)) (vector-set! v i (* i i)))
(display (vector-ref v 4)) (newline)
(display (vector-ref v 3)) (newline)
(display (vector-length v)) (newline)
(define w (vector 10 20 30))
(display (vector-ref w 1)) (newline)
(display (vector->list w)) (newline)
(display (vector-ref (list->vector (list 7 8)) 0)) (newline)
