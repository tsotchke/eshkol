; string builtins
(display (string-append "foo" "bar" "baz")) (newline)
(display (string-length "hello")) (newline)
(display (substring "hello" 1 3)) (newline)
(display (string-upcase "abc")) (newline)
(display (string-downcase "XY")) (newline)
(display (string=? "ab" "ab")) (newline)
(display (string<? "a" "b")) (newline)
(display (number->string 42)) (newline)
(display (string->number "3.5")) (newline)
