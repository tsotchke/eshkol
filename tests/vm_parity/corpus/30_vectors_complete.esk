; R7RS vector constructors and conversions retain their full contents in all
; three routes (native, VM source compiler, and ESKB loader).
(display (vector-ref (vector 10 20 30) 1))
(newline)
(display (vector->list (vector 1 2)))
(newline)
(display (vector-ref (list->vector (list 7 8)) 0))
(newline)
(display (vector-ref #(10 20 30) 1))
(newline)
