;; Regression: gradient must recover a CALLABLE's arity when the function is
;; reached through a parameter / wrapper, so the input point is expanded to match
;; the function's true signature instead of being passed whole as one tensor arg.
;;
;; Defect: (gradient f point) where f is a callable parameter lost the callable's
;; arity, treated the point list as one tensor argument, and misdispatched a
;; scalar loss to tensor-sub/tensor-mul (type error). The direct call
;; (gradient loss point) already worked; the indirect/wrapped and curried forms
;; did not. All forms must now agree with the direct call.

(require stdlib)

(define tests-passed 0)
(define tests-failed 0)

(define (approx-equal? a b epsilon)
  (< (abs (- a b)) epsilon))

(define (check name expected actual)
  (if (approx-equal? expected actual 0.001)
      (begin
        (set! tests-passed (+ tests-passed 1))
        (display "PASS: ") (display name) (newline))
      (begin
        (set! tests-failed (+ tests-failed 1))
        (display "FAIL: ") (display name)
        (display " (expected ") (display expected)
        (display ", got ") (display actual) (display ")") (newline))))

;; Strict equality: the two gradient values must match to the last bit (used to
;; assert an indirect/curried form is byte-identical to the direct exact-AD call,
;; not merely close — the higher-order path must be exact AD, never a
;; finite-difference approximation).
(define (check-exact name direct-val other-val)
  (if (= direct-val other-val)
      (begin
        (set! tests-passed (+ tests-passed 1))
        (display "PASS: ") (display name) (newline))
      (begin
        (set! tests-failed (+ tests-failed 1))
        (display "FAIL: ") (display name)
        (display " (direct ") (display direct-val)
        (display " != ") (display other-val)
        (display ", diff ") (display (- other-val direct-val)) (display ")") (newline))))

;; ---------------------------------------------------------------------------
;; Test 1: two-scalar named loss reached through a callable parameter.
;; loss(x,y) = (x-3)^2 + (y-5)^2, so grad = (2(x-3), 2(y-5)); at (0,0) => (-6,-10).
;; The indirect (wrapped) result must equal the direct result.
;; ---------------------------------------------------------------------------
(define (loss x y)
  (+ (* (- x 3.0) (- x 3.0)) (* (- y 5.0) (- y 5.0))))
(define (gradient-wrapper f point) (gradient f point))

(define d1 (gradient loss (vector 0.0 0.0)))
(define w1 (gradient-wrapper loss (vector 0.0 0.0)))
(check "t1 direct  d/dx"  -6.0  (vref d1 0))
(check "t1 direct  d/dy" -10.0  (vref d1 1))
(check "t1 wrapped d/dx"  -6.0  (vref w1 0))
(check "t1 wrapped d/dy" -10.0  (vref w1 1))

;; ---------------------------------------------------------------------------
;; Test 2: same, with type annotations on the wrapper's function/point params.
;; ---------------------------------------------------------------------------
(define (loss2 (x : real) (y : real)) : real
  (+ (* (- x 3.0) (- x 3.0)) (* (- y 5.0) (- y 5.0))))
(define (gwrap2 (f : (-> real real real)) (point : (list real))) : (vector real)
  (gradient f point))

(define w2 (gwrap2 loss2 (list 0.0 0.0)))
(check "t2 annotated d/dx"  -6.0  (vref w2 0))
(check "t2 annotated d/dy" -10.0  (vref w2 1))

;; ---------------------------------------------------------------------------
;; Test 3: THREE-argument callable (guards against any arity-2 hardcoding).
;; loss3(x,y,z) = (x-1)^2 + (y-2)^2 + (z-3)^2; at (0,0,0) => (-2,-4,-6).
;; ---------------------------------------------------------------------------
(define (loss3 x y z)
  (+ (* (- x 1.0) (- x 1.0))
     (+ (* (- y 2.0) (- y 2.0))
        (* (- z 3.0) (- z 3.0)))))
(define (gwrap3 f point) (gradient f point))

(define d3 (gradient loss3 (vector 0.0 0.0 0.0)))
(define w3 (gwrap3 loss3 (vector 0.0 0.0 0.0)))
(check "t3 direct  d/dx" -2.0 (vref d3 0))
(check "t3 direct  d/dz" -6.0 (vref d3 2))
(check "t3 wrapped d/dx" -2.0 (vref w3 0))
(check "t3 wrapped d/dy" -4.0 (vref w3 1))
(check "t3 wrapped d/dz" -6.0 (vref w3 2))

;; ---------------------------------------------------------------------------
;; Test 4: indirect single-VECTOR-argument loss (arity 1). The intended
;; whole-point tensor path must keep working: f takes ONE vector v and reads
;; its components with vref. f(v) = v0^2 + v1^2; at (3,4) => (6,8).
;; ---------------------------------------------------------------------------
(define (vloss v)
  (+ (* (vref v 0) (vref v 0))
     (* (vref v 1) (vref v 1))))
(define (gwrap-v f point) (gradient f point))

(define d4 (gradient vloss (vector 3.0 4.0)))
(define w4 (gwrap-v vloss (vector 3.0 4.0)))
(check "t4 direct  d/dx" 6.0 (vref d4 0))
(check "t4 direct  d/dy" 8.0 (vref d4 1))
(check "t4 wrapped d/dx" 6.0 (vref w4 0))
(check "t4 wrapped d/dy" 8.0 (vref w4 1))

;; ---------------------------------------------------------------------------
;; Test 5: curried form ((gradient f) point) for a multi-arg callable. A single
;; collection argument is expanded to spread coordinates, so it agrees with the
;; two-argument form: at (0,0) => (-6,-10).
;; ---------------------------------------------------------------------------
(define w5 ((gradient loss) (vector 0.0 0.0)))
(check "t5 curried-vec    d/dx"  -6.0 (vref w5 0))
(check "t5 curried-vec    d/dy" -10.0 (vref w5 1))
;; and the established spread-scalar curried convention still works.
(define w5b ((gradient loss) 0.0 0.0))
(check "t5 curried-spread d/dx"  -6.0 (vref w5b 0))
(check "t5 curried-spread d/dy" -10.0 (vref w5b 1))

;; ---------------------------------------------------------------------------
;; Test 6: the curried and wrapped forms are EXACT (byte-identical to the direct
;; call), not finite-difference approximations. A NON-polynomial function is the
;; discriminating case: central differencing would leave a ~1e-8 residual, so
;; every diff below must be exactly 0.0. f(x,y) = sin(x)cos(y) + x^3.
;; ---------------------------------------------------------------------------
(define (nonpoly x y) (+ (* (sin x) (cos y)) (* x x x)))
(define (npwrap f p) (gradient f p))
(define dnp  (gradient nonpoly (vector 0.7 1.3)))
(define wnp  (npwrap nonpoly (vector 0.7 1.3)))
(define cnp  ((gradient nonpoly) (vector 0.7 1.3)))
;; correctness (approximate): df/dx = cos(x)cos(y)+3x^2, df/dy = -sin(x)sin(y)
(check "t6 nonpoly direct d/dx"
       (+ (* (cos 0.7) (cos 1.3)) (* 3.0 (* 0.7 0.7))) (vref dnp 0))
(check "t6 nonpoly direct d/dy"
       (- (* (sin 0.7) (sin 1.3))) (vref dnp 1))
;; byte-identical: wrapped == direct, curried == direct (exact AD, diff == 0)
(check-exact "t6 wrapped==direct d/dx" (vref dnp 0) (vref wnp 0))
(check-exact "t6 wrapped==direct d/dy" (vref dnp 1) (vref wnp 1))
(check-exact "t6 curried==direct d/dx" (vref dnp 0) (vref cnp 0))
(check-exact "t6 curried==direct d/dy" (vref dnp 1) (vref cnp 1))

;; ---------------------------------------------------------------------------
(newline)
(display "gradient_callable_arity: ")
(display tests-passed) (display " passed, ")
(display tests-failed) (display " failed") (newline)
(if (= tests-failed 0)
    (display "RESULT: ALL PASSED\n")
    (display "RESULT: FAILURES\n"))
