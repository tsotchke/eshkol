;; Test lambda returning vector with runtime debug
(extern void printf char* ...)

(define make-vec (lambda (v) (vector 1.0 2.0)))

(define (main)
  (display "Testing lambda that returns vector...\n")
  (let ((result (make-vec 0)))
    (display "Lambda returned: ")
    (display result)
    (newline)
    ;; Verify it's a proper vector by accessing elements
    (display "Vector length: ")
    (display (vector-length result))
    (newline)
    (display "Element 0: ")
    (display (vector-ref result 0))
    (newline)
    (display "Element 1: ")
    (display (vector-ref result 1))
    (newline))
  0)