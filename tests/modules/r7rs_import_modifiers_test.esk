;;; R7RS import modifiers lower to existing require plus alias forms.

(import (only (test modules mod_b) func-b))
(import (rename (test modules mod_b) (func-b double-b)))
(import (prefix (only (test modules mod_b) func-b) b-))
(import (except (test modules mod_b) not-a-real-export))

(define failures 0)

(define (check name expected actual)
  (if (= expected actual)
      (begin
        (display "PASS: ")
        (display name)
        (newline))
      (begin
        (display "FAIL: ")
        (display name)
        (display " expected ")
        (display expected)
        (display " got ")
        (display actual)
        (newline)
        (set! failures (+ failures 1)))))

(check "only import exposes func-b" 12 (func-b 6))
(check "rename import alias" 14 (double-b 7))
(check "prefix import alias" 16 (b-func-b 8))
(check "except import still loads module" 18 (func-b 9))

(if (= failures 0)
    (display "R7RS import modifier tests passed")
    (error "R7RS import modifier tests failed"))
(newline)
