(metamorphic-check "list.append_assoc.case31" (equal? (append (append (list 9 9 9 -2) (list 8 6 -5 -3 0 8)) (list -5 -3 0 -1 3)) (append (list 9 9 9 -2) (append (list 8 6 -5 -3 0 8) (list -5 -3 0 -1 3)))) "case=31 a=[9, 9, 9, -2] b=[8, 6, -5, -3, 0, 8] c=[-5, -3, 0, -1, 3]")
