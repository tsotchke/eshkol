(display (if (string? "hello") "PASS" "FAIL")) (display ": string? on \"hello\" = true") (newline)
(display (if (not (string? 42)) "PASS" "FAIL")) (display ": string? on integer 42 = false") (newline)
(display (if (not (string? 3.14)) "PASS" "FAIL")) (display ": string? on float 3.14 = false") (newline)
(display (if (not (string? #t)) "PASS" "FAIL")) (display ": string? on #t = false") (newline)
