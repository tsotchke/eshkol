(display (if (not (pair? '())) "PASS" "FAIL")) (display ": pair? on '() empty list = false") (newline)
(display (if (not (pair? 42)) "PASS" "FAIL")) (display ": pair? on integer 42 = false") (newline)
(display (if (not (pair? 3.14)) "PASS" "FAIL")) (display ": pair? on float 3.14 = false") (newline)
