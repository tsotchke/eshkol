(require stdlib)

(display "TEST: Type predicate matrix") (newline)

; --- number? predicate ---
(display (if (number? 42) "PASS" "FAIL")) (display ": number? on integer 42 = true") (newline)
(display (if (number? 3.14) "PASS" "FAIL")) (display ": number? on float 3.14 = true") (newline)
(display (if (not (number? #t)) "PASS" "FAIL")) (display ": number? on #t = false") (newline)
(display (if (not (number? #f)) "PASS" "FAIL")) (display ": number? on #f = false") (newline)
(display (if (not (number? "hello")) "PASS" "FAIL")) (display ": number? on string = false") (newline)
(display (if (not (number? #\a)) "PASS" "FAIL")) (display ": number? on char = false") (newline)
(display (if (not (number? 'foo)) "PASS" "FAIL")) (display ": number? on symbol = false") (newline)
(display (if (not (number? '(1 2 3))) "PASS" "FAIL")) (display ": number? on list = false") (newline)
(display (if (not (number? '())) "PASS" "FAIL")) (display ": number? on empty list = false") (newline)
(display (if (not (number? #(1 2 3))) "PASS" "FAIL")) (display ": number? on vector = false") (newline)
(display (if (not (number? (lambda (x) x))) "PASS" "FAIL")) (display ": number? on lambda = false") (newline)

