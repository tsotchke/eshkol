(display (if (null? '()) "PASS" "FAIL")) (display ": null? on '() = true") (newline)
(display (if (not (null? '(1 2 3))) "PASS" "FAIL")) (display ": null? on '(1 2 3) = false") (newline)
(display (if (not (null? '(1))) "PASS" "FAIL")) (display ": null? on '(1) = false") (newline)
(display (if (not (null? 42)) "PASS" "FAIL")) (display ": null? on integer 42 = false") (newline)
(display (if (not (null? 3.14)) "PASS" "FAIL")) (display ": null? on float 3.14 = false") (newline)
(display (if (not (null? #t)) "PASS" "FAIL")) (display ": null? on #t = false") (newline)
