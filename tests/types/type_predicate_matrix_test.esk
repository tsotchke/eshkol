; --- procedure? predicate ---
(display (if (procedure? (lambda (x) x)) "PASS" "FAIL")) (display ": procedure? on (lambda (x) x) = true") (newline)
(display (if (procedure? car) "PASS" "FAIL")) (display ": procedure? on builtin car = true") (newline)
(display (if (procedure? cdr) "PASS" "FAIL")) (display ": procedure? on builtin cdr = true") (newline)
(display (if (procedure? cons) "PASS" "FAIL")) (display ": procedure? on builtin cons = true") (newline)
(display (if (procedure? +) "PASS" "FAIL")) (display ": procedure? on builtin + = true") (newline)
(display (if (not (procedure? 42)) "PASS" "FAIL")) (display ": procedure? on integer 42 = false") (newline)
(display (if (not (procedure? 3.14)) "PASS" "FAIL")) (display ": procedure? on float 3.14 = false") (newline)
(display (if (not (procedure? #t)) "PASS" "FAIL")) (display ": procedure? on #t = false") (newline)
(display (if (not (procedure? #f)) "PASS" "FAIL")) (display ": procedure? on #f = false") (newline)
(display (if (not (procedure? "hello")) "PASS" "FAIL")) (display ": procedure? on string = false") (newline)
