(display (if (not (symbol? 42)) "PASS" "FAIL")) (display ": symbol? on integer 42 = false") (newline)
(display (if (not (symbol? 3.14)) "PASS" "FAIL")) (display ": symbol? on float 3.14 = false") (newline)
