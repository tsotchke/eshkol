; --- char? predicate ---
(display (if (char? #\a) "PASS" "FAIL")) (display ": char? on #\\a = true") (newline)
(display (if (char? #\space) "PASS" "FAIL")) (display ": char? on #\\space = true") (newline)
(display (if (not (char? 42)) "PASS" "FAIL")) (display ": char? on integer 42 = false") (newline)
(display (if (not (char? 3.14)) "PASS" "FAIL")) (display ": char? on float 3.14 = false") (newline)
