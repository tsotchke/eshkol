; --- exact? predicate ---
(display (if (exact? 42) "PASS" "FAIL")) (display ": exact? on integer 42 = true") (newline)
(display (if (not (exact? 3.14)) "PASS" "FAIL")) (display ": exact? on float 3.14 = false") (newline)
(display (if (exact? 0) "PASS" "FAIL")) (display ": exact? on integer 0 = true") (newline)
(display (if (not (exact? 0.0)) "PASS" "FAIL")) (display ": exact? on float 0.0 = false") (newline)

; --- inexact? predicate ---
(display (if (inexact? 3.14) "PASS" "FAIL")) (display ": inexact? on float 3.14 = true") (newline)
(display (if (not (inexact? 42)) "PASS" "FAIL")) (display ": inexact? on integer 42 = false") (newline)
(display (if (inexact? 0.0) "PASS" "FAIL")) (display ": inexact? on float 0.0 = true") (newline)
(display (if (not (inexact? 0)) "PASS" "FAIL")) (display ": inexact? on integer 0 = false") (newline)

; --- boolean? predicate ---
(display (if (boolean? #t) "PASS" "FAIL")) (display ": boolean? on #t = true") (newline)
(display (if (boolean? #f) "PASS" "FAIL")) (display ": boolean? on #f = true") (newline)
(display (if (not (boolean? 42)) "PASS" "FAIL")) (display ": boolean? on integer 42 = false") (newline)
(display (if (not (boolean? 3.14)) "PASS" "FAIL")) (display ": boolean? on float 3.14 = false") (newline)
