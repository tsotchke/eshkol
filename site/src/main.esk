        ;; Architecture
        (let ((g4 (render-sidebar-group sidebar "ARCHITECTURE")))
          (render-sidebar-item g4 "Architecture Overview" "https://raw.githubusercontent.com/tsotchke/eshkol/master/docs/ESHKOL_V1_ARCHITECTURE.md")
          (render-sidebar-item g4 "Compiler Architecture" "https://raw.githubusercontent.com/tsotchke/eshkol/master/docs/breakdown/COMPILER_ARCHITECTURE.md")
          (render-sidebar-item g4 "Memory Management" "https://raw.githubusercontent.com/tsotchke/eshkol/master/docs/breakdown/MEMORY_MANAGEMENT.md")
          (render-sidebar-item g4 "Type System" "https://raw.githubusercontent.com/tsotchke/eshkol/master/docs/breakdown/TYPE_SYSTEM.md"))

        ;; Topics
        (let ((g5 (render-sidebar-group sidebar "TOPICS")))
          (render-sidebar-item g5 "Automatic Differentiation" "https://raw.githubusercontent.com/tsotchke/eshkol/master/docs/breakdown/AUTODIFF.md")
          (render-sidebar-item g5 "Vector Operations" "https://raw.githubusercontent.com/tsotchke/eshkol/master/docs/breakdown/VECTOR_OPERATIONS.md")
          (render-sidebar-item g5 "GPU Acceleration" "https://raw.githubusercontent.com/tsotchke/eshkol/master/docs/breakdown/GPU_ACCELERATION.md")
          (render-sidebar-item g5 "Scheme Compatibility" "https://raw.githubusercontent.com/tsotchke/eshkol/master/docs/breakdown/SCHEME_COMPATIBILITY.md"))

        ;; Project
        (let ((g6 (render-sidebar-group sidebar "PROJECT")))
          (render-sidebar-item g6 "Roadmap" "https://raw.githubusercontent.com/tsotchke/eshkol/master/ROADMAP.md")
          (render-sidebar-item g6 "Changelog" "https://raw.githubusercontent.com/tsotchke/eshkol/master/CHANGELOG.md")
