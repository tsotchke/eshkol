;; ═══════════════════════════════════════════════════════════

(define (render-sidebar-group parent title)
  (let ((group (create-div parent)))
    (web-add-class group "docs-sidebar-group")
    (let ((t (create-text "div" title group)))
      (web-add-class t "docs-sidebar-group-title"))
    group))

(define (render-sidebar-item parent label url)
  (let ((item (create-text "a" label parent)))
    (web-add-class item "docs-sidebar-item")
    (web-set-attribute item "href" url)
    (web-set-attribute item "data-url" url)
    item))

