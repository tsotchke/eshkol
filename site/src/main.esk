(define (render-docs-page content)
  (let ((page (create-div content)))
    (style! page "paddingTop" "32px")

    ;; Docs layout: sidebar + content
    (let ((layout (create-div page)))
      (web-add-class layout "docs-layout")

      ;; Sidebar
      (let ((sidebar (create-div layout)))
        (web-add-class sidebar "docs-sidebar")

        ;; Language
        (let ((g2 (render-sidebar-group sidebar "LANGUAGE")))
          (render-sidebar-item g2 "Language Guide" "https://raw.githubusercontent.com/tsotchke/eshkol/master/ESHKOL_LANGUAGE_GUIDE.md")
          (render-sidebar-item g2 "Language Reference" "https://raw.githubusercontent.com/tsotchke/eshkol/master/ESHKOL_V1_LANGUAGE_REFERENCE.md")
          (render-sidebar-item g2 "Language Specification" "https://raw.githubusercontent.com/tsotchke/eshkol/master/COMPLETE_LANGUAGE_SPECIFICATION.md"))

        ;; Reference
        (let ((g3 (render-sidebar-group sidebar "REFERENCE")))
          (render-sidebar-item g3 "API Reference" "https://raw.githubusercontent.com/tsotchke/eshkol/master/docs/API_REFERENCE.md")
