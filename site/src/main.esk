        (let ((hint (create-text "p" "Select a document from the sidebar to load it." doc-area)))
          (style! hint "color" "#71717a")
          (style! hint "fontStyle" "italic"))))))

;; ═══════════════════════════════════════════════════════════
;; PAGE: DOWNLOADS
;; ═══════════════════════════════════════════════════════════

(define (render-downloads-page content)
  (let ((page (create-section content)))
    (create-page-header page "Downloads" "Install Eshkol on macOS, Linux, Windows, or build from source. Every release ships 16 pre-built binaries across 3 platforms, 2 architectures, and 3 acceleration tiers.")

    ;; ── macOS ──────────────────────────────────────────────────
    (section-subheading page "macOS (Homebrew)")
    (body-text page "The fastest way to install on macOS. Supports both Apple Silicon (M1/M2/M3/M4) and Intel x86_64.")
    (let ((cmd (create-div page)))
      (web-add-class cmd "install-cmd")
      (web-set-text-content cmd "brew tap tsotchke/eshkol && brew install eshkol"))

    ;; ── Linux ──────────────────────────────────────────────────
    (section-subheading page "Linux")
    (body-text page "Download a .tar.gz archive from the latest release, extract, and add to your PATH.")
    (create-code-block page
      "<code style='color:#22c55e'>$</code> curl -LO https://github.com/tsotchke/eshkol/releases/latest\n<code style='color:#606078'># download the linux-x64-lite or linux-arm64-lite .tar.gz</code>\n<code style='color:#22c55e'>$</code> tar xzf eshkol-*.tar.gz\n<code style='color:#22c55e'>$</code> sudo cp eshkol-run eshkol-repl /usr/local/bin/")

    ;; ── Windows ────────────────────────────────────────────────
    (section-subheading page "Windows")
    (body-text page "Native Windows builds via Visual Studio 2022 + ClangCL + LLVM 21 SDK. Supports both x86_64 and ARM64.")
    (create-code-block page
      "<code style='color:#606078'>:: Download the .zip for your architecture from GitHub Releases</code>\n<code style='color:#606078'>:: Extract and add the directory to your PATH</code>\n<code style='color:#22c55e'>&gt;</code> eshkol-run hello.esk -o hello.exe\n<code style='color:#22c55e'>&gt;</code> hello.exe\n<span style='color:#a78bfa'>Hello, world!</span>")

    ;; ── Release Artifacts Table ────────────────────────────────
    (section-subheading page "Release Artifacts")
    (body-text page "Each release includes three build tiers per platform. All link to the latest release on GitHub.")

    (let ((tbl (web-create-element "table")))
      (web-add-class tbl "comparison-table")
      (web-set-inner-html tbl "<thead><tr><th>Platform</th><th>Architecture</th><th>Lite</th><th>XLA</th><th>CUDA</th></tr></thead><tbody><tr><td><strong>macOS</strong></td><td>Apple Silicon (arm64)</td><td><a href='https://github.com/tsotchke/eshkol/releases/latest' target='_blank'>.tar.gz</a></td><td><a href='https://github.com/tsotchke/eshkol/releases/latest' target='_blank'>.tar.gz</a></td><td>-</td></tr><tr><td><strong>macOS</strong></td><td>Intel (x86_64)</td><td><a href='https://github.com/tsotchke/eshkol/releases/latest' target='_blank'>.tar.gz</a></td><td><a href='https://github.com/tsotchke/eshkol/releases/latest' target='_blank'>.tar.gz</a></td><td>-</td></tr><tr><td><strong>Linux</strong></td><td>x86_64</td><td><a href='https://github.com/tsotchke/eshkol/releases/latest' target='_blank'>.tar.gz</a></td><td><a href='https://github.com/tsotchke/eshkol/releases/latest' target='_blank'>.tar.gz</a></td><td><a href='https://github.com/tsotchke/eshkol/releases/latest' target='_blank'>.tar.gz</a></td></tr><tr><td><strong>Linux</strong></td><td>ARM64</td><td><a href='https://github.com/tsotchke/eshkol/releases/latest' target='_blank'>.tar.gz</a></td><td><a href='https://github.com/tsotchke/eshkol/releases/latest' target='_blank'>.tar.gz</a></td><td><a href='https://github.com/tsotchke/eshkol/releases/latest' target='_blank'>.tar.gz</a></td></tr><tr><td><strong>Windows</strong></td><td>x86_64</td><td><a href='https://github.com/tsotchke/eshkol/releases/latest' target='_blank'>.zip</a></td><td><a href='https://github.com/tsotchke/eshkol/releases/latest' target='_blank'>.zip</a></td><td><a href='https://github.com/tsotchke/eshkol/releases/latest' target='_blank'>.zip</a></td></tr><tr><td><strong>Windows</strong></td><td>ARM64</td><td><a href='https://github.com/tsotchke/eshkol/releases/latest' target='_blank'>.zip</a></td><td><a href='https://github.com/tsotchke/eshkol/releases/latest' target='_blank'>.zip</a></td><td><a href='https://github.com/tsotchke/eshkol/releases/latest' target='_blank'>.zip</a></td></tr><tr><td><strong>WebAssembly</strong></td><td>Any</td><td><a href='#/playground'>Try in Browser</a></td><td>-</td><td>-</td></tr></tbody>")
      (web-append-child page tbl))

    (body-html page "<strong>Lite</strong> &mdash; core compiler + REPL + stdlib. No GPU dependencies. Best for most users.<br><strong>XLA</strong> &mdash; adds StableHLO/XLA backend for accelerated tensor operations.<br><strong>CUDA</strong> &mdash; adds NVIDIA GPU acceleration via CUDA + Metal on macOS.")

    ;; ── Build from Source ──────────────────────────────────────
    (section-subheading page "Build from Source")
    (body-text page "Requires LLVM 21+, a C++17 compiler, and CMake 3.14+.")
    (create-code-block page
      "<code style='color:#22c55e'>$</code> git clone https://github.com/tsotchke/eshkol.git\n<code style='color:#22c55e'>$</code> cd eshkol && mkdir build && cd build\n<code style='color:#22c55e'>$</code> cmake .. -DCMAKE_BUILD_TYPE=Release\n<code style='color:#22c55e'>$</code> make -j$(nproc)\n<code style='color:#22c55e'>$</code> sudo make install")

    ;; ── Verify ──────────────────────────────────────────────────
    (section-subheading page "Verify Installation")
    (body-text page "Compile and run a simple program to confirm everything works.")
    (create-code-block page
      "<code style='color:#22c55e'>$</code> echo '(display (+ 1 2))' > test.esk\n<code style='color:#22c55e'>$</code> eshkol-run test.esk -o test && ./test\n<span style='color:#a78bfa'>3</span>")

    ;; Platform badges
    (let ((badges (create-div page)))
      (style! badges "marginTop" "40px")
      (style! badges "display" "flex")
      (style! badges "gap" "12px")
      (style! badges "flexWrap" "wrap")

      (let ((make-badge (lambda (text badge-class)
              (let ((badge (create-text "span" text badges)))
                (web-add-class badge "badge")
                (web-add-class badge badge-class)
                badge))))
        (make-badge "macOS (Apple Silicon)" "badge-stable")
        (make-badge "macOS (Intel)" "badge-stable")
        (make-badge "Linux (x86_64)" "badge-stable")
        (make-badge "Linux (ARM64)" "badge-stable")
        (make-badge "Windows (x64)" "badge-stable")
        (make-badge "Windows (ARM64)" "badge-stable")
        (make-badge "WebAssembly" "badge-pre")))

    (create-divider page)

    ;; Quick start guide
    (section-subheading page "Quick Start")
    (body-text page "After installing, create your first program:")

    (create-code-block page
      "<code style='color:#22c55e'>$</code> cat > hello.esk\n<span style='color:#c084fc'>(display</span> <span style='color:#00ff88'>\"Hello, world!\"</span><span style='color:#c084fc'>)</span>\n<span style='color:#c084fc'>(newline)</span>\n^D\n\n<code style='color:#22c55e'>$</code> eshkol-run hello.esk -o hello\n<code style='color:#22c55e'>$</code> ./hello\n<span style='color:#a78bfa'>Hello, world!</span>")

    (body-text page "Try a derivative computation:")

    (create-code-block page
      "<code style='color:#22c55e'>$</code> cat > deriv.esk\n<span style='color:#c084fc'>(define</span> <span style='color:#a78bfa'>(f x)</span> <span style='color:#c084fc'>(+</span> <span style='color:#c084fc'>(*</span> x x x<span style='color:#c084fc'>)</span> <span style='color:#c084fc'>(*</span> <span style='color:#00ff88'>2.0</span> x<span style='color:#c084fc'>)))</span>\n<span style='color:#c084fc'>(display</span> <span style='color:#c084fc'>(derivative</span> f <span style='color:#00ff88'>3.0</span><span style='color:#c084fc'>))</span>\n^D\n\n<code style='color:#22c55e'>$</code> eshkol-run deriv.esk -o deriv && ./deriv\n<span style='color:#a78bfa'>29.0</span>")

    (body-text page "Launch the REPL for interactive development:")

    (create-code-block page
      "<code style='color:#22c55e'>$</code> eshkol-run --repl\n<span style='color:#7c3aed'>eshkol></span> (+ 1 2)\n<span style='color:#a78bfa'>3</span>\n<span style='color:#7c3aed'>eshkol></span> (map (lambda (x) (* x x)) '(1 2 3 4 5))\n<span style='color:#a78bfa'>(1 4 9 16 25)</span>")

    ;; System requirements
    (section-subheading page "System Requirements")

    (let ((reqs (create-grid-2 page)))
      (let ((r1 (create-card reqs)))
        (let ((h (create-text "h3" "Runtime" r1)))
          (style! h "color" "#a78bfa")
          (style! h "marginBottom" "8px"))
        (body-text r1 "No runtime dependencies. Eshkol compiles to standalone native binaries. The compiled output links only against libc and system libraries (libm, libpthread)."))

      (let ((r2 (create-card reqs)))
        (let ((h (create-text "h3" "Build Requirements" r2)))
          (style! h "color" "#a78bfa")
          (style! h "marginBottom" "8px"))
        (body-text r2 "LLVM 21+ (for the compiler backend), C++20 compiler (GCC 12+ or Clang 15+), CMake 3.14+. Optional: Metal SDK (GPU on macOS), CUDA toolkit (GPU on Linux).")))

    (render-footer page)))

;; ═══════════════════════════════════════════════════════════
;; PAGE: PLAYGROUND
;; ═══════════════════════════════════════════════════════════

(define (render-playground-page content)
  (let ((page (create-section content)))
    (create-page-header page "Playground" "The full Eshkol bytecode VM running in your browser.")

    ;; REPL Terminal
    (let ((terminal (create-div page)))
      (web-add-class terminal "repl-terminal")
      (style! terminal "marginBottom" "48px")

      ;; Title bar
      (let ((titlebar (create-div terminal)))
        (web-add-class titlebar "repl-titlebar")

        ;; Window dots
        (let ((dots (create-div titlebar)))
          (style! dots "display" "flex")
          (style! dots "gap" "6px")
          (let ((d1 (create-div dots)))
            (web-add-class d1 "repl-dot")
            (style! d1 "background" "#ff5f57"))
          (let ((d2 (create-div dots)))
            (web-add-class d2 "repl-dot")
            (style! d2 "background" "#febc2e"))
          (let ((d3 (create-div dots)))
            (web-add-class d3 "repl-dot")
            (style! d3 "background" "#28c840")))

        (let ((title (create-text "span" "Eshkol REPL — Bytecode VM (WebAssembly)" titlebar)))
          (style! title "color" "#71717a")
          (style! title "fontSize" "0.8rem")
          (style! title "marginLeft" "12px")))

      ;; Terminal output area
      (let ((output (create-div terminal)))
        (web-set-attribute output "id" "repl-output")
        (style! output "padding" "16px 20px")
        (style! output "fontFamily" "'JetBrains Mono', monospace")
        (style! output "fontSize" "0.85rem")
        (style! output "lineHeight" "1.5")
        (style! output "color" "#e8e8f0")
        (style! output "minHeight" "300px")
        (style! output "maxHeight" "500px")
        (style! output "overflow" "auto")
        (style! output "whiteSpace" "pre-wrap")

        ;; Welcome message
        (web-set-inner-html output
          "<span style='color:#7c3aed;font-weight:bold'>Eshkol Bytecode VM</span> <span style='color:#71717a'>v1.1.13-accelerate</span>\n<span style='color:#71717a'>63-opcode ISA | Arena memory (OALR) | R7RS Scheme</span>\n<span style='color:#71717a'>Type an expression and press Enter.</span>\n\n"))

      ;; Terminal input area
      (let ((input-row (create-div terminal)))
        (style! input-row "display" "flex")
        (style! input-row "alignItems" "center")
        (style! input-row "padding" "8px 20px 12px")
        (style! input-row "borderTop" "1px solid #27272a")

        (let ((prompt (create-text "span" "eshkol> " input-row)))
          (style! prompt "color" "#7c3aed")
          (style! prompt "fontFamily" "'JetBrains Mono', monospace")
          (style! prompt "fontSize" "0.85rem")
          (style! prompt "fontWeight" "bold"))

        (let ((input (web-create-element "input")))
          (web-set-attribute input "id" "repl-input")
          (web-set-attribute input "type" "text")
          (web-set-attribute input "placeholder" "(+ 1 2)")
          (web-set-attribute input "autocomplete" "off")
          (web-set-attribute input "spellcheck" "false")
          (style! input "background" "transparent")
          (style! input "border" "none")
          (style! input "outline" "none")
          (style! input "color" "#e8e8f0")
          (style! input "fontFamily" "'JetBrains Mono', monospace")
          (style! input "fontSize" "0.85rem")
          (style! input "flex" "1")
          (web-append-child input-row input))))

    ;; WASM showcase banner
    (let ((banner (create-div page)))
      (web-add-class banner "card-highlight")
      (style! banner "marginBottom" "48px")

      (let ((h (create-text "h2" "Two WASM Modules, One Website" banner)))
        (style! h "fontSize" "1.5rem")
        (style! h "marginBottom" "12px"))

      (body-text banner "This website runs TWO Eshkol WASM modules simultaneously: the site renderer (compiled via LLVM to WebAssembly) and the bytecode VM interpreter (compiled via Emscripten). The REPL above executes real Eshkol code through the full 63-opcode bytecode interpreter.")

      (body-text banner "Try: (+ 1 2), (map (lambda (x) (* x x)) '(1 2 3 4 5)), (define (fib n) (if (< n 2) n (+ (fib (- n 1)) (fib (- n 2))))) then (fib 20)"))

    ;; Architecture diagram
    (section-subheading page "Architecture")
    (create-code-block page
      "  <span style='color:#a78bfa'>Website</span>                        <span style='color:#a78bfa'>REPL</span>\n  main.esk                       eshkol_vm.c + eshkol_compiler.c\n      |                                |\n  LLVM IR (eshkol-run --wasm)    Emscripten (emcc)\n      |                                |\n  eshkol-site.wasm               eshkol-vm.wasm\n      |                                |\n  eshkol-runtime.js              Emscripten glue\n      |                                |\n      +----------<span style='color:#22c55e'> Browser </span>-----------+")

    ;; Stats
    (section-subheading page "Site Statistics")
    (let ((stats (create-grid-4 page)))
      (let ((s1 (create-card stats)))
        (web-add-class s1 "text-center")
        (let ((v (create-text "div" "484KB" s1))) (web-add-class v "stat-value") (style! v "fontSize" "1.8rem"))
        (let ((l (create-text "div" "Site WASM" s1))) (web-add-class l "stat-label")))

      (let ((s2 (create-card stats)))
        (web-add-class s2 "text-center")
        (let ((v (create-text "div" "380KB" s2))) (web-add-class v "stat-value") (style! v "fontSize" "1.8rem"))
        (let ((l (create-text "div" "VM WASM" s2))) (web-add-class l "stat-label")))

      (let ((s3 (create-card stats)))
        (web-add-class s3 "text-center")
        (let ((v (create-text "div" "63" s3))) (web-add-class v "stat-value") (style! v "fontSize" "1.8rem"))
        (let ((l (create-text "div" "VM Opcodes" s3))) (web-add-class l "stat-label")))

      (let ((s4 (create-card stats)))
        (web-add-class s4 "text-center")
        (let ((v (create-text "div" "59" s4))) (web-add-class v "stat-value") (style! v "fontSize" "1.8rem"))
        (let ((l (create-text "div" "DOM Bindings" s4))) (web-add-class l "stat-label"))))

    ;; Example snippets to try
    (create-divider page)
    (section-subheading page "Try These")
    (body-text page "Click to copy, then paste into the REPL above.")

    (let ((snippets (create-grid-3 page)))
      (let ((sn1 (create-card snippets)))
        (let ((h (create-text "h4" "Arithmetic" sn1)))
          (style! h "color" "#a78bfa")
          (style! h "fontSize" "0.9rem")
          (style! h "marginBottom" "8px"))
        (create-code-block sn1
          "<span style='color:#c084fc'>(+</span> <span style='color:#00ff88'>1</span> <span style='color:#00ff88'>2</span><span style='color:#c084fc'>)</span>\n<span style='color:#c084fc'>(*</span> <span style='color:#00ff88'>6</span> <span style='color:#00ff88'>7</span><span style='color:#c084fc'>)</span>\n<span style='color:#c084fc'>(expt</span> <span style='color:#00ff88'>2</span> <span style='color:#00ff88'>10</span><span style='color:#c084fc'>)</span>"))

      (let ((sn2 (create-card snippets)))
        (let ((h (create-text "h4" "Lists" sn2)))
          (style! h "color" "#a78bfa")
          (style! h "fontSize" "0.9rem")
          (style! h "marginBottom" "8px"))
        (create-code-block sn2
          "<span style='color:#c084fc'>(map</span> <span style='color:#c084fc'>(lambda</span> <span style='color:#a78bfa'>(x)</span> <span style='color:#c084fc'>(*</span> x x<span style='color:#c084fc'>))</span>\n  <span style='color:#00ff88'>'(1 2 3 4 5)</span><span style='color:#c084fc'>)</span>"))

      (let ((sn3 (create-card snippets)))
        (let ((h (create-text "h4" "Recursion" sn3)))
          (style! h "color" "#a78bfa")
          (style! h "fontSize" "0.9rem")
          (style! h "marginBottom" "8px"))
        (create-code-block sn3
          "<span style='color:#c084fc'>(define</span> <span style='color:#a78bfa'>(fact n)</span>\n  <span style='color:#c084fc'>(if</span> <span style='color:#c084fc'>(=</span> n <span style='color:#00ff88'>0</span><span style='color:#c084fc'>)</span> <span style='color:#00ff88'>1</span>\n    <span style='color:#c084fc'>(*</span> n <span style='color:#c084fc'>(fact</span> <span style='color:#c084fc'>(-</span> n <span style='color:#00ff88'>1</span><span style='color:#c084fc'>)))))</span>\n<span style='color:#c084fc'>(fact</span> <span style='color:#00ff88'>10</span><span style='color:#c084fc'>)</span>")))

    (render-footer page)))

;; ═══════════════════════════════════════════════════════════
;; PAGE: COMMUNITY
;; ═══════════════════════════════════════════════════════════

(define (render-community-page content)
  (let ((page (create-section content)))
    (create-page-header page "Community" "Join the Eshkol project.")

    ;; GitHub links
    (section-subheading page "GitHub")
    (body-text page "Eshkol is developed in the open on GitHub. Star, fork, or contribute.")

    (let ((links (create-grid-3 page)))
      (let ((c1 (create-card links)))
        (let ((h (create-text "h3" "Repository" c1)))
          (style! h "color" "#a78bfa")
          (style! h "marginBottom" "8px"))
        (body-text c1 "Source code, issues, and pull requests.")
        (let ((a (create-text "a" "github.com/tsotchke/eshkol" c1)))
          (web-set-attribute a "href" "https://github.com/tsotchke/eshkol")
          (web-set-attribute a "target" "_blank")))

      (let ((c2 (create-card links)))
        (let ((h (create-text "h3" "Issues" c2)))
          (style! h "color" "#a78bfa")
          (style! h "marginBottom" "8px"))
        (body-text c2 "Report bugs, request features, or ask questions.")
        (let ((a (create-text "a" "Issue Tracker" c2)))
          (web-set-attribute a "href" "https://github.com/tsotchke/eshkol/issues")
          (web-set-attribute a "target" "_blank")))

      (let ((c3 (create-card links)))
        (let ((h (create-text "h3" "Discussions" c3)))
          (style! h "color" "#a78bfa")
          (style! h "marginBottom" "8px"))
        (body-text c3 "Ask questions, share ideas, and discuss the language.")
        (let ((a (create-text "a" "GitHub Discussions" c3)))
          (web-set-attribute a "href" "https://github.com/tsotchke/eshkol/discussions")
          (web-set-attribute a "target" "_blank"))))

    (create-divider page)

    ;; Contributing
    (section-subheading page "Contributing")
    (body-text page "Eshkol is open source under the MIT License. Contributions are welcome -- from bug fixes to new language features. See the Contributing Guide for code style, PR process, and development setup.")
    (body-text page "The compiler is written in C++20 with LLVM 21+ as the backend. The standard library is written in Eshkol itself. Test suites use shell scripts in the scripts/ directory.")

    (create-divider page)

    ;; Development setup
    (section-subheading page "Development Setup")
    (body-text page "To build Eshkol from source for development, you need LLVM 21+, a C++20 compiler (GCC 12+ or Clang 15+), and CMake 3.14+.")
    (create-code-block page
      "<code style='color:#22c55e'>$</code> git clone https://github.com/tsotchke/eshkol.git\n<code style='color:#22c55e'>$</code> cd eshkol && mkdir build && cd build\n<code style='color:#22c55e'>$</code> cmake .. -DCMAKE_BUILD_TYPE=Debug\n<code style='color:#22c55e'>$</code> make -j8\n<code style='color:#22c55e'>$</code> ./scripts/run_all_tests.sh")
    (body-text page "Run the full test suite with scripts/run_all_tests.sh. Individual test suites can be run with scripts/run_numeric_tests.sh, scripts/run_macros_tests.sh, etc.")

    (create-divider page)

    ;; What makes Eshkol different
    (section-subheading page "What Makes Eshkol Different")

    (let ((diff-grid (create-grid-2 page)))
      (let ((d1 (create-card diff-grid)))
        (let ((h (create-text "h3" "AD at the Compiler Level" d1)))
          (style! h "color" "#a78bfa")
          (style! h "marginBottom" "8px"))
        (body-text d1 "Other languages bolt on differentiation as a library (JAX, Zygote, PyTorch). Eshkol integrates AD directly into the LLVM codegen pipeline. The compiler sees gradients the same way it sees addition -- as a native operation to optimize."))

      (let ((d2 (create-card diff-grid)))
        (let ((h (create-text "h3" "Deterministic Performance" d2)))
          (style! h "color" "#a78bfa")
          (style! h "marginBottom" "8px"))
        (body-text d2 "Arena-based memory means no garbage collector, no reference counting, no stop-the-world pauses. Allocation is O(1) via bump pointer. Deallocation is automatic at scope boundaries. Perfect for real-time systems and simulations."))

      (let ((d3 (create-card diff-grid)))
        (let ((h (create-text "h3" "Self-Modifying Programs" d3)))
          (style! h "color" "#a78bfa")
          (style! h "marginBottom" "8px"))
        (body-text d3 "Homoiconicity means every function can inspect and transform its own source code. Combined with knowledge bases and probabilistic inference, this enables programs that reason about and improve themselves."))

      (let ((d4 (create-card diff-grid)))
        (let ((h (create-text "h3" "One Language, All Targets" d4)))
          (style! h "color" "#a78bfa")
          (style! h "marginBottom" "8px"))
        (body-text d4 "Write once, compile to native ARM64/x86_64, WebAssembly, or GPU compute shaders. The same tensor operation dispatches to Metal on a MacBook, CUDA on a workstation, and SIMD on a Raspberry Pi.")))

    (create-divider page)

    ;; About
    (section-subheading page "About Eshkol")
    (body-text page "Eshkol is developed by Tsotchke Corporation. The name comes from the Hebrew word for 'cluster' -- a reference to both grape clusters (abundance) and computational clusters (parallel computing).")
    (body-text page "Eshkol is the first production programming language to integrate automatic differentiation directly at the compiler level, making calculus operations as natural and efficient as basic arithmetic. It combines the elegance of Scheme with the performance of compiled native code.")
    (body-text page "The language targets scientific computing, machine learning, and autonomous systems -- domains where mathematical precision, deterministic performance, and hardware acceleration matter.")

    (create-divider page)

    ;; License
    (section-subheading page "License")
    (body-text page "MIT License. Free for commercial and non-commercial use. See the LICENSE file in the repository for full terms.")

    (render-footer page)))

;; ═══════════════════════════════════════════════════════════
;; ROUTER
;; ═══════════════════════════════════════════════════════════

;; Route buffer for reading URL hash
(define route-buf "                                                                                                                                                                                                                                                                ")

(define (route!)
  (let ((content (web-get-element-by-id "content")))
    (let ((hash-len (web-get-hash route-buf 256)))
      (web-set-inner-html content "")
      (web-scroll-to 0 0)
      (cond
        ((string=? route-buf "/learn")
         (render-learn-page content))
        ((string=? route-buf "/tutorials")
         (render-tutorials-page content))
        ((string=? route-buf "/examples")
         (render-examples-page content))
        ((string=? route-buf "/docs")
         (render-docs-page content))
        ((string=? route-buf "/downloads")
         (render-downloads-page content))
        ((string=? route-buf "/download")
         (render-downloads-page content))
        ((string=? route-buf "/playground")
         (render-playground-page content))
        ((string=? route-buf "/community")
         (render-community-page content))
        (else
         (render-landing content))))))

;; ═══════════════════════════════════════════════════════════
;; MAIN ENTRY POINT
;; ═══════════════════════════════════════════════════════════

(define (main)
  (let ((body (web-get-body))
        (existing (web-get-element-by-id "content")))
    (if (= existing 0)
      ;; First load: set up body styles, nav, and content container
      (begin
        (style! body "margin" "0")
        (style! body "fontFamily" "'Inter', system-ui, sans-serif")
        (style! body "backgroundColor" "#09090b")
        (style! body "color" "#d4d4d8")
        (style! body "lineHeight" "1.7")
        (render-nav body)
        (let ((content (create-div body)))
          (web-set-attribute content "id" "content")
          (style! content "paddingTop" "64px")
          (route!))
        (web-console-log "Eshkol website loaded — written in Eshkol, compiled to WebAssembly"))
      ;; Subsequent calls (hashchange): clear content and re-route
      (begin
        (web-set-inner-html existing "")
        (web-scroll-to 0 0)
        (route!)))
    0))

