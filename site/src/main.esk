          (render-sidebar-item gt "Functional Programming" "https://raw.githubusercontent.com/tsotchke/eshkol/master/docs/tutorials/17_FUNCTIONAL_PROGRAMMING.md")
          (render-sidebar-item gt "Web Platform" "https://raw.githubusercontent.com/tsotchke/eshkol/master/docs/tutorials/18_WEB_PLATFORM.md")
          (render-sidebar-item gt "GPU Acceleration" "https://raw.githubusercontent.com/tsotchke/eshkol/master/docs/tutorials/19_GPU_ACCELERATION.md")
          (render-sidebar-item gt "Bitwise & System" "https://raw.githubusercontent.com/tsotchke/eshkol/master/docs/tutorials/20_BITWISE_AND_SYSTEM.md"))

        ;; Project Tutorials
        (let ((gp (render-sidebar-group sidebar "PROJECT TUTORIALS")))
