(define A (reshape (arange 6) 2 3))
(define B (reshape (arange 6) 3 2))
(define C (matmul A B))
(display (tensor-data C))
(newline)
(display (tensor-ref C 0 0)) (display " ")
(display (tensor-ref C 0 1)) (display " ")
(display (tensor-ref C 1 0)) (display " ")
(display (tensor-ref C 1 1)) (newline)
