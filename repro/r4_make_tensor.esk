(define A (make-tensor (list 2 2) 0.0))
(tensor-set! A (list 0 0) 1.0)
(tensor-set! A (list 0 1) 2.0)
(tensor-set! A (list 1 0) 3.0)
(tensor-set! A (list 1 1) 4.0)
(define B (make-tensor (list 2 2) 0.0))
(tensor-set! B (list 0 0) 5.0)
(tensor-set! B (list 0 1) 6.0)
(tensor-set! B (list 1 0) 7.0)
(tensor-set! B (list 1 1) 8.0)
(display (tensor-data (matmul A B)))
(newline)
